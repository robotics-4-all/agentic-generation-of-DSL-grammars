SmAutoModel:
    (
        metadata=Metadata?
        brokers*=Broker
        authentications*=Authentication
        entities*=Entity
        automations*=Automation
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'hybrid' | 'virtual'
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'array' | 'object'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

BehaviorAction:
    'publish' | 'subscribe' | 'request' | 'response'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ExecutionMode:
    'sequential' | 'parallel' | 'async'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

Behavior:
    name=ID ':' action=BehaviorAction
;

PayloadItem:
    key=STRING ':' value=PropertyValue
;

ObjectPayload:
    '{' items*=PayloadItem[','] '}'
;

ActionPayload:
    STRING | PropertyValue | ObjectPayload
;

ActionParameters:
    '[' params*=PropertyValue[','] ']'
;

RetryPolicy:
    'RetryPolicy' '(' attempts=INT ',' delay=INT ')'
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' seconds=INT ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[Authentication])?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | RedisBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[Broker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

EventTrigger:
    'Event' '(' entity=[Entity] ',' event=STRING ')'
;

TimeTrigger:
    'Time' '(' schedule=TimeSchedule ')'
;

StateTrigger:
    'State' '(' entity=[Entity] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

Trigger:
    EventTrigger | TimeTrigger | StateTrigger
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

PrimitiveCondition:
    SimpleCondition | '(' ComplexCondition ')'
;

ComplexCondition:
    left=PrimitiveCondition (operator=LogicalOperator right=PrimitiveCondition)*
;

Condition:
    ComplexCondition | SimpleCondition
;

PublishAction:
    'Publish' '(' entity=[Entity] ',' topic=STRING ',' payload=ActionPayload ')'
;

CallAction:
    'Call' '(' entity=[Entity] ',' method=STRING (',' parameters=ActionParameters)? ')'
;

SetAction:
    'Set' '(' entity=[Entity] ',' property=ID ',' value=PropertyValue ')'
;

DelayAction:
    'Delay' '(' duration=INT ')'
;

Action:
    PublishAction | CallAction | SetAction | DelayAction
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('priority:' priority=INT)?
        ('timeout:' timeout=INT)?
        ('retry:' retry=RetryPolicy)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('execution:' execution=ExecutionControl)?
        ('description:' description=STRING)?
    )#
    'end'
;