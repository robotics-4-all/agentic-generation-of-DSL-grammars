SmartHomeModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication=AuthenticationConfig?
        entities*=EntityDefinition
        automations*=AutomationDeclaration
    )#
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)
        ('ssl:' ssl=BOOL)?
        ('vhost:' vhost=STRING)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

AuthenticationConfig:
    'Authentication'
    (
        ('type:' auth_type=AuthType)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('token:' token=STRING)?
        ('api_key:' api_key=STRING)?
        ('cert_path:' cert_path=STRING)?
    )#
    'end'
;

AuthType:
    'basic' | 'token' | 'api_key' | 'certificate' | 'oauth'
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'switch' | 'light' | 'thermostat' | 'camera' | 'door' | 'window' | 'motion' | 'temperature' | 'humidity' | 'custom'
;

PropertyDefinition:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)? ('(' unit=STRING ')')?
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | ArrayValue | ObjectValue
;

ArrayValue:
    '[' items*=PropertyValue[','] ']'
;

ObjectValue:
    '{' items*=ObjectItem[','] '}'
;

ObjectItem:
    key=STRING ':' value=PropertyValue
;

BehaviorDefinition:
    name=ID ':' behavior_type=BehaviorType ('(' parameters=ParameterList ')')?
;

BehaviorType:
    'read' | 'write' | 'toggle' | 'increment' | 'decrement' | 'notify' | 'custom'
;

ParameterList:
    parameters*=Parameter[',']
;

Parameter:
    name=ID '=' value=PropertyValue
;

AutomationDeclaration:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDefinition)
        ('conditions:' '-' conditions*=ConditionSpecification['-'])?
        ('actions:' '-' actions*=ActionDefinition['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;

TriggerDefinition:
    EntityTrigger | TimeTrigger | EventTrigger
;

EntityTrigger:
    'entity_state_change' '(' entity=[EntityDefinition] ',' property=ID (',' previous_value=PropertyValue)? ')'
;

TimeTrigger:
    'time_schedule' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'custom_event' '(' event_name=STRING ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule | FixedTimeSchedule
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' duration=INT ',' unit=TimeUnit ')'
;

FixedTimeSchedule:
    'at' '(' time=STRING ')'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ConditionSpecification:
    condition=LogicalCondition
;

PrimitiveCondition:
    EntityCondition | TimeCondition | ValueCondition
;

EntityCondition:
    entity=[EntityDefinition] '.' property=ID comparator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' comparator=ComparisonOperator value=STRING
;

ValueCondition:
    left=PropertyValue comparator=ComparisonOperator right=PropertyValue
;

ComparisonCondition:
    '(' condition=LogicalCondition ')' | PrimitiveCondition
;

LogicalCondition:
    left=ComparisonCondition (operator=LogicalOperator right=ComparisonCondition)*
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'starts_with' | 'ends_with'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ActionDefinition:
    EntityAction | NotificationAction | DelayAction | CustomAction
;

EntityAction:
    'set_entity' '(' entity=[EntityDefinition] ',' property=ID ',' value=PropertyValue ')'
;

NotificationAction:
    'send_notification' '(' message=STRING (',' recipients=STRING)? ')'
;

DelayAction:
    'delay' '(' duration=INT ',' unit=TimeUnit ')'
;

CustomAction:
    'custom_action' '(' action_name=STRING (',' parameters=ParameterList)? ')'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;