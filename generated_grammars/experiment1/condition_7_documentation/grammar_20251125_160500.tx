SmAutoModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'hybrid' | 'device' | 'controller'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | ArrayValue | ObjectValue
;

ArrayValue:
    '[' items*=PropertyValue[','] ']'
;

ObjectValue:
    '{' items*=ObjectItem[','] '}'
;

ObjectItem:
    key=STRING ':' value=PropertyValue
;

PropertyDef:
    name=ID ':' dtype=DataType ('=' default=PropertyValue)?
;

BehaviorDef:
    name=ID ':' action=ActionDef
;

PlainAuth:
    'Auth<Plain>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

ApiKeyAuth:
    'Auth<ApiKey>' name=ID
    (
        ('key:' key=STRING)
    )#
    'end'
;

CertAuth:
    'Auth<Cert>' name=ID
    (
        ('cert:' cert=STRING)
        ('certPath:' certPath=STRING)?
    )#
    'end'
;

AuthConfig:
    PlainAuth | ApiKeyAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('basePath:' basePath=STRING)?
        ('webPath:' webPath=STRING)?
        ('webPort:' webPort=INT)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('topicExchange:' topicE=STRING)?
        ('rpcExchange:' rpcE=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' value=INT unit=TimeUnit ')'
;

FixedTimeSchedule:
    'at' '(' time=STRING ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule | FixedTimeSchedule
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[EntityDef] ',' event=STRING ')'
;

StateTrigger:
    'state' '(' entity=[EntityDef] ',' property=ID ',' condition=ComparisonCondition ')'
;

TriggerDef:
    TimeTrigger | EventTrigger | StateTrigger
;

EntityPropertyRef:
    entity=[EntityDef] '.' property=ID
;

FunctionCall:
    name=ID '(' args*=ConditionOperand[','] ')'
;

ConditionOperand:
    PropertyValue | EntityPropertyRef | FunctionCall
;

ComparisonCondition:
    left=ConditionOperand operator=ComparisonOperator right=ConditionOperand
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

StateCondition:
    entity=[EntityDef] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

Condition:
    '(' group=ConditionGroup ')' | ComparisonCondition | TimeCondition | StateCondition
;

ConditionGroup:
    conditions+=Condition (operator=LogicalOperator conditions+=Condition)*
;

SetPropertyAction:
    'set' '(' entity=[EntityDef] ',' property=ID ',' value=PropertyValue ')'
;

CallServiceAction:
    'call' '(' service=STRING ',' params=ObjectValue? ')'
;

SendMessageAction:
    'send' '(' broker=[BrokerConfig] ',' topic=STRING ',' message=PropertyValue ')'
;

DelayAction:
    'delay' '(' duration=INT unit=TimeUnit ')'
;

ActionDef:
    SetPropertyAction | CallServiceAction | SendMessageAction | DelayAction
;

AutomationDef:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' conditions=ConditionGroup)?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;