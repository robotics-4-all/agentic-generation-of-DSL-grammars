SmAutoModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication=AuthenticationConfig?
        entities*=EntityDefinition
        automations*=AutomationRule
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('system:' system=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('topic:' topic=STRING)?
        ('auth:' auth=AuthenticationMethod)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=AuthenticationMethod)?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=AuthenticationMethod)?
    )#
    'end'
;

AuthenticationConfig:
    'Authentication'
    (
        ('method:' method=AuthMethod)
        ('config:' config=AuthenticationMethod)?
    )#
    'end'
;

AuthMethod:
    'basic' | 'token' | 'certificate' | 'oauth'
;

AuthenticationMethod:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Basic'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Token'
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Certificate'
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
        ('ca:' ca=STRING)?
    )#
    'end'
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('state:' state=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'switch' | 'light' | 'thermostat' | 'camera' | 'lock' | 'alarm' | 'other'
;

PropertyDefinition:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'timestamp' | 'json'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

BehaviorDefinition:
    name=ID ':' behavior=BehaviorType
;

BehaviorType:
    'on' | 'off' | 'toggle' | 'set' | 'get' | 'notify'
;

AutomationRule:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDefinition)
        ('conditions:' '-' conditions*=ConditionDefinition['-'])?
        ('actions:' '-' actions*=ActionDefinition['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

TriggerDefinition:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'Time'
    (
        ('schedule:' schedule=STRING)
        ('timezone:' timezone=STRING)?
    )#
;

EventTrigger:
    'Event'
    (
        ('entity:' entity=[EntityDefinition])
        ('event:' event=STRING)
    )#
;

StateTrigger:
    'State'
    (
        ('entity:' entity=[EntityDefinition])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('delay:' delay=INT)?
        ('timeout:' timeout=INT)?
        ('retries:' retries=INT)?
    )#
    'end'
;

ExecutionMode:
    'immediate' | 'delayed' | 'queued' | 'parallel'
;

ConditionDefinition:
    left=PrimitiveCondition (operator=LogicalOperator right=PrimitiveCondition)*
;

PrimitiveCondition:
    '(' condition=ConditionDefinition ')' | ComparisonCondition | TimeCondition
;

ComparisonCondition:
    'Compare'
    (
        ('entity:' entity=[EntityDefinition])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

TimeCondition:
    'Time'
    (
        ('start:' startTime=STRING)
        ('end:' endTime=STRING)?
        ('days:' days=STRING)?
    )#
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

ActionDefinition:
    EntityAction | NotificationAction | ScriptAction
;

EntityAction:
    'EntityAction'
    (
        ('entity:' entity=[EntityDefinition])
        ('behavior:' behavior=STRING)
        ('parameters:' parameters=ActionParameters)?
    )#
;

NotificationAction:
    'Notification'
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)?
        ('priority:' priority=STRING)?
    )#
;

ScriptAction:
    'Script'
    (
        ('language:' language=STRING)
        ('code:' code=STRING)
        ('parameters:' parameters=ActionParameters)?
    )#
;

ActionParameters:
    '{' params*=ParameterDefinition[','] '}'
;

ParameterDefinition:
    name=ID ':' value=PropertyValue
;