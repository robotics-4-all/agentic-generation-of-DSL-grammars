SmAutoModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth_configs*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic_prefix:' topic_prefix=STRING)?
        ('qos:' qos=INT)?
        ('retain:' retain=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('vhost:' vhost=STRING)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('base_url:' base_url=STRING)
        ('timeout:' timeout=INT)?
        ('headers:' headers=PropertyMap)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AuthConfig:
    BasicAuth | ApiKeyAuth | TokenAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

ApiKeyAuth:
    'Auth<ApiKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)?
        ('properties:' properties=PropertyMap)?
        ('behaviors:' behaviors*=BehaviorDef)*
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'switch' | 'light' | 'thermostat' | 'camera' | 'lock' | 'other'
;

BehaviorDef:
    'Behavior' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('action:' action=ActionDef)
    )#
    'end'
;

TriggerDef:
    'on_state_change' | 'on_value_change' | 'on_threshold' | 'periodic'
;

AutomationDef:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('conditions:' conditions=ConditionGroup)
        ('actions:' actions*=ActionDef)*
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

ConditionGroup:
    left=Condition (operator=LogicalOperator right=Condition)*
;

Condition:
    '(' group=ConditionGroup ')' |
    PropertyCondition |
    TimeCondition |
    StateCondition
;

PropertyCondition:
    entity=[EntityDef] '.' property=ID operator=ComparisonOperator value=Value
;

TimeCondition:
    'time' operator=ComparisonOperator value=TimeValue
;

StateCondition:
    entity=[EntityDef] '.' 'state' operator=ComparisonOperator value=STRING
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

ActionDef:
    SetPropertyAction | CallServiceAction | SendNotificationAction | DelayAction
;

SetPropertyAction:
    'set' entity=[EntityDef] '.' property=ID '=' value=Value
;

CallServiceAction:
    'call' service=STRING '(' params=PropertyMap? ')'
;

SendNotificationAction:
    'notify' message=STRING ('to' target=STRING)?
;

DelayAction:
    'delay' duration=INT unit=TimeUnit
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('max_runs:' max_runs=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ExecutionMode:
    'single' | 'restart' | 'parallel' | 'queued'
;

PropertyMap:
    '{' items*=PropertyItem[','] '}'
;

PropertyItem:
    key=STRING ':' value=Value
;

Value:
    FLOAT | INT | STRING | BOOL | PropertyMap | ValueArray
;

ValueArray:
    '[' items*=Value[','] ']'
;

TimeValue:
    time=TIME | duration=Duration
;

TIME:
    /([0-1]?[0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?/
;

Duration:
    value=INT unit=TimeUnit
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;