SmartHomeModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        entities*=Entity
        automations*=Automation
    )#
;

DataType:
    'int' | 'float' | 'bool' | 'string' | 'json' | 'array'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'hub'
;

TopicType:
    'command' | 'status' | 'sensor' | 'event'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

BehaviorType:
    'read' | 'write' | 'notify' | 'command'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ScriptLanguage:
    'python' | 'javascript' | 'lua' | 'shell'
;

ExecutionMode:
    'single' | 'parallel' | 'queued' | 'restart'
;

TopicConfig:
    name=STRING ':' type=TopicType
;

HTTPEndpoint:
    path=STRING ':' method=HTTPMethod
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

Behavior:
    name=ID ':' behaviorType=BehaviorType
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

BasicAuth:
    'BasicAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'CertAuth'
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
        ('topics:' '-' topics*=TopicConfig['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
        ('endpoints:' '-' endpoints*=HTTPEndpoint['-'])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('timezone:' timezone=STRING)?
    )#
;

EventTrigger:
    'EventTrigger'
    (
        ('entity:' entity=[Entity])
        ('event:' event=STRING)
        ('value:' value=PropertyValue)?
    )#
;

StateTrigger:
    'StateTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

Trigger:
    TimeTrigger | EventTrigger | StateTrigger
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ConditionExpression:
    left=SimpleCondition (operator=LogicalOperator right=SimpleCondition)*
;

Condition:
    ConditionExpression | '(' ConditionExpression ')'
;

EntityAction:
    'EntityAction'
    (
        ('entity:' entity=[Entity])
        ('command:' command=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
;

NotificationAction:
    'NotificationAction'
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)?
        ('priority:' priority=NotificationPriority)?
    )#
;

DelayAction:
    'DelayAction'
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
;

ScriptAction:
    'ScriptAction'
    (
        ('script:' script=STRING)
        ('language:' language=ScriptLanguage)?
    )#
;

Action:
    EntityAction | NotificationAction | DelayAction | ScriptAction
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('maxRuns:' maxRuns=INT)?
        ('cooldown:' cooldown=INT)?
        ('timeout:' timeout=INT)?
    )#
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('execution:' execution=ExecutionControl)?
        ('description:' description=STRING)?
    )#
    'end'
;

Comment: CommentLine | CommentBlock;
CommentLine: /\/\/.*?$/;
CommentBlock: /\/\*(.|\n)*?\*\//;