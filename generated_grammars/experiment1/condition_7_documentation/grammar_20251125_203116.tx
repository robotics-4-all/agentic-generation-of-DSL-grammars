SmAutoModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

APIKeyLocation:
    'header' | 'query' | 'cookie'
;

DataType:
    'string' | 'float' | 'int' | 'bool' | 'object' | 'array'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days' | 'weeks'
;

ComparisonOp:
    '==' | '!=' | '>=' | '<=' | '>' | '<'
;

LogicalOp:
    'and' | 'or' | 'not'
;

SystemProperty:
    'sunrise' | 'sunset' | 'dayOfWeek' | 'temperature' | 'humidity' | 'pressure'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'webhook'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

ScriptLanguage:
    'javascript' | 'python' | 'lua' | 'shell'
;

ExecutionMode:
    'sequential' | 'parallel' | 'queued' | 'restart'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

ConditionValue:
    STRING | FLOAT | INT | BOOL | EntityRef
;

ActionValue:
    STRING | FLOAT | INT | BOOL | EntityRef | ExpressionValue
;

HeaderPair:
    key=STRING ':' value=STRING
;

HeaderList:
    '[' headers*=HeaderPair[','] ']'
;

PropertyDef:
    name=ID ':' type=DataType ('=' default=PropertyValue)?
;

PropertyList:
    '[' properties*=PropertyDef[','] ']'
;

TimeValue:
    hour=INT ':' minute=INT (':' second=INT)?
;

EntityRef:
    entity=[EntityDef] ('.' property=ID)?
;

ExpressionValue:
    'expr' '(' expression=STRING ')'
;

ParameterDef:
    name=ID ':' value=ActionValue
;

ParameterList:
    '[' parameters*=ParameterDef[','] ']'
;

RecipientList:
    '[' recipients*=STRING[','] ']'
;

FilterExpr:
    key=STRING operator=ComparisonOp value=ConditionValue
;

EventFilter:
    '[' filters*=FilterExpr[','] ']'
;

CronExpr:
    'cron' '(' expression=STRING ')'
;

TimeExpr:
    'at' '(' time=TimeValue ')'
;

IntervalExpr:
    'every' '(' interval=INT unit=TimeUnit ')'
;

ScheduleExpr:
    CronExpr | TimeExpr | IntervalExpr
;

ComparisonCondition:
    entity=[EntityDef] '.' property=ID operator=ComparisonOp value=ConditionValue
;

RangeCondition:
    entity=[EntityDef] '.' property=ID 'between' lower=FLOAT 'and' upper=FLOAT
;

ChangeCondition:
    entity=[EntityDef] '.' property=ID 'changed' ('to' target=ConditionValue)? ('from' previous=ConditionValue)?
;

StateCondition:
    ComparisonCondition | RangeCondition | ChangeCondition
;

EntityCondition:
    entity=[EntityDef] ('.' property=ID)? operator=ComparisonOp value=ConditionValue
;

TimeCondition:
    'time' operator=ComparisonOp time=TimeValue
;

SystemCondition:
    'system' '.' property=SystemProperty operator=ComparisonOp value=ConditionValue
;

SimpleCondition:
    EntityCondition | TimeCondition | SystemCondition
;

ConditionTerm:
    '(' condition=LogicalCondition ')' | SimpleCondition
;

LogicalCondition:
    left=ConditionTerm (operator=LogicalOp right=ConditionTerm)*
;

ConditionGroup:
    LogicalCondition
;

TimeTrigger:
    'Trigger<Time>'
    (
        ('schedule:' schedule=ScheduleExpr)
        ('timezone:' timezone=STRING)?
    )#
;

StateTrigger:
    'Trigger<State>'
    (
        ('entity:' entity=[EntityDef])
        ('condition:' condition=StateCondition)
        ('duration:' duration=INT)?
    )#
;

EventTrigger:
    'Trigger<Event>'
    (
        ('eventType:' eventType=STRING)
        ('source:' source=STRING)?
        ('filter:' filter=EventFilter)?
    )#
;

ManualTrigger:
    'Trigger<Manual>'
    (
        ('name:' triggerName=STRING)
        ('description:' description=STRING)?
    )#
;

TriggerDef:
    TimeTrigger | StateTrigger | EventTrigger | ManualTrigger
;

SetAction:
    'Action<Set>'
    (
        ('entity:' entity=[EntityDef])
        ('value:' value=ActionValue)
        ('property:' property=ID)?
    )#
;

CallAction:
    'Action<Call>'
    (
        ('service:' service=STRING)
        ('method:' method=STRING)
        ('parameters:' parameters=ParameterList)?
    )#
;

NotifyAction:
    'Action<Notify>'
    (
        ('message:' message=STRING)
        ('recipients:' recipients=RecipientList)?
        ('channel:' channel=NotificationChannel)?
        ('priority:' priority=NotificationPriority)?
    )#
;

DelayAction:
    'Action<Delay>'
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
;

ScriptAction:
    'Action<Script>'
    (
        ('language:' language=ScriptLanguage)
        ('code:' code=STRING)
        ('timeout:' timeout=INT)?
    )#
;

ActionDef:
    SetAction | CallAction | NotifyAction | DelayAction | ScriptAction
;

ActionList:
    '[' actions*=ActionDef[','] ']'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepAlive:' keepAlive=INT)?
        ('cleanSession:' cleanSession=BOOL)?
        ('clientId:' clientId=STRING)?
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('topicPrefix:' topicPrefix=STRING)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('baseUrl:' baseUrl=STRING)
        ('timeout:' timeout=INT)?
        ('retries:' retries=INT)?
        ('headers:' headers=HeaderList)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
        ('realm:' realm=STRING)?
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('tokenType:' tokenType=STRING)?
        ('refreshToken:' refreshToken=STRING)?
        ('expiresIn:' expiresIn=INT)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('caPath:' caPath=STRING)?
        ('passphrase:' passphrase=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('key:' key=STRING)
        ('location:' location=APIKeyLocation)
        ('paramName:' paramName=STRING)?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth | APIKeyAuth
;

SensorEntity:
    'Entity<Sensor>' name=ID
    (
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)
        ('dataType:' dataType=DataType)
        ('properties:' properties=PropertyList)?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
        ('pollInterval:' pollInterval=INT)?
        ('retain:' retain=BOOL)?
        ('qos:' qos=INT)?
    )#
    'end'
;

ActuatorEntity:
    'Entity<Actuator>' name=ID
    (
        ('broker:' broker=[BrokerConfig])
        ('commandTopic:' commandTopic=STRING)
        ('statusTopic:' statusTopic=STRING)?
        ('dataType:' dataType=DataType)
        ('properties:' properties=PropertyList)?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
        ('retain:' retain=BOOL)?
        ('qos:' qos=INT)?
    )#
    'end'
;

HybridEntity:
    'Entity<Hybrid>' name=ID
    (
        ('broker:' broker=[BrokerConfig])
        ('sensorTopic:' sensorTopic=STRING)
        ('commandTopic:' commandTopic=STRING)
        ('statusTopic:' statusTopic=STRING)?
        ('dataType:' dataType=DataType)
        ('properties:' properties=PropertyList)?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
        ('pollInterval:' pollInterval=INT)?
        ('retain:' retain=BOOL)?
        ('qos:' qos=INT)?
    )#
    'end'
;

EntityDef:
    SensorEntity | ActuatorEntity | HybridEntity
;

AutomationDef:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' conditions=ConditionGroup)?
        ('actions:' actions=ActionList)
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('description:' description=STRING)?
        ('executionMode:' executionMode=ExecutionMode)?
        ('maxExecutions:' maxExecutions=INT)?
        ('cooldownPeriod:' cooldownPeriod=INT)?
    )#
    'end'
;