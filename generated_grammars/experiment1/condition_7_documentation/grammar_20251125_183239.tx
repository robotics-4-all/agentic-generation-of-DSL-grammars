SmartHomeModel:
    (
        imports*=Import
        metadata=Metadata?
        brokers*=MessageBroker
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
    )#
;

Import:
    'import' importURI=STRING ('as' alias=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'switch' | 'light' | 'thermostat' | 'camera' | 'lock' | 'alarm' | 'other'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'json' | 'timestamp'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

BehaviorAction:
    'publish' | 'subscribe' | 'request' | 'response' | 'notify'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

TimeValue:
    time=STRING | duration=STRING
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

Behavior:
    name=ID ':' action=BehaviorAction
;

PropertyReference:
    entity=[Entity] '.' property=ID
;

Parameter:
    name=ID '=' value=PropertyValue
;

ParameterList:
    '[' parameters*=Parameter[','] ']'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[Authentication])?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
        ('endpoints:' '-' endpoints*=STRING['-'])?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

TimeCondition:
    'time' operator=ComparisonOperator value=TimeValue
;

EntityCondition:
    'entity' entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ValueCondition:
    'value' property=PropertyReference operator=ComparisonOperator value=PropertyValue
;

StateCondition:
    'state' entity=[Entity] '.' property=ID operator=ComparisonOperator state=STRING
;

Condition:
    '(' group=ConditionGroup ')' |
    TimeCondition |
    EntityCondition |
    ValueCondition |
    StateCondition
;

ConditionGroup:
    left=Condition (operator=LogicalOperator right=Condition)*
;

EntityAction:
    'action' 'entity' entity=[Entity] 'set' property=ID 'to' value=PropertyValue
;

NotificationAction:
    'action' 'notify' message=STRING ('to' target=STRING)?
;

DelayAction:
    'action' 'delay' duration=STRING
;

ScriptAction:
    'action' 'script' script=STRING ('with' parameters=ParameterList)?
;

Action:
    EntityAction | NotificationAction | DelayAction | ScriptAction
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('conditions:' conditions=ConditionGroup)
        ('actions:' '-' actions*=Action['-'])
        ('description:' description=STRING)?
    )#
    'end'
;

FQN:
    ID ('.' ID)*
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;