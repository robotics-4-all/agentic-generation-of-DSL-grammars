SmartHomeModel:
    (
        imports*=Import
        metadata=Metadata?
        broker=BrokerConfig?
        auth=AuthConfig?
        entities*=Entity
        automations*=Automation
    )#
;

Import:
    'import' importURI=STRING
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('basePath:' basePath=STRING)?
        ('webPath:' webPath=STRING)?
        ('webPort:' webPort=INT)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('topicExchange:' topicE=STRING)?
        ('rpcExchange:' rpcE=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

AuthConfig:
    'Authentication'
    (
        ('method:' method=AuthMethod)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('apiKey:' apiKey=STRING)?
        ('certPath:' certPath=STRING)?
    )#
    'end'
;

AuthMethod:
    'plain' | 'apikey' | 'certificate'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('topic:' topic=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'list' | 'dict'
;

List:
    '[' items*=PropertyValue[','] ']'
;

Dict:
    '{' items*=DictItem[','] '}'
;

DictItem:
    key=STRING ':' value=PropertyValue
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | List | Dict
;

Behavior:
    name=ID ':' action=BehaviorAction
;

BehaviorAction:
    'publish' | 'subscribe' | 'request' | 'response'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=TriggerCondition)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

EntityTrigger:
    'entity' entity=[Entity] 'property' property=ID operator=ComparisonOperator value=PropertyValue
;

CronExpression:
    'cron' expression=STRING
;

IntervalExpression:
    'interval' value=INT unit=TimeUnit
;

TimeSpecification:
    CronExpression | IntervalExpression
;

TimeTrigger:
    'time' timeSpec=TimeSpecification
;

EventTrigger:
    'event' eventType=STRING
;

TriggerCondition:
    EntityTrigger | TimeTrigger | EventTrigger
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

EntityCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator timeValue=TimeSpecification
;

PrimitiveCondition:
    EntityCondition | TimeCondition
;

Condition:
    left=PrimitiveCondition (logicalOp=LogicalOperator right=PrimitiveCondition)*
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

LogicalOperator:
    'and' | 'or' | 'not'
;

EntityAction:
    'set' entity=[Entity] '.' property=ID 'to' value=PropertyValue
;

NotificationAction:
    'notify' message=STRING ('to' recipient=STRING)?
;

DelayAction:
    'delay' duration=INT unit=TimeUnit
;

Action:
    EntityAction | NotificationAction | DelayAction
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;