SmartHomeModel:
    (
        metadata=Metadata
        brokers*=BrokerConfig
        auth*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

EntityType:
    'sensor' | 'actuator' | 'hybrid' | 'controller'
;

DataType:
    'str' | 'int' | 'float' | 'bool' | 'list' | 'dict'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | ListValue | DictValue
;

ListValue:
    '[' items*=PropertyValue[','] ']'
;

DictValue:
    '{' items*=DictItem[','] '}'
;

DictItem:
    key=STRING ':' value=PropertyValue
;

PropertyDef:
    name=ID ':' datatype=DataType ('=' defaultValue=PropertyValue)?
;

ActionType:
    'read' | 'write' | 'execute' | 'notify'
;

BehaviorDef:
    name=ID ':' action=ActionType
;

ComparisonOp:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOp:
    'and' | 'or' | 'not'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' seconds=INT ')'
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[EntityDef] ',' event=STRING ')'
;

StateTrigger:
    'state' '(' entity=[EntityDef] '.' property=ID ',' condition=ComparisonOp ',' value=PropertyValue ')'
;

TriggerDef:
    TimeTrigger | EventTrigger | StateTrigger
;

SimpleCondition:
    entity=[EntityDef] '.' property=ID operator=ComparisonOp value=PropertyValue
;

ConditionGroup:
    conditions+=SimpleCondition (operator=LogicalOp conditions+=SimpleCondition)*
;

Condition:
    '(' group=ConditionGroup ')' | SimpleCondition
;

EntityAction:
    'set' entity=[EntityDef] '.' property=ID '=' value=PropertyValue
;

DelayAction:
    'delay' '(' seconds=INT ')'
;

NotificationAction:
    'notify' '(' message=STRING ',' channel=STRING? ')'
;

ActionDef:
    EntityAction | DelayAction | NotificationAction
;

PlainAuth:
    'Auth<Plain>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

ApiKeyAuth:
    'Auth<ApiKey>' name=ID
    (
        ('key:' key=STRING)
    )#
    'end'
;

CertAuth:
    'Auth<Cert>' name=ID
    (
        ('cert:' cert=STRING)
        ('certPath:' certPath=STRING)?
    )#
    'end'
;

AuthConfig:
    PlainAuth | ApiKeyAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('basePath:' basePath=STRING)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

AutomationDef:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' conditions=ConditionGroup)?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;