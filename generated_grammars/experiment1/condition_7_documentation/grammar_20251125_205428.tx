SmartHomeModel:
    (
        metadata=Metadata?
        broker=BrokerConfig?
        authentication=AuthConfig?
        entities*=Entity
        automations*=Automation
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

AuthConfig:
    'Authentication'
    (
        ('method:' method=AuthMethod)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('token:' token=STRING)?
        ('certificate:' certificate=STRING)?
    )#
    'end'
;

AuthMethod:
    'basic' | 'token' | 'certificate' | 'oauth'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

PropertyType:
    'str' | 'int' | 'float' | 'bool' | 'datetime' | 'json'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

Property:
    name=ID ':' type=PropertyType ('=' defaultValue=PropertyValue)?
;

BehaviorAction:
    'read' | 'write' | 'notify' | 'execute' | 'subscribe'
;

Behavior:
    name=ID ':' action=BehaviorAction
;

Entity:
    'Entity' name=ID
    (
        ('type:' type=EntityType)
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

CronExpression:
    'cron' '(' expression=STRING ')'
;

TimeInterval:
    'interval' '(' seconds=INT ')'
;

TimeSchedule:
    CronExpression | TimeInterval
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event=STRING ')'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

StateCondition:
    property=ID operator=ComparisonOperator value=PropertyValue
;

StateTrigger:
    'state' '(' entity=[Entity] ',' condition=StateCondition ')'
;

Trigger:
    TimeTrigger | EventTrigger | StateTrigger
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ConditionGroup:
    left=SimpleCondition (operator=LogicalOperator right=SimpleCondition)*
;

GroupedCondition:
    '(' group=ConditionGroup ')'
;

Condition:
    SimpleCondition | GroupedCondition
;

EntityAction:
    'set' entity=[Entity] '.' property=ID '=' value=PropertyValue
;

NotificationAction:
    'notify' '(' message=STRING ',' channel=STRING? ')'
;

DelayAction:
    'delay' '(' duration=INT ')'
;

Action:
    EntityAction | NotificationAction | DelayAction
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('conditions:' conditions=ConditionGroup)?
        ('actions:' '-' actions*=Action['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;