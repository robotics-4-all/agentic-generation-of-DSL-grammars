SmartEnvironmentModel:
    imports_or_references*=ImportOrReferenceStm
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

ImportOrReferenceStm:
    ImportStm | ReferenceStm
;

ImportStm:
    'import' grammar_to_import=STRING
;

ReferenceStm:
    'reference' language_name=ID ('as' language_alias=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)?
        ('method:' method=HTTPMethod)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=TokenType)?
    )#
    'end'
;

CertAuth:
    'Auth<Cert>' name=ID
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)
        ('ca:' ca=STRING)?
    )#
    'end'
;

TokenType:
    'Bearer' | 'API' | 'JWT'
;

Entity:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)
        ('broker:' broker=[MessageBroker])
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

Property:
    name=ID ':' dtype=DataType ('=' default=PropertyValue)?
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

DataType:
    'str' | 'int' | 'float' | 'bool' | 'object' | 'array'
;

Behavior:
    name=ID ':' description=STRING
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=TriggerCondition)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

TriggerCondition:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event=STRING ')'
;

StateTrigger:
    'state' '(' entity=[Entity] '.' property=ID ',' value=PropertyValue ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

CronSchedule:
    'cron' '(' pattern=STRING ')'
;

IntervalSchedule:
    'interval' '(' seconds=INT ')'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('retry:' retry=INT)?
        ('timeout:' timeout=INT)?
        ('priority:' priority=INT)?
    )#
    'end'
;

ExecutionMode:
    'sequential' | 'parallel' | 'single'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

LogicalExpression:
    term=LogicalTerm (operator=LogicalOperator right=LogicalTerm)*
;

LogicalTerm:
    ComparisonExpression | '(' expression=LogicalExpression ')'
;

ComparisonExpression:
    left=OperandValue operator=ComparisonOperator right=OperandValue
;

OperandValue:
    EntityPropertyRef | LiteralValue
;

EntityPropertyRef:
    entity=[Entity] '.' property=ID
;

LiteralValue:
    FLOAT | INT | STRING | BOOL
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

Action:
    EntityAction | NotificationAction | SystemAction
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('entity:' entity=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=NotificationChannel)
        ('recipients:' '-' recipients*=STRING['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

SystemAction:
    'Action<System>' name=ID
    (
        ('command:' command=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'webhook'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;