SmartEnvironmentModel:
    (
        imports*=Import
        metadata=Metadata?
        broker_configs*=BrokerConfig
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)?
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MQTTBrokerConfig:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBrokerConfig:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBrokerConfig:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

BrokerConfig:
    MQTTBrokerConfig | AMQPBrokerConfig | RedisBrokerConfig
;

PlainAuth:
    'Auth<Plain>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('token_type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Authentication:
    PlainAuth | TokenAuth | CertAuth
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('description:' description=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('capabilities:' '-' capabilities*=Capability['-'])?
        ('broker:' broker=[BrokerConfig])?
        ('topic:' topic=STRING)?
        ('state:' state=EntityState)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'hybrid'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object'
;

Array:
    '[' values*=PropertyValue[','] ']'
;

Object:
    '{' pairs*=ObjectPair[','] '}'
;

ObjectPair:
    key=STRING ':' value=PropertyValue
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | Array | Object
;

Capability:
    name=ID '(' parameters*=Parameter[','] ')' ('->' return_type=DataType)?
;

Parameter:
    name=ID ':' param_type=DataType
;

EntityState:
    'online' | 'offline' | 'maintenance' | 'error' | 'unknown'
;

EventTrigger:
    'Event' '(' event_name=STRING ',' source=[Entity] ')'
;

TimeTrigger:
    'Time' '(' schedule=TimeSchedule ')'
;

StateTrigger:
    'State' '(' entity=[Entity] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

Trigger:
    EventTrigger | TimeTrigger | StateTrigger
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' seconds=INT ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

AutomationMode:
    'single' | 'restart' | 'queued' | 'parallel'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('condition:' condition=[Condition])?
        ('action:' action=[Action])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('mode:' mode=AutomationMode)?
    )#
    'end'
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ConditionTerm:
    SimpleCondition | '(' expression=ConditionExpression ')'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'in' | 'not_in' | 'contains'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ActionParameters:
    '{' params*=ActionParameter[','] '}'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

ActionType:
    'set_property' | 'call_service' | 'send_notification' | 'execute_script' | 'delay'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])
        ('parameters:' parameters=ActionParameters)?
        ('timeout:' timeout=INT)?
        ('retry_count:' retry_count=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;