SmartEnvironmentModel:
    (
        metadata=SystemMetadata?
        brokers*=BrokerConfig
        auth*=AuthenticationConfig
        entities*=EntityDef
        automations*=AutomationDecl
    )#
;

SystemMetadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('token_type:' token_type=STRING)?
        ('refresh_token:' refresh_token=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_file:' cert_file=STRING)
        ('key_file:' key_file=STRING)
        ('ca_file:' ca_file=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('api_key:' api_key=STRING)
        ('header_name:' header_name=STRING)?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertificateAuth | APIKeyAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('topic_prefix:' topic_prefix=STRING)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('base_path:' base_path=STRING)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker | HTTPBroker
;

PropertyList:
    '[' items*=PropertyValue[','] ']'
;

PropertyDict:
    '{' items*=PropertyDictItem[','] '}'
;

PropertyDictItem:
    key=STRING ':' value=PropertyValue
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | PropertyList | PropertyDict
;

EntityProperty:
    name=ID ':' value=PropertyValue
;

PeriodicBehavior:
    'Periodic' name=ID
    (
        ('interval:' interval=INT)
        ('action:' action=[ActionDef])?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

EventBehavior:
    'OnEvent' name=ID
    (
        ('event:' event=STRING)
        ('action:' action=[ActionDef])?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

ConditionalBehavior:
    'OnCondition' name=ID
    (
        ('condition:' condition=ConditionSpec)
        ('action:' action=[ActionDef])?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

EntityBehavior:
    PeriodicBehavior | EventBehavior | ConditionalBehavior
;

ActuatorCommand:
    name=ID ':' command_type=STRING ('(' parameters=STRING ')')?
;

EntityStatus:
    'ACTIVE' | 'INACTIVE' | 'ERROR' | 'MAINTENANCE' | 'UNKNOWN'
;

ValueRange:
    '(' min=NUMBER ',' max=NUMBER ')'
;

SensorEntity:
    'Entity<Sensor>' name=ID
    (
        ('properties:' '-' properties*=EntityProperty['-'])?
        ('behaviors:' '-' behaviors*=EntityBehavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
        ('data_type:' data_type=STRING)?
        ('units:' units=STRING)?
        ('range:' range=ValueRange)?
        ('broker:' broker=[BrokerConfig])?
    )#
    'end'
;

ActuatorEntity:
    'Entity<Actuator>' name=ID
    (
        ('properties:' '-' properties*=EntityProperty['-'])?
        ('behaviors:' '-' behaviors*=EntityBehavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
        ('commands:' '-' commands*=ActuatorCommand['-'])?
        ('broker:' broker=[BrokerConfig])?
    )#
    'end'
;

HybridEntity:
    'Entity<Hybrid>' name=ID
    (
        ('properties:' '-' properties*=EntityProperty['-'])?
        ('behaviors:' '-' behaviors*=EntityBehavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
        ('data_type:' data_type=STRING)?
        ('commands:' '-' commands*=ActuatorCommand['-'])?
        ('broker:' broker=[BrokerConfig])?
    )#
    'end'
;

VirtualEntity:
    'Entity<Virtual>' name=ID
    (
        ('properties:' '-' properties*=EntityProperty['-'])?
        ('behaviors:' '-' behaviors*=EntityBehavior['-'])?
        ('computation:' computation=STRING)?
        ('dependencies:' '-' dependencies*=[EntityDef]['-'])?
    )#
    'end'
;

EntityDef:
    SensorEntity | ActuatorEntity | HybridEntity | VirtualEntity
;

CronExpression:
    'cron' '(' expression=STRING ')'
;

IntervalExpression:
    'interval' '(' seconds=INT ')'
;

AbsoluteTime:
    'at' '(' time=STRING ')'
;

TimeExpression:
    CronExpression | IntervalExpression | AbsoluteTime
;

TimeTrigger:
    'Time' '(' time=TimeExpression ')'
;

EventTrigger:
    'Event' '(' event=STRING ')'
;

ValueTrigger:
    'Value' '(' entity=[EntityDef] '.' property=ID operator=ComparisonOperator value=NUMBER ')'
;

StateTrigger:
    'State' '(' entity=[EntityDef] state=STRING ')'
;

TriggerSpec:
    TimeTrigger | EventTrigger | ValueTrigger | StateTrigger
;

EntityCondition:
    'Entity' '(' entity=[EntityDef] '.' property=ID operator=ComparisonOperator value=PropertyValue ')'
;

TimeCondition:
    'Time' '(' operator=ComparisonOperator value=STRING ')'
;

ValueCondition:
    'Value' '(' entity=[EntityDef] '.' property=ID operator=ComparisonOperator value=PropertyValue ')'
;

StateCondition:
    'State' '(' entity=[EntityDef] operator=ComparisonOperator state=STRING ')'
;

SimpleCondition:
    EntityCondition | TimeCondition | ValueCondition | StateCondition
;

LogicalOperator:
    '&&' | '||' | '!' | 'XOR'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

ConditionSpec:
    left=SimpleCondition (logical_op=LogicalOperator right=SimpleCondition)*
;

EntityAction:
    'EntityAction' name=ID
    (
        ('target:' target=[EntityDef])
        ('operation:' operation=STRING)
        ('parameters:' parameters=PropertyValue)?
    )#
    'end'
;

NotificationAction:
    'Notification' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)?
        ('priority:' priority=STRING)?
    )#
    'end'
;

ScriptAction:
    'Script' name=ID
    (
        ('language:' language=STRING)
        ('code:' code=STRING)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

DelayAction:
    'Delay' name=ID
    (
        ('duration:' duration=INT)
    )#
    'end'
;

ActionDef:
    EntityAction | NotificationAction | ScriptAction | DelayAction
;

ExecutionMode:
    'SEQUENTIAL' | 'PARALLEL' | 'CONDITIONAL' | 'IMMEDIATE'
;

AutomationDecl:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerSpec)
        ('conditions:' '-' conditions*=ConditionSpec['-'])?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' execution_mode=ExecutionMode)?
    )#
    'end'
;