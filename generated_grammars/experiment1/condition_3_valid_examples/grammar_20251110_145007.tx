SmartEnvironmentModel:
    (
        imports*=ImportStatement
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthenticationConfig
        entities*=EntityDefinition
        automations*=AutomationDefinition
    )#
;

ImportStatement:
    'import' module=STRING
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'gateway' | 'device'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

DayOfWeek:
    'monday' | 'tuesday' | 'wednesday' | 'thursday' | 'friday' | 'saturday' | 'sunday'
;

Value:
    ArrayValue | ObjectValue | STRING | FLOAT | INT | BOOL
;

ArrayValue:
    '[' items*=Value[','] ']'
;

ObjectValue:
    '{' pairs*=KeyValuePair[','] '}'
;

KeyValuePair:
    key=STRING ':' value=Value
;

TimeValue:
    hour=INT ':' minute=INT (':' second=INT)?
;

Location:
    'Location' '(' x=FLOAT ',' y=FLOAT (',' z=FLOAT)? ')'
;

PropertyDefinition:
    name=ID ':' dataType=DataType ('=' defaultValue=Value)?
;

TriggerCondition:
    property=[PropertyDefinition] operator=ComparisonOperator value=Value
;

BehaviorDefinition:
    'behavior' name=ID
    (
        ('triggers:' '-' triggers*=TriggerCondition['-'])
        ('actions:' '-' actions*=ActionDefinition['-'])
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Cert>' name=ID
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
        ('ca:' ca=STRING)?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' type=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('location:' location=Location)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

EntityCondition:
    entity=[EntityDefinition] '.' property=ID operator=ComparisonOperator value=Value
;

TimeCondition:
    'time' operator=ComparisonOperator time=TimeValue
;

GroupCondition:
    '(' condition=ConditionDefinition ')'
;

ConditionExpression:
    EntityCondition | TimeCondition | GroupCondition
;

ConditionDefinition:
    left=ConditionExpression (operator=LogicalOperator right=ConditionExpression)*
;

CronSchedule:
    'cron' expression=STRING
;

IntervalSchedule:
    'interval' value=INT unit=TimeUnit
;

TimeSchedule:
    'at' time=TimeValue ('on' days*=DayOfWeek[','])?
;

ScheduleDefinition:
    CronSchedule | IntervalSchedule | TimeSchedule
;

EntityAction:
    'set' entity=[EntityDefinition] '.' property=ID '=' value=Value
;

NotificationAction:
    'notify' message=STRING ('to' recipient=STRING)?
;

ScriptAction:
    'execute' script=STRING ('with' params=ObjectValue)?
;

ActionDefinition:
    EntityAction | NotificationAction | ScriptAction
;

AutomationDefinition:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('conditions:' '-' conditions*=ConditionDefinition['-'])
        ('actions:' '-' actions*=ActionDefinition['-'])
        ('schedule:' schedule=ScheduleDefinition)?
    )#
    'end'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;