SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthenticationConfig
        entities*=EntityDefinition
        automations*=AutomationDeclaration
    )#
;

HeaderPair:
    key=STRING ':' value=STRING
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

APIKeyLocation:
    'header' | 'query' | 'body'
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'gateway' | 'device' | 'virtual'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'array' | 'object' | 'timestamp'
;

ArrayValue:
    '[' values*=PropertyValue[','] ']'
;

ObjectValue:
    '{' pairs*=ObjectPair[','] '}'
;

ObjectPair:
    key=STRING ':' value=PropertyValue
;

PropertyValue:
    STRING | INT | FLOAT | BOOL | ArrayValue | ObjectValue
;

PropertyConstraints:
    constraint_items*=ConstraintItem[',']
;

ConstraintItem:
    'min:' min_val=NUMBER |
    'max:' max_val=NUMBER |
    'pattern:' pattern=STRING |
    'enum:' '[' enum_values*=STRING[','] ']'
;

PropertyDefinition:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)? ('(' constraints=PropertyConstraints ')')?
;

BehaviorType:
    'read' | 'write' | 'notify' | 'execute' | 'schedule'
;

BehaviorParameters:
    param_items*=ParameterItem[',']
;

ParameterItem:
    name=ID '=' value=PropertyValue
;

BehaviorDefinition:
    name=ID ':' behavior_type=BehaviorType ('(' parameters=BehaviorParameters ')')?
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' duration=INT ',' unit=TimeUnit ')'
;

FixedTimeSchedule:
    'at' '(' time=STRING ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule | FixedTimeSchedule
;

EventTrigger:
    'event' '(' entity=[EntityDefinition] ',' event_type=STRING ')'
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

StateTrigger:
    'state' '(' entity=[EntityDefinition] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

TriggerSpec:
    EventTrigger | TimeTrigger | StateTrigger
;

SimpleCondition:
    entity=[EntityDefinition] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ConditionSpec:
    left=SimpleCondition (logical_op=LogicalOperator right=SimpleCondition)*
;

EntityAction:
    'entity' '(' target=[EntityDefinition] ',' operation=STRING ',' parameters=ObjectValue? ')'
;

NotificationAction:
    'notify' '(' message=STRING ',' channel=STRING? ')'
;

ScriptAction:
    'script' '(' script_path=STRING ',' parameters=ObjectValue? ')'
;

ActionSpec:
    EntityAction | NotificationAction | ScriptAction
;

ExecutionMode:
    'sequential' | 'parallel' | 'async'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('retry:' retry_count=INT)?
        ('timeout:' timeout=INT)?
        ('delay:' delay=INT)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('header:' header=STRING)?
        ('prefix:' prefix=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('api_key:' api_key=STRING)
        ('location:' location=APIKeyLocation)
        ('name:' param_name=STRING)?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertAuth | APIKeyAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('url:' url=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' '{' headers*=HeaderPair[','] '}')?
        ('timeout:' timeout=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('properties:' '{' properties*=PropertyDefinition[','] '}')?
        ('behaviors:' '{' behaviors*=BehaviorDefinition[','] '}')?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

AutomationDeclaration:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerSpec)
        ('conditions:' conditions*=ConditionSpec[','])?
        ('actions:' actions*=ActionSpec[','])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;