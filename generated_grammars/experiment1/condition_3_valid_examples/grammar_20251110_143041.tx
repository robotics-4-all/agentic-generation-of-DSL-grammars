SmartEnvironmentModel:
    (
        metadata=Metadata
        brokers*=BrokerConfig
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
    )#
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

HTTPHeader:
    name=STRING ':' value=STRING
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'hybrid'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object' | 'timestamp'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | Array | Object
;

Array:
    '[' items*=PropertyValue[','] ']'
;

Object:
    '{' items*=ObjectItem[','] '}'
;

ObjectItem:
    key=STRING ':' value=PropertyValue
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional' | 'immediate' | 'delayed'
;

LogicalOperator:
    'and' | 'or' | 'not' | 'xor'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'starts_with' | 'ends_with'
;

NotificationPriority:
    'low' | 'medium' | 'high' | 'critical'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

EventTrigger:
    'event:' event_name=STRING
;

TimeTrigger:
    'schedule:' cron_expression=STRING
;

StateTrigger:
    'state_change:' property_name=ID
;

Trigger:
    EventTrigger | TimeTrigger | StateTrigger
;

StateValue:
    property=ID ':' value=PropertyValue
;

ComparisonCondition:
    property=[Property] operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    time_expression=STRING operator=ComparisonOperator time_value=STRING
;

StateCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

Condition:
    left=PrimitiveCondition (operator=LogicalOperator right=PrimitiveCondition)*
;

PrimitiveCondition:
    ComparisonCondition | TimeCondition | StateCondition
;

ServiceParameter:
    name=ID ':' value=PropertyValue
;

PropertyAction:
    'SetProperty' entity=[Entity] '.' property=ID '=' value=PropertyValue
;

DelayAction:
    'Delay' duration=INT unit=TimeUnit
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('priority:' priority=INT)?
        ('timeout:' timeout=INT)?
        ('retry_count:' retry_count=INT)?
    )#
    'end'
;

NotificationAction:
    'Notify'
    (
        ('message:' message=STRING)
        ('recipient:' recipient=STRING)
        ('channel:' channel=STRING)?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

ServiceAction:
    'CallService'
    (
        ('service_name:' service_name=STRING)
        ('parameters:' parameters*=ServiceParameter)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Action:
    PropertyAction | NotificationAction | ServiceAction | DelayAction
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('actions:' actions*=Action)
        ('frequency:' frequency=INT)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

EntityState:
    'State'
    (
        values*=StateValue
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('api_key:' api_key=STRING)
        ('header_name:' header_name=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth | APIKeyAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('keepalive:' keepalive=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' headers*=HTTPHeader)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('properties:' properties*=Property)?
        ('behaviors:' behaviors*=Behavior)?
        ('state:' state=EntityState)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('description:' description=STRING)?
        ('enabled:' enabled=BOOL)?
        ('conditions:' conditions*=Condition)?
        ('actions:' actions*=Action)
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;