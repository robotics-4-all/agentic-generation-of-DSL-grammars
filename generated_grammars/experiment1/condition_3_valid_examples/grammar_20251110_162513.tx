SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth*=AuthenticationMech
        entities*=EntityDef
        automations*=AutomationDecl
        conditions*=ConditionSpec
        actions*=ActionDef
    )#
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'datetime' | 'json'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

BehaviorType:
    'periodic' | 'event_driven' | 'on_demand' | 'threshold_based'
;

LogicalOperator:
    'AND' | 'OR' | 'NOT'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'in'
;

ActionType:
    'set_property' | 'call_method' | 'send_message' | 'execute_script' | 'notify'
;

PropertyDef:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

BehaviorParam:
    name=ID '=' value=PropertyValue
;

BehaviorDef:
    name=ID ':' behavior_type=BehaviorType ('(' params*=BehaviorParam[','] ')')?
;

ActionParam:
    name=ID ':' value=PropertyValue
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' seconds=INT ')'
;

PropertyReference:
    entity=[EntityDef] '.' property=ID
;

ExpressionValue:
    PropertyValue | PropertyReference
;

ComparisonExpression:
    left=PropertyReference operator=ComparisonOperator right=ExpressionValue
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

TriggerSpec:
    EventTrigger | TimeTrigger | PropertyTrigger
;

EventTrigger:
    'event' '(' entity=[EntityDef] ',' event_name=STRING ')'
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

PropertyTrigger:
    'property' '(' entity=[EntityDef] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

AuthenticationMech:
    UsernamePasswordAuth | APIKeyAuth | TokenAuth
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationMech])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationMech])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationMech])?
    )#
    'end'
;

UsernamePasswordAuth:
    'Auth<UserPass>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

AutomationDecl:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerSpec)
        ('conditions:' conditions=[ConditionSpec])?
        ('actions:' '-' actions*=[ActionDef]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;

ConditionSpec:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
    )#
    'end'
;

ActionDef:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[EntityDef])
        ('parameters:' '-' parameters*=ActionParam['-'])?
        ('retry:' retry=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;