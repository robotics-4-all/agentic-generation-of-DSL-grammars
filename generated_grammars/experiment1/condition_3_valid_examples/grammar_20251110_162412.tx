SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=MessageBroker
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

NotificationPriority:
    'low' | 'medium' | 'high' | 'critical'
;

ScriptLanguage:
    'python' | 'javascript' | 'bash'
;

Parameter:
    name=ID ':' param_type=DataType
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

Capability:
    'Capability' name=ID
    (
        ('operation:' operation=STRING)
        ('parameters:' '-' parameters*=Parameter['-'])?
        ('returns:' return_type=DataType)?
    )#
    'end'
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' value=INT unit=TimeUnit ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

TimeTrigger:
    'Trigger<Time>' schedule=TimeSchedule
;

EventTrigger:
    'Trigger<Event>' event_source=[Entity] ':' event_type=STRING
;

StateTrigger:
    'Trigger<State>' entity=[Entity] ':' property=ID operator=ComparisonOperator value=PropertyValue
;

Trigger:
    TimeTrigger | EventTrigger | StateTrigger
;

ComparisonExpression:
    entity=[Entity] ':' property=ID operator=ComparisonOperator value=PropertyValue
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ConditionExpression:
    LogicalExpression | ComparisonExpression
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('retain:' retain=BOOL)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)
        ('queue:' queue=STRING)
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('channel:' channel=STRING)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('capabilities:' '-' capabilities*=Capability['-'])?
        ('broker:' broker=[MessageBroker])?
    )#
    'end'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('target:' target=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry_count:' retry_count=INT)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

ScriptAction:
    'Action<Script>' name=ID
    (
        ('script:' script=STRING)
        ('language:' language=ScriptLanguage)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Action:
    EntityAction | NotificationAction | ScriptAction
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('execution_mode:' execution_mode=ExecutionMode)?
    )#
    'end'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;