SmartEnvironmentModel:
    (
        imports*=Import
        metadata=Metadata?
        brokers*=MessageBroker
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MessageBroker:
    HTTPBroker | AMQPBroker | MQTTBroker
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('baseUrl:' baseUrl=STRING)
        ('timeout:' timeout=INT)?
        ('retries:' retries=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepAlive:' keepAlive=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    CertificateAuth | TokenAuth | BasicAuth
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('caCertPath:' caCertPath=STRING)?
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('capabilities:' '-' capabilities*=Capability['-'])?
        ('broker:' broker=[MessageBroker])?
        ('topic:' topic=STRING)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'gateway' | 'device'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)? ('unit:' unit=STRING)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

Capability:
    name=ID ':' capabilityType=CapabilityType ('config:' config=CapabilityConfig)?
;

CapabilityType:
    'read' | 'write' | 'subscribe' | 'publish' | 'command'
;

CapabilityConfig:
    '{' items*=ConfigItem[','] '}'
;

ConfigItem:
    key=STRING ':' value=PropertyValue
;

Trigger:
    EventTrigger | ScheduleTrigger | PropertyTrigger
;

EventTrigger:
    'Event<' eventType=STRING '>' ('from:' source=[Entity])?
;

ScheduleTrigger:
    'Schedule<' schedule=ScheduleExpression '>'
;

PropertyTrigger:
    'Property<' entity=[Entity] '.' property=ID '>' 'when:' condition=PropertyCondition
;

ScheduleExpression:
    CronExpression | IntervalExpression | TimeExpression
;

CronExpression:
    'cron:' expression=STRING
;

IntervalExpression:
    'interval:' value=INT unit=TimeUnit
;

TimeExpression:
    'at:' time=STRING
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

PropertyCondition:
    operator=ComparisonOperator value=PropertyValue
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains'
;

SimpleCondition:
    EntityCondition | TimeCondition | ExpressionCondition
;

EntityCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

ExpressionCondition:
    'expression:' expression=STRING
;

LogicalOperator:
    '&&' | '||' | '!'
;

Condition:
    left=SimpleCondition (operator=LogicalOperator right=SimpleCondition)*
;

Action:
    EntityAction | NotificationAction | DelayAction | ScriptAction
;

EntityAction:
    'SetProperty' entity=[Entity] '.' property=ID 'to:' value=PropertyValue
;

NotificationAction:
    'Notify' message=STRING ('to:' target=STRING)?
;

DelayAction:
    'Delay' duration=INT unit=TimeUnit
;

ScriptAction:
    'Script' script=STRING ('language:' language=STRING)?
;

Automation:
    'Automation' name=ID
    (
        ('description:' description=STRING)?
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('priority:' priority=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;