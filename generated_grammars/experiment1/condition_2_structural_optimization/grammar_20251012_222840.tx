SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

AuthenticationType:
    'basic' | 'token' | 'apikey' | 'certificate' | 'none'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

DataType:
    'float' | 'int' | 'string' | 'bool' | 'object' | 'array'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

BehaviorType:
    'read' | 'write' | 'notify' | 'command' | 'status'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'startsWith' | 'endsWith'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ScriptLanguage:
    'javascript' | 'python' | 'lua'
;

Authentication:
    'Authentication' name=ID
    (
        ('type:' authType=AuthenticationType)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('token:' token=STRING)?
        ('apiKey:' apiKey=STRING)?
        ('certificate:' certificate=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routingKey:' routingKey=STRING)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

MessageBroker:
    HTTPBroker | AMQPBroker | MQTTBroker
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

Parameter:
    name=ID ':' dataType=DataType
;

ParameterList:
    parameters*=Parameter[',']
;

Behavior:
    name=ID ':' behaviorType=BehaviorType ('(' parameters=ParameterList ')')?
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[MessageBroker])
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

SimpleCondition:
    entityRef=[Entity] '.' propertyRef=ID operator=ComparisonOperator value=PropertyValue
;

Condition:
    left=SimpleCondition (logicalOperator=LogicalOperator right=SimpleCondition)*
    | '(' condition=Condition ')'
;

Argument:
    name=ID '=' value=PropertyValue
;

ArgumentList:
    arguments*=Argument[',']
;

EntityAction:
    'action' target=[Entity] '.' behavior=ID ('(' arguments=ArgumentList ')')?
;

NotificationAction:
    'notify' message=STRING ('via' channel=STRING)?
;

DelayAction:
    'delay' duration=INT unit=TimeUnit
;

ScriptAction:
    'script' scriptContent=STRING language=ScriptLanguage?
;

Action:
    ScriptAction | DelayAction | NotificationAction | EntityAction
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Condition)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;