SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        brokers*=MessageBroker
        entities*=Entity
        automations*=Automation
        condition_pools*=ConditionPool
        action_pools*=ActionPool
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BasicAuth:
    'BasicAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'CertAuth'
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

EntityType:
    'sensor' | 'actuator' | 'hybrid' | 'device' | 'controller'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'array'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

BehaviorType:
    'reactive' | 'proactive' | 'scheduled' | 'event_driven'
;

Behavior:
    name=ID ':' behavior_type=BehaviorType
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)?
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityTrigger:
    'EntityTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('repeat:' repeat=BOOL)?
    )#
;

EventTrigger:
    'EventTrigger'
    (
        ('event:' event=STRING)
        ('source:' source=STRING)?
    )#
;

TriggerCondition:
    EntityTrigger | TimeTrigger | EventTrigger
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=TriggerCondition)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('execution:' execution=ExecutionMode)?
        ('priority:' priority=INT)?
    )#
    'end'
;

EntityReference:
    entity=[Entity] '.' property=ID
;

ConditionValue:
    PropertyValue | EntityReference
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonExpression:
    left=EntityReference operator=ComparisonOperator right=ConditionValue
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ConditionExpression:
    LogicalExpression
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

ConditionPool:
    'Conditions'
        conditions*=Condition
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'notify' | 'call_service'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

ActionPool:
    'Actions'
        actions*=Action
    'end'
;