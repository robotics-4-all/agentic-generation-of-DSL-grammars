SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[Authentication])?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('basePath:' basePath=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

ApiKeyAuth:
    'Auth<ApiKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | ApiKeyAuth | TokenAuth
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'system' | 'virtual'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'object' | 'array'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

BehaviorTrigger:
    'onChange' | 'onValue' | 'periodic' | 'manual'
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('actions:' '-' actions*=[Action]['-'])
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[MessageBroker])
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('capabilities:' '-' capabilities*=STRING['-'])?
    )#
    'end'
;

AutomationMode:
    'trigger' | 'continuous' | 'scheduled'
;

TimeSpec:
    hour=INT ':' minute=INT (':' second=INT)?
;

Schedule:
    'Schedule'
    (
        ('cron:' cron=STRING) |
        ('interval:' interval=INT) |
        ('time:' time=TimeSpec)
    )
    'end'
;

ConditionType:
    'entity' | 'time' | 'location' | 'system' | 'composite'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ConditionValue:
    STRING | FLOAT | INT | BOOL | TimeSpec
;

Condition:
    'Condition' name=ID
    (
        ('type:' conditionType=ConditionType)
        ('entity:' entity=[Entity])?
        ('property:' property=ID)?
        ('operator:' operator=ComparisonOperator)
        ('value:' value=ConditionValue)
        ('logicOp:' logicOp=LogicalOperator)?
        ('subConditions:' '-' subConditions*=[Condition]['-'])?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('conditions:' '-' conditions*=[Condition]['-'])
        ('actions:' '-' actions*=[Action]['-'])
        ('schedule:' schedule=Schedule)?
        ('mode:' mode=AutomationMode)?
    )#
    'end'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

ScriptLanguage:
    'python' | 'javascript' | 'bash' | 'lua'
;

PropertyReference:
    entity=[Entity] '.' property=ID
;

ParameterValue:
    STRING | FLOAT | INT | BOOL | PropertyReference
;

ActionParameter:
    name=ID ':' value=ParameterValue
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('entity:' entity=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('delay:' delay=INT)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

SystemAction:
    'Action<System>' name=ID
    (
        ('command:' command=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

ScriptAction:
    'Action<Script>' name=ID
    (
        ('language:' language=ScriptLanguage)
        ('code:' code=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

Action:
    EntityAction | NotificationAction | SystemAction | ScriptAction
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;

Comment:
    CommentLine | CommentBlock
;