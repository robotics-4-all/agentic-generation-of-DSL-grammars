SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=Broker
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

DataType:
    'str' | 'int' | 'float' | 'bool' | 'datetime' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

Range:
    'Range' '(' min=NUMBER ',' max=NUMBER ')'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional' | 'immediate'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

PropertyOperation:
    'set' | 'increment' | 'decrement' | 'toggle'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

Header:
    name=STRING ':' value=STRING
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
        ('param:' param=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth | APIKeyAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('queue:' queue=STRING)
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Property:
    'Property' name=ID
    (
        ('datatype:' datatype=DataType)
        ('value:' value=PropertyValue)?
        ('readonly:' readonly=BOOL)?
        ('unit:' unit=STRING)?
        ('range:' range=Range)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' type=EntityType)
        ('broker:' broker=[Broker])
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EventTrigger:
    'Trigger<Event>' event=STRING
;

TimeTrigger:
    'Trigger<Time>' schedule=STRING
;

PropertyTrigger:
    'Trigger<Property>' property=[Property] condition=Condition
;

Trigger:
    EventTrigger | TimeTrigger | PropertyTrigger
;

PropertyRef:
    entity=[Entity] '.' property=ID
;

LiteralValue:
    FLOAT | INT | STRING | BOOL
;

Operand:
    PropertyRef | LiteralValue
;

SimpleCondition:
    operand1=Operand operator=ComparisonOperator operand2=Operand
;

Condition:
    left=SimpleCondition (logical_op=LogicalOperator right=SimpleCondition)*
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('action:' action=Action)
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

PropertyAction:
    'Action<Property>'
    (
        ('target:' target=PropertyRef)
        ('operation:' operation=PropertyOperation)
        ('value:' value=PropertyValue)?
    )#
    'end'
;

MessageAction:
    'Action<Message>'
    (
        ('broker:' broker=[Broker])
        ('topic:' topic=STRING)
        ('payload:' payload=STRING)
        ('qos:' qos=INT)?
    )#
    'end'
;

ServiceAction:
    'Action<Service>'
    (
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('payload:' payload=STRING)?
        ('headers:' '-' headers*=Header['-'])?
    )#
    'end'
;

DelayAction:
    'Action<Delay>' duration=INT unit=TimeUnit
;

Action:
    PropertyAction | MessageAction | ServiceAction | DelayAction
;

Automation:
    'Automation' name=ID
    (
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;