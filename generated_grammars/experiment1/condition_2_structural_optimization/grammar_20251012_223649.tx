SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthenticationConfig
        entities*=Entity
        conditions*=Condition
        actions*=Action
        automations*=Automation
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

PropertyType:
    'string' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | Array | Object
;

Array:
    '[' items*=PropertyValue[','] ']'
;

ObjectPair:
    key=STRING ':' value=PropertyValue
;

Object:
    '{' pairs*=ObjectPair[','] '}'
;

Property:
    name=ID ':' ptype=PropertyType ('=' default_value=PropertyValue)?
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=STRING)
        ('action:' action=STRING)
        ('parameters:' '-' parameters*=Property['-'])?
    )#
    'end'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('token_type:' token_type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertificateAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('channel:' channel=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)
        ('broker:' broker=[BrokerConfig])?
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

PropertyReference:
    entity=[Entity] '.' property=ID
;

Value:
    STRING | FLOAT | INT | BOOL | property_ref=PropertyReference
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '<' | '<=' | '>' | '>=' | 'contains' | 'matches'
;

ComparisonExpression:
    left=PropertyReference comparator=ComparisonOperator right=Value
    | '(' expression=LogicalExpression ')'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
        ('retry_count:' retry_count=INT)?
    )#
    'end'
;

ActionType:
    'set_property' | 'call_service' | 'send_notification' | 'execute_script' | 'trigger_automation'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

RetryPolicy:
    'RetryPolicy'
    (
        ('max_attempts:' max_attempts=INT)
        ('delay:' delay=INT)?
        ('backoff_factor:' backoff_factor=FLOAT)?
    )#
;

Action:
    'Action' name=ID
    (
        ('type:' atype=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry_policy:' retry_policy=RetryPolicy)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ExecutionMode:
    'immediate' | 'delayed' | 'scheduled' | 'conditional'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('trigger_conditions:' '-' trigger_conditions*=[Condition]['-'])
        ('trigger_actions:' '-' trigger_actions*=[Action]['-'])
        ('else_actions:' '-' else_actions*=[Action]['-'])?
        ('execution_mode:' execution_mode=ExecutionMode)?
        ('schedule:' schedule=STRING)?
    )#
    'end'
;