SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication=Authentication?
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

BehaviorTrigger:
    'onUpdate' | 'onStart' | 'onStop' | 'onEvent' | 'periodic'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'startsWith' | 'endsWith'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ActionType:
    'setValue' | 'sendCommand' | 'sendNotification' | 'callService' | 'delay'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

Parameter:
    name=ID ':' paramType=DataType ('=' defaultValue=PropertyValue)?
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

BasicAuth:
    'BasicAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'CertAuth'
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('basePath:' basePath=STRING)?
        ('keepAlive:' keepAlive=INT)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('parameters:' '-' parameters*=Parameter['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('timezone:' timezone=STRING)?
    )#
;

EventTrigger:
    'EventTrigger'
    (
        ('entity:' entity=[Entity])
        ('event:' event=STRING)
        ('filter:' filter=STRING)?
    )#
;

StateTrigger:
    'StateTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ConditionTerm:
    SimpleCondition | '(' expression=ConditionExpression ')'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

Action:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('target:' target=[Entity])
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('timeout:' timeout=INT)?
        ('retries:' retries=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('priority:' priority=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;

Comment:
    CommentLine | CommentBlock
;