SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=Broker
        authentication*=Authentication
        entities*=Entity
        conditions*=Condition
        actions*=Action
        automations*=Automation
    )#
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

AuthType:
    'basic' | 'bearer' | 'api_key' | 'certificate' | 'oauth'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

CapabilityType:
    'read' | 'write' | 'execute' | 'notify'
;

EntityState:
    'active' | 'inactive' | 'error' | 'maintenance'
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' seconds=INT ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event_type=STRING ')'
;

StateTrigger:
    'state' '(' entity=[Entity] '.' property=ID ',' value=PropertyValue ')'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>='
;

EntityPropertyRef:
    entity=[Entity] '.' property=ID
;

ValueExpression:
    EntityPropertyRef | PropertyValue | '(' LogicalExpression ')'
;

ComparisonExpression:
    left=ValueExpression operator=ComparisonOperator right=ValueExpression
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ConditionExpression:
    LogicalExpression
;

ActionType:
    'set_property' | 'send_command' | 'notify' | 'log' | 'execute_script'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

Capability:
    name=ID ':' capability_type=CapabilityType
;

Metadata:
    'Metadata' name=ID
    (
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)?
        ('method:' method=HTTPMethod)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Authentication:
    'Authentication' name=ID
    (
        ('type:' auth_type=AuthType)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('token:' token=STRING)?
        ('api_key:' api_key=STRING)?
        ('certificate:' certificate=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[Broker])?
        ('properties:' '-' properties*=Property['-'])?
        ('capabilities:' '-' capabilities*=Capability['-'])?
        ('state:' state=EntityState)?
    )#
    'end'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('delay:' delay=INT)?
        ('retry:' retry=INT)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;