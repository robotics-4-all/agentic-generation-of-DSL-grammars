SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=Broker
        authentications*=Authentication
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('tokenType:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'gateway' | 'device' | 'service'
;

EntityStatus:
    'online' | 'offline' | 'error' | 'maintenance'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

BehaviorType:
    'read' | 'write' | 'readwrite' | 'event' | 'command'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

Behavior:
    name=ID ':' behaviorType=BehaviorType
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[Broker])?
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' seconds=INT ')'
;

ExecutionMode:
    'sequential' | 'parallel' | 'immediate' | 'queued'
;

Trigger:
    EventTrigger | TimeTrigger | StateTrigger
;

EventTrigger:
    'event' '(' entity=[Entity] ',' property=ID (',' value=PropertyValue)? ')'
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

StateTrigger:
    'state' '(' condition=[Condition] ')'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

EntityReference:
    entity=[Entity] '.' property=ID
;

ValueExpression:
    PropertyValue | EntityReference
;

ComparisonExpression:
    left=ValueExpression operator=ComparisonOperator right=ValueExpression
    | '(' expression=LogicalExpression ')'
    | entityReference=EntityReference
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('executionMode:' executionMode=ExecutionMode)?
    )#
    'end'
;

ActionType:
    'set' | 'get' | 'toggle' | 'increment' | 'decrement' | 'execute' | 'notify'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Action:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('target:' target=[Entity])
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('timeout:' timeout=INT)?
        ('retries:' retries=INT)?
    )#
    'end'
;