SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthenticationMechanism
        entities*=EntityDefinition
        conditions*=ConditionSpecification
        actions*=ActionDefinition
        automations*=AutomationDeclaration
    )#
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

APIKeyLocation:
    'header' | 'query' | 'cookie'
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'gateway' | 'device' | 'service'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'timestamp' | 'json' | 'binary'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | 'null'
;

BehaviorType:
    'periodic' | 'event_driven' | 'threshold_based' | 'manual' | 'scheduled'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'matches'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

LogicalOperator:
    'AND' | 'OR' | 'NOT'
;

ActionType:
    'set_property' | 'send_command' | 'notify' | 'log' | 'execute_script' | 'call_service'
;

BackoffStrategy:
    'fixed' | 'exponential' | 'linear'
;

Coordinates:
    x=FLOAT ',' y=FLOAT (',' z=FLOAT)?
;

LocationSpec:
    'Location' '(' coordinates=Coordinates (',' zone=STRING)? ')'
;

PropertyDefinition:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)? ('readonly')?
;

BehaviorParameter:
    name=ID '=' value=PropertyValue
;

BehaviorDefinition:
    name=ID ':' behavior_type=BehaviorType ('(' parameters*=BehaviorParameter[','] ')')?
;

PropertyCondition:
    operator=ComparisonOperator value=PropertyValue
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

CronExpression:
    'cron' '(' expression=STRING ')'
;

TimeInterval:
    'interval' '(' value=INT unit=TimeUnit ')'
;

SpecificTime:
    'at' '(' time=STRING ')'
;

TimeSchedule:
    CronExpression | TimeInterval | SpecificTime
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' event_type=STRING (',' source=[EntityDefinition])? ')'
;

PropertyTrigger:
    'property' '(' entity=[EntityDefinition] '.' property=ID condition=PropertyCondition ')'
;

TriggerDefinition:
    TimeTrigger | EventTrigger | PropertyTrigger
;

SimpleCondition:
    entity=[EntityDefinition] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

GroupedCondition:
    '(' expression=LogicalExpression ')'
;

LogicalTerm:
    SimpleCondition | GroupedCondition
;

LogicalExpression:
    left=LogicalTerm (operator=LogicalOperator right=LogicalTerm)*
;

RetryPolicy:
    'RetryPolicy'
    (
        ('max_attempts:' max_attempts=INT)
        ('backoff:' backoff=BackoffStrategy)?
    )#
    'end'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('max_retries:' max_retries=INT)?
        ('timeout:' timeout=INT)?
        ('delay:' delay=INT)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
        ('header:' header=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('key:' key=STRING)
        ('location:' location=APIKeyLocation)
        ('name:' param_name=STRING)?
    )#
    'end'
;

AuthenticationMechanism:
    BasicAuth | TokenAuth | CertificateAuth | APIKeyAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[AuthenticationMechanism])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationMechanism])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationMechanism])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('location:' location=LocationSpec)?
        ('status:' status=EntityStatus)?
        ('description:' description=STRING)?
    )#
    'end'
;

ConditionSpecification:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

ActionDefinition:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[EntityDefinition])
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry_policy:' retry_policy=RetryPolicy)?
        ('description:' description=STRING)?
    )#
    'end'
;

AutomationDeclaration:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDefinition)
        ('conditions:' '-' conditions*=[ConditionSpecification]['-'])?
        ('actions:' '-' actions*=[ActionDefinition]['-'])
        ('execution:' execution=ExecutionControl)?
        ('priority:' priority=INT)?
        ('enabled:' enabled=BOOL)?
        ('description:' description=STRING)?
    )#
    'end'
;