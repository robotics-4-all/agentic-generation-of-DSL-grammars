SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        brokers*=BrokerConfig
        authentication*=AuthenticationMechanism
        entities*=EntityDefinition
        automations*=AutomationDeclaration
        conditions*=ConditionSpecification
        actions*=ActionDefinition
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

UsernamePasswordAuth:
    'Auth<UserPass>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

AuthenticationMechanism:
    UsernamePasswordAuth | TokenAuth | CertificateAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationMechanism])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationMechanism])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('url:' url=STRING)
        ('timeout:' timeout=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationMechanism])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

PropertyDataType:
    'int' | 'float' | 'str' | 'bool' | 'array' | 'object'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

EntityProperty:
    name=ID ':' data_type=PropertyDataType ('=' default_value=PropertyValue)?
;

BehaviorType:
    'periodic' | 'event_driven' | 'continuous' | 'on_demand'
;

EntityBehavior:
    'behavior' name=ID ':' behavior_type=BehaviorType
;

CommandParameter:
    name=ID ':' param_type=PropertyDataType
;

ActuatorCommand:
    'command' name=ID ':' command_type=STRING ('(' parameters*=CommandParameter[','] ')')?
;

SensorEntity:
    'Entity<Sensor>' name=ID
    (
        ('type:' entity_type=STRING)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)
        ('properties:' '-' properties*=EntityProperty['-'])?
        ('behaviors:' '-' behaviors*=EntityBehavior['-'])?
        ('update_interval:' update_interval=INT)?
    )#
    'end'
;

ActuatorEntity:
    'Entity<Actuator>' name=ID
    (
        ('type:' entity_type=STRING)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)
        ('properties:' '-' properties*=EntityProperty['-'])?
        ('behaviors:' '-' behaviors*=EntityBehavior['-'])?
        ('commands:' '-' commands*=ActuatorCommand['-'])?
    )#
    'end'
;

VirtualEntity:
    'Entity<Virtual>' name=ID
    (
        ('type:' entity_type=STRING)
        ('properties:' '-' properties*=EntityProperty['-'])?
        ('behaviors:' '-' behaviors*=EntityBehavior['-'])?
        ('computation:' computation=STRING)?
    )#
    'end'
;

EntityDefinition:
    SensorEntity | ActuatorEntity | VirtualEntity
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

CronSchedule:
    'cron' expression=STRING
;

IntervalSchedule:
    'interval' duration=INT unit=TimeUnit
;

OnceSchedule:
    'once' datetime=STRING
;

TimeSchedule:
    CronSchedule | IntervalSchedule | OnceSchedule
;

TimeTrigger:
    'trigger<time>' schedule=TimeSchedule
;

EventTrigger:
    'trigger<event>' event_source=[EntityDefinition] event_type=STRING
;

StateChangeTrigger:
    'trigger<state>' entity=[EntityDefinition] property=ID from_value=PropertyValue to_value=PropertyValue
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateChangeTrigger
;

ExecutionMode:
    'sequential' | 'parallel' | 'single'
;

AutomationDeclaration:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[ConditionSpecification]['-'])?
        ('actions:' '-' actions*=[ActionDefinition]['-'])
        ('execution_mode:' execution_mode=ExecutionMode)?
        ('priority:' priority=INT)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

EntityReference:
    entity=[EntityDefinition] '.' property=ID
;

LiteralValue:
    FLOAT | INT | STRING | BOOL
;

FunctionCall:
    function_name=ID '(' arguments*=ValueExpression[','] ')'
;

ValueExpression:
    EntityReference | LiteralValue | FunctionCall
;

PredicateExpression:
    'exists' '(' entity=[EntityDefinition] ')'
    | 'online' '(' entity=[EntityDefinition] ')'
    | 'changed' '(' entity=[EntityDefinition] '.' property=ID ')'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonExpression:
    left=ValueExpression operator=ComparisonOperator right=ValueExpression
    | '(' expression=LogicalExpression ')'
    | predicate=PredicateExpression
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ConditionSpecification:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'notify' | 'log' | 'script' | 'rest_call'
;

EntityTarget:
    'entity' entity=[EntityDefinition]
;

ExternalTarget:
    'external' url=STRING
;

ActionTarget:
    EntityTarget | ExternalTarget
;

ParameterValue:
    FLOAT | INT | STRING | BOOL | EntityReference | FunctionCall
;

ActionParameter:
    name=ID ':' value=ParameterValue
;

ActionDefinition:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=ActionTarget)?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('delay:' delay=INT)?
        ('retry_count:' retry_count=INT)?
    )#
    'end'
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;

Comment:
    CommentLine | CommentBlock
;