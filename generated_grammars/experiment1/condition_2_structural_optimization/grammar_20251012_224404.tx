SmartEnvironmentModel:
    (
        imports*=ImportStm
        (metadata=Metadata)?
        (brokers*=MessageBroker)*
        (authentications*=Authentication)*
        (entities*=Entity)*
        (automations*=Automation)*
        (conditions*=Condition)*
        (actions*=Action)*
    )#
;

ImportStm:
    'import' importURI=STRING ('as' alias=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days' | 'weeks'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

ParameterType:
    'str' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

ActionType:
    'control' | 'notify' | 'log' | 'execute' | 'call'
;

NotificationMethod:
    'email' | 'sms' | 'push' | 'webhook'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'in'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | PropertyList
;

LiteralValue:
    STRING | FLOAT | INT | BOOL
;

Property:
    name=ID ':' value=PropertyValue
;

PropertyList:
    '[' properties*=Property[','] ']'
;

Parameter:
    name=ID ':' type=ParameterType ('=' default=PropertyValue)?
;

ParameterList:
    '[' parameters*=Parameter[','] ']'
;

Behavior:
    name=ID '(' parameters=ParameterList? ')' '->' result=PropertyValue
;

BehaviorList:
    '[' behaviors*=Behavior[','] ']'
;

RetryPolicy:
    'retry' '(' attempts=INT ',' delay=INT ')'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('timeout:' timeout=INT)?
        ('retry:' retry=RetryPolicy)?
    )#
    'end'
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' duration=INT ',' unit=TimeUnit ')'
;

FixedTimeSchedule:
    'at' '(' time=STRING ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule | FixedTimeSchedule
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event_type=STRING ')'
;

StateTrigger:
    'state' '(' entity=[Entity] ',' condition=[Condition] ')'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

EntityReference:
    entity=[Entity] ('.' property=ID)?
;

FunctionCall:
    name=ID '(' arguments*=ValueExpression[','] ')'
;

ValueExpression:
    EntityReference | LiteralValue | FunctionCall
;

ComparisonExpression:
    left=ValueExpression (operator=ComparisonOperator right=ValueExpression)?
    | '(' expression=LogicalExpression ')'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

NotificationConfig:
    'notification' '(' method=NotificationMethod ',' recipient=STRING ')'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
        ('param:' param=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth | APIKeyAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('url:' url=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' headers=PropertyList)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])?
        ('properties:' properties=PropertyList)?
        ('behaviors:' behaviors=BehaviorList)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' conditions*=[Condition][','])?
        ('actions:' actions*=[Action][','])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])?
        ('operation:' operation=STRING)
        ('parameters:' parameters=PropertyList)?
        ('notification:' notification=NotificationConfig)?
    )#
    'end'
;