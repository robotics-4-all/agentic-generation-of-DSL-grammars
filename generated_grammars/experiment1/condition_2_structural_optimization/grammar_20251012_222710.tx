SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth_mechanisms*=AuthMechanism
        entities*=Entity
        conditions*=Condition
        actions*=Action
        automations*=Automation
    )#
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | Array | Object
;

Array:
    '[' items*=PropertyValue[','] ']'
;

Object:
    '{' pairs*=ObjectPair[','] '}'
;

ObjectPair:
    key=STRING ':' value=PropertyValue
;

BehaviorType:
    'read_only' | 'write_only' | 'read_write' | 'event_driven' | 'scheduled'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ExecutionMode:
    'sequential' | 'parallel' | 'single_instance'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

EntityOperation:
    'set_property' | 'get_property' | 'execute_command' | 'restart' | 'shutdown'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'webhook' | 'mqtt'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

ScriptInterpreter:
    'python' | 'bash' | 'javascript' | 'powershell'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

Behavior:
    name=ID ':' behavior_type=BehaviorType
;

ActionParameter:
    name=STRING '=' value=PropertyValue
;

PropertyReference:
    entity=[Entity] '.' property=ID
;

ConditionValue:
    PropertyValue | PropertyReference
;

ComparisonExpression:
    left=PropertyReference operator=ComparisonOperator right=ConditionValue
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ConditionExpression:
    LogicalExpression
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' duration=INT ',' unit=TimeUnit ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event_type=STRING ')'
;

StateTrigger:
    'state' '(' entity=[Entity] '.' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

AuthMechanism:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('target:' target=[Entity])
        ('operation:' operation=EntityOperation)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=NotificationChannel)
        ('recipients:' '-' recipients*=STRING['-'])?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

ScriptAction:
    'Action<Script>' name=ID
    (
        ('script_path:' script_path=STRING)
        ('interpreter:' interpreter=ScriptInterpreter)?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

Action:
    EntityAction | NotificationAction | ScriptAction
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' execution_mode=ExecutionMode)?
    )#
    'end'
;