SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=Broker
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

AuthType:
    'basic' | 'bearer' | 'api_key' | 'certificate' | 'oauth2'
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'gateway' | 'device'
;

EntityState:
    'active' | 'inactive' | 'error' | 'maintenance'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

BehaviorAction:
    'read' | 'write' | 'execute' | 'monitor' | 'control'
;

ExecutionMode:
    'immediate' | 'delayed' | 'scheduled' | 'conditional'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Property:
    name=ID ':' value=PropertyValue
;

PropertyList:
    '[' properties*=Property[','] ']'
;

Behavior:
    name=ID ':' action=BehaviorAction
;

BehaviorList:
    '[' behaviors*=Behavior[','] ']'
;

Authentication:
    'Authentication' name=ID
    (
        ('type:' auth_type=AuthType)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('token:' token=STRING)?
        ('key:' key=STRING)?
        ('cert:' cert=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('url:' url=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' headers=PropertyList)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Broker:
    HTTPBroker | AMQPBroker | MQTTBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[Broker])
        ('location:' location=STRING)?
        ('properties:' properties=PropertyList)?
        ('behaviors:' behaviors=BehaviorList)?
        ('state:' state=EntityState)?
    )#
    'end'
;

ExecutionControl:
    (
        ('mode:' mode=ExecutionMode)
        ('delay:' delay=INT)?
        ('retry:' retry=INT)?
        ('timeout:' timeout=INT)?
    )#
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

Condition:
    left=SimpleCondition (logical_op=LogicalOperator right=SimpleCondition)*
;

ConditionList:
    '[' conditions*=Condition[','] ']'
;

EntityAction:
    'set' entity=[Entity] '.' property=ID 'to' value=PropertyValue
;

MessageAction:
    'send' message=STRING 'to' broker=[Broker] ('topic:' topic=STRING)?
;

SystemAction:
    'execute' command=STRING ('params:' params=PropertyList)?
;

Action:
    SystemAction | MessageAction | EntityAction
;

ActionList:
    '[' actions*=Action[','] ']'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Condition)
        ('conditions:' conditions=ConditionList)?
        ('actions:' actions=ActionList)
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;

Comment:
    CommentBlock | CommentLine
;