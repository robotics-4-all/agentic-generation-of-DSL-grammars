SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=Broker
        authentication*=Authentication
        entities*=Entity
        conditions*=Condition
        actions*=Action
        automations*=Automation
    )#
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

AuthType:
    'basic' | 'token' | 'certificate' | 'oauth'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ExecutionControl:
    'once' | 'repeat' | 'continuous'
;

ActionType:
    'command' | 'notification' | 'data_write' | 'service_call'
;

Parameter:
    name=ID ':' param_type=DataType
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

Behavior:
    name=ID '(' parameters*=Parameter[','] ')' ':' operation=STRING
;

ActionParameter:
    name=ID ':' value=ActionValue
;

PropertyReference:
    entity=[Entity] '.' property=ID
;

ComparisonValue:
    STRING | FLOAT | INT | BOOL | PropertyReference
;

ActionValue:
    STRING | FLOAT | INT | BOOL | PropertyReference
;

ComparisonExpression:
    left=PropertyReference comparator=ComparisonOperator right=ComparisonValue
;

ConditionOperand:
    PropertyReference | ComparisonExpression | '(' nested=ConditionExpression ')'
;

ConditionExpression:
    left=ConditionOperand (operator=LogicalOperator right=ConditionOperand)*
;

TimeTrigger:
    'time' '(' schedule=STRING ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event=STRING ')'
;

StateTrigger:
    'state' '(' entity=[Entity] '.' property=ID comparator=ComparisonOperator value=ComparisonValue ')'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

Metadata:
    'Metadata' name=ID
    (
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Authentication:
    'Authentication' name=ID
    (
        ('type:' auth_type=AuthType)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('token:' token=STRING)?
        ('certificate:' certificate=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('queue:' queue=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[Broker])
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

Condition:
    'Condition' name=ID
    (
        expression=ConditionExpression
    )
    'end'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('timeout:' timeout=INT)?
        ('retry:' retry=INT)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;