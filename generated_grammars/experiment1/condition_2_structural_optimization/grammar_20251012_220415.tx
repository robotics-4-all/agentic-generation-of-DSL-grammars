SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthenticationConfig
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

APIKeyLocation:
    'header' | 'query' | 'cookie'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'hub'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'datetime' | 'json' | 'binary'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

BehaviorType:
    'periodic' | 'event_driven' | 'on_demand' | 'threshold_based'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days' | 'weeks'
;

ExecutionMode:
    'sequential' | 'parallel' | 'single'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'startswith' | 'endswith'
;

ActionType:
    'set_property' | 'send_command' | 'send_notification' | 'call_service' | 'delay'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

BehaviorParam:
    name=ID '=' value=PropertyValue
;

BehaviorParameters:
    params*=BehaviorParam[',']
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' parameters=BehaviorParameters ')')?
;

EntityReference:
    entity=[Entity] ('.' property=ID)?
;

ConditionOperand:
    entity_ref=EntityReference | literal=PropertyValue
;

ComparisonCondition:
    left=ConditionOperand operator=ComparisonOperator right=ConditionOperand
;

EntityCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ConditionTerm:
    '(' expression=ConditionExpression ')' | ComparisonCondition | EntityCondition
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' value=INT ',' unit=TimeUnit ')'
;

OnceSchedule:
    'once' '(' datetime=STRING ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule | OnceSchedule
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event_type=STRING ')'
;

StateTrigger:
    'state' '(' entity=[Entity] '.' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

FunctionArguments:
    args*=PropertyValue[',']
;

FunctionCall:
    function_name=ID '(' arguments=FunctionArguments? ')'
;

ActionValue:
    PropertyValue | EntityReference | FunctionCall
;

ActionParameter:
    name=ID ':' value=ActionValue
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('token_type:' token_type=STRING)?
        ('header_name:' header_name=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('api_key:' api_key=STRING)
        ('key_name:' key_name=STRING)?
        ('location:' location=APIKeyLocation)?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertificateAuth | APIKeyAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('keepalive:' keepalive=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('method:' method=HTTPMethod)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' execution_mode=ExecutionMode)?
    )#
    'end'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('timeout:' timeout=INT)?
        ('retry_count:' retry_count=INT)?
    )#
    'end'
;