SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        brokers*=MessageBroker
        authentications*=Authentication
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

DataType:
    'str' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

BehaviorType:
    'publish' | 'subscribe' | 'request' | 'response' | 'periodic' | 'event'
;

BehaviorParam:
    name=ID ':' value=PropertyValue
;

BehaviorParameters:
    '{' params*=BehaviorParam[','] '}'
;

Behavior:
    name=ID ':' behaviorType=BehaviorType ('=' parameters=BehaviorParameters)?
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'startsWith' | 'endsWith'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

PropertyCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

StateCondition:
    entity=[Entity] '.' 'status' operator=ComparisonOperator state=EntityStatus
;

SimpleCondition:
    PropertyCondition | TimeCondition | StateCondition
;

ConditionTerm:
    '(' expr=ConditionExpression ')' | SimpleCondition
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' seconds=INT ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

ExecutionControl:
    'sequential' | 'parallel' | 'conditional' | 'retry'
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event=STRING ')'
;

PropertyTrigger:
    'property' '(' entity=[Entity] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | PropertyTrigger
;

EntityReference:
    'entity' '(' ref=[Entity] ')'
;

VariableReference:
    'var' '(' name=ID ')'
;

ActionValue:
    PropertyValue | EntityReference | VariableReference
;

ActionParam:
    name=ID ':' value=ActionValue
;

ActionParameters:
    '{' params*=ActionParam[','] '}'
;

ActionType:
    'publish' | 'set' | 'call' | 'notify' | 'log' | 'delay' | 'script'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepAlive:' keepAlive=INT)?
        ('clientId:' clientId=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('basePath:' basePath=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

Action:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('target:' target=[Entity])
        ('parameters:' parameters=ActionParameters)?
        ('timeout:' timeout=INT)?
        ('retries:' retries=INT)?
    )#
    'end'
;

FQN:
    ID ('.' ID)*
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;