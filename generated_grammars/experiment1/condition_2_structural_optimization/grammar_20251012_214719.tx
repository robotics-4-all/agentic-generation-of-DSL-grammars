SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        brokers*=MessageBroker
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('keepalive:' keepalive=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)
        ('ca:' ca=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

Property:
    name=ID ':' ptype=PropertyType ('=' default=PropertyValue)?
;

PropertyType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

Behavior:
    name=ID ':' btype=BehaviorType ('(' params*=BehaviorParam[','] ')')?
;

BehaviorType:
    'read' | 'write' | 'notify' | 'execute' | 'stream'
;

BehaviorParam:
    name=ID '=' value=PropertyValue
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDefinition)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;

TriggerDefinition:
    TimeTrigger | EntityTrigger | EventTrigger
;

TimeTrigger:
    'time' '(' schedule=STRING ')'
;

EntityTrigger:
    'entity' '(' entity=[Entity] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

EventTrigger:
    'event' '(' event=STRING ')'
;

ExecutionMode:
    'sequential' | 'parallel' | 'immediate' | 'delayed'
;

EntityCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

Condition:
    left=BaseCondition (operator=LogicalOperator right=BaseCondition)*
;

BaseCondition:
    EntityCondition | TimeCondition | '(' Condition ')'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    EntityAction | NotificationAction | ServiceAction
;

EntityAction:
    'set' entity=[Entity] '.' property=ID '=' value=PropertyValue
;

NotificationAction:
    'notify' '(' message=STRING ',' channel=STRING? ')'
;

ServiceAction:
    'call' service=STRING '(' params*=ServiceParam[','] ')'
;

ServiceParam:
    name=ID '=' value=PropertyValue
;