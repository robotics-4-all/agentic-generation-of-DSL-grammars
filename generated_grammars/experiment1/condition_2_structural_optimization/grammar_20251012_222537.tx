SmartEnvironmentModel:
    imports*=Import
    (
        (metadata=Metadata)?
        (brokers*=Broker)?
        (entities*=Entity)?
        (conditions*=Condition)?
        (actions*=Action)?
        (automations*=Automation)?
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'array'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ActionType:
    'send_command' | 'set_property' | 'notify' | 'log' | 'script'
;

Property:
    name=ID ':' datatype=DataType ('=' default=PropertyValue)?
;

Behavior:
    name=ID ':' action=[Action]
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

BasicAuth:
    'BasicAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'CertAuth'
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('topic:' topic=STRING)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)
        ('broker:' broker=[Broker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityPropertyCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

ValueCondition:
    value1=PropertyValue operator=ComparisonOperator value2=PropertyValue
;

SimpleCondition:
    EntityPropertyCondition | TimeCondition | ValueCondition
;

ConditionTerm:
    '(' expression=ConditionExpression ')' | SimpleCondition
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

Action:
    'Action' name=ID
    (
        ('type:' atype=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('repeat:' repeat=BOOL)?
    )#
;

EventTrigger:
    'EventTrigger'
    (
        ('entity:' entity=[Entity])
        ('event:' event=STRING)
    )#
;

StateTrigger:
    'StateTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=AutomationTrigger)
        ('condition:' condition=[Condition])?
        ('actions:' '-' actions*=[Action]['-'])
        ('description:' description=STRING)?
    )#
    'end'
;