SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth_mechanisms*=AuthMechanism
        entities*=Entity
        conditions*=Condition
        actions*=Action
        automations*=Automation
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'json' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | JsonObject | JsonArray
;

JsonObject:
    '{' items*=JsonItem[','] '}'
;

JsonArray:
    '[' values*=PropertyValue[','] ']'
;

JsonItem:
    key=STRING ':' value=PropertyValue
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

BehaviorType:
    'periodic' | 'event_driven' | 'manual' | 'automatic' | 'scheduled'
;

Behavior:
    name=ID ':' behavior_type=BehaviorType
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

HeaderParam:
    name=ID ':' value=STRING
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ExecutionMode:
    'sequential' | 'parallel' | 'single' | 'queued'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'webhook' | 'mqtt' | 'slack'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

ScriptType:
    'python' | 'javascript' | 'bash' | 'powershell'
;

ComparisonOperator:
    '==' | '!=' | '<' | '<=' | '>' | '>=' | 'contains' | 'starts_with' | 'ends_with'
;

PropertyReference:
    entity=[Entity] '.' property=ID
;

ComparisonValue:
    STRING | FLOAT | INT | BOOL | PropertyReference
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

ApiKeyAuth:
    'Auth<ApiKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
        ('param:' param=STRING)?
    )#
    'end'
;

AuthMechanism:
    BasicAuth | TokenAuth | CertAuth | ApiKeyAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)
        ('queue:' queue=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('url:' url=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' '-' headers*=HeaderParam['-'])?
        ('timeout:' timeout=INT)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('state:' state=STRING)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

ComparisonExpression:
    left=PropertyReference operator=ComparisonOperator right=ComparisonValue
;

NotExpression:
    ('not')? operand=ComparisonExpression
;

AndExpression:
    left=NotExpression ('and' right=NotExpression)*
;

OrExpression:
    left=AndExpression ('or' right=AndExpression)*
;

LogicalExpression:
    or_expr=OrExpression
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('target:' target=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry_count:' retry_count=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=NotificationChannel)
        ('priority:' priority=NotificationPriority)?
        ('recipients:' '-' recipients*=STRING['-'])?
    )#
    'end'
;

ScriptAction:
    'Action<Script>' name=ID
    (
        ('script_type:' script_type=ScriptType)
        ('script_content:' script_content=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

DelayAction:
    'Action<Delay>' name=ID
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

Action:
    EntityAction | NotificationAction | ScriptAction | DelayAction
;

CronExpression:
    'cron' '(' expression=STRING ')'
;

IntervalExpression:
    'interval' '(' value=INT unit=TimeUnit ')'
;

TimeExpression:
    'at' '(' time=STRING ')'
;

ScheduleExpression:
    CronExpression | IntervalExpression | TimeExpression
;

TimeBasedTrigger:
    'time' '(' schedule=ScheduleExpression ')'
;

EventBasedTrigger:
    'event' '(' event_source=[Entity] ',' event_type=STRING ')'
;

StateChangeTrigger:
    'state_change' '(' entity=[Entity] ',' property=ID ')'
;

AutomationTrigger:
    TimeBasedTrigger | EventBasedTrigger | StateChangeTrigger
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' execution_mode=ExecutionMode)?
    )#
    'end'
;