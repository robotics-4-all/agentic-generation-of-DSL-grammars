SmartEnvironmentModel:
    imports_or_references*=ImportOrReferenceStm
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

ImportOrReferenceStm:
    ImportStm | ReferenceStm
;

ImportStm:
    'import' grammar_to_import=GrammarToImport
;

ReferenceStm:
    'reference' language_name=LanguageName ('as' language_alias=ID)?
;

GrammarToImport:
    /(\w|\.)+/
;

LanguageName:
    /(\w|-)+/
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('keepalive:' keepalive=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
        ('endpoints:' '-' endpoints*=STRING['-'])?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=TokenType)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

TokenType:
    'Bearer' | 'Basic' | 'API-Key'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'online' | 'offline' | 'maintenance' | 'error'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'object' | 'array'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' parameters=ParameterList ')')?
;

BehaviorType:
    'periodic' | 'triggered' | 'continuous' | 'on_demand'
;

ParameterList:
    parameters*=Parameter[',']
;

Parameter:
    name=ID '=' value=PropertyValue
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' execution_mode=ExecutionMode)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event_name=STRING ')'
;

StateTrigger:
    'state' '(' entity=[Entity] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' value=INT ',' unit=TimeUnit ')'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ExecutionMode:
    'sequential' | 'parallel' | 'queued'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionTerm:
    '(' expression=ConditionExpression ')' | SimpleCondition
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

Action:
    EntityAction | NotificationAction | SystemAction
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('target:' target=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' parameters=ParameterList)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=NotificationChannel)
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

SystemAction:
    'Action<System>' name=ID
    (
        ('command:' command=STRING)
        ('parameters:' parameters=ParameterList)?
    )#
    'end'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'webhook'
;

NotificationPriority:
    'low' | 'medium' | 'high' | 'critical'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;