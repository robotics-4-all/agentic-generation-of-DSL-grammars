SmartEnvironmentModel:
    (
        imports*=ImportStm
        metadata=SystemMetadata?
        brokers*=BrokerConfig
        auth*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

ImportStm:
    'import' module=STRING
;

SystemMetadata:
    'System'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object' | 'datetime'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | ArrayValue | ObjectValue
;

ArrayValue:
    '[' items*=PropertyValue[','] ']'
;

ObjectValue:
    '{' items*=ObjectItem[','] '}'
;

ObjectItem:
    key=STRING ':' value=PropertyValue
;

Constraint:
    RangeConstraint | EnumConstraint | PatternConstraint
;

RangeConstraint:
    'range' '(' min=NUMBER ',' max=NUMBER ')'
;

EnumConstraint:
    'enum' '(' values*=PropertyValue[','] ')'
;

PatternConstraint:
    'pattern' '(' pattern=STRING ')'
;

ConstraintDef:
    constraints*=Constraint[',']
;

PropertyDef:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)? ('[' constraints=ConstraintDef ']')?
;

BehaviorType:
    'read' | 'write' | 'notify' | 'execute' | 'subscribe'
;

BehaviorParam:
    name=ID '=' value=PropertyValue
;

BehaviorDef:
    name=ID ':' behavior_type=BehaviorType '(' parameters*=BehaviorParam[','] ')'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days' | 'weeks'
;

TimeSchedule:
    CronSchedule | IntervalSchedule | OnceSchedule
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' duration=NUMBER ',' unit=TimeUnit ')'
;

OnceSchedule:
    'once' '(' datetime=STRING ')'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'in' | 'not_in' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

PropertyCondition:
    entity=[EntityDef] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

EntityCondition:
    entity=[EntityDef] '.' 'status' operator=ComparisonOperator status=EntityStatus
;

ConditionTerm:
    '(' expr=ConditionExpr ')' | PropertyCondition | TimeCondition | EntityCondition
;

ConditionExpr:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionDef:
    condition=ConditionExpr
;

TriggerDef:
    EventTrigger | TimeTrigger | PropertyTrigger
;

EventTrigger:
    'event' '(' event_type=STRING ',' source=[EntityDef] ')'
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

PropertyTrigger:
    'property' '(' entity=[EntityDef] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

ActionParam:
    name=ID '=' value=PropertyValue
;

ActionExpr:
    EntityAction | ServiceAction | NotificationAction | DelayAction
;

EntityAction:
    'set' entity=[EntityDef] '.' property=ID '=' value=PropertyValue
;

ServiceAction:
    'call' service=[ServiceEntity] '.' method=ID '(' parameters*=ActionParam[','] ')'
;

NotificationAction:
    'notify' '(' message=STRING ',' recipients*=STRING[','] ')'
;

DelayAction:
    'delay' '(' duration=NUMBER ',' unit=TimeUnit ')'
;

ActionDef:
    action=ActionExpr
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth | APIKeyAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

EntityDef:
    SensorEntity | ActuatorEntity | DeviceEntity | ServiceEntity
;

SensorEntity:
    'Entity<Sensor>' name=ID
    (
        ('type:' entity_type=STRING)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

ActuatorEntity:
    'Entity<Actuator>' name=ID
    (
        ('type:' entity_type=STRING)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

DeviceEntity:
    'Entity<Device>' name=ID
    (
        ('type:' entity_type=STRING)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

ServiceEntity:
    'Entity<Service>' name=ID
    (
        ('type:' entity_type=STRING)
        ('endpoint:' endpoint=STRING)
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

AutomationDef:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' '-' conditions*=ConditionDef['-'])?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;