SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth_mechanisms*=AuthMechanism
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

Metadata:
    'Metadata'
    (
        ('system_name:' system_name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('client_id:' client_id=STRING)?
        ('keepalive:' keepalive=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('base_url:' base_url=STRING)
        ('timeout:' timeout=INT)?
        ('ssl_verify:' ssl_verify=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

AuthMechanism:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('token_type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_file:' cert_file=STRING)
        ('key_file:' key_file=STRING)?
        ('ca_file:' ca_file=STRING)?
    )#
    'end'
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)?
        ('endpoint:' endpoint=STRING)?
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'gateway' | 'device' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

PropertyDef:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

BehaviorDef:
    'behavior' name=ID ':' behavior_type=BehaviorType
;

BehaviorType:
    'periodic' | 'event_driven' | 'on_demand' | 'scheduled'
;

AutomationDef:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' '-' conditions*=ConditionDef['-'])?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' execution_mode=ExecutionMode)?
    )#
    'end'
;

ExecutionMode:
    'sequential' | 'parallel' | 'single_shot' | 'continuous'
;

TriggerDef:
    EventTrigger | TimeTrigger | StateTrigger
;

EventTrigger:
    'event' '(' entity=[EntityDef] ',' event_type=STRING ')'
;

TimeTrigger:
    'time' '(' schedule=STRING ')'
;

StateTrigger:
    'state' '(' entity=[EntityDef] '.' property=ID ',' condition=ConditionExpression ')'
;

ConditionDef:
    left=PrimitiveCondition (operator=LogicalOperator right=PrimitiveCondition)*
;

PrimitiveCondition:
    ComparisonCondition | EntityCondition | '(' nested=ConditionDef ')'
;

ComparisonCondition:
    entity=[EntityDef] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

EntityCondition:
    entity=[EntityDef] '.' property=ID operator=EntityOperator
;

ConditionExpression:
    operand1=PropertyValue operator=ComparisonOperator operand2=PropertyValue
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

EntityOperator:
    'exists' | 'available' | 'changed'
;

ActionDef:
    EntityAction | NotificationAction | SystemAction
;

EntityAction:
    'entity_action' '(' entity=[EntityDef] ',' action_type=STRING ',' parameters=ActionParameters? ')'
;

NotificationAction:
    'notify' '(' message=STRING ',' recipient=STRING? ')'
;

SystemAction:
    'system' '(' command=STRING ',' parameters=ActionParameters? ')'
;

ActionParameters:
    '{' params*=ActionParam[','] '}'
;

ActionParam:
    name=ID ':' value=PropertyValue
;