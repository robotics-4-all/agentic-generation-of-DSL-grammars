SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=Broker
        authentications*=Authentication
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

DataType:
    'str' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

PropertyValue:
    FLOAT | INT | BOOL | STRING
;

BehaviorType:
    'reactive' | 'proactive' | 'scheduled' | 'event_driven'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'matches'
;

ActionType:
    'set_property' | 'send_command' | 'notify' | 'log' | 'call_service' | 'delay'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

Behavior:
    name=ID ':' behavior_type=BehaviorType
;

TimeSpec:
    CronExpression | TimeInterval
;

CronExpression:
    'cron' '(' expression=STRING ')'
;

TimeInterval:
    'interval' '(' seconds=INT ')'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'Time' '(' time_spec=TimeSpec ')'
;

EventTrigger:
    'Event' '(' entity=[Entity] ',' event_type=STRING ')'
;

StateTrigger:
    'State' '(' entity=[Entity] ',' property=ID ',' value=PropertyValue ')'
;

SimpleCondition:
    EntityCondition | ValueCondition | TimeCondition
;

EntityCondition:
    entity=[Entity] '.' property=ID comparison=ComparisonOperator value=PropertyValue
;

ValueCondition:
    left_value=PropertyValue comparison=ComparisonOperator right_value=PropertyValue
;

TimeCondition:
    'time' comparison=ComparisonOperator time_value=STRING
;

ConditionTerm:
    SimpleCondition | '(' expression=ConditionExpression ')'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

EntityReference:
    entity=[Entity] ('.' property=ID)?
;

ParameterValue:
    FLOAT | INT | BOOL | STRING | EntityReference
;

ActionParameter:
    name=ID ':' value=ParameterValue
;

Authentication:
    BasicAuth | TokenAuth | CertAuth | APIKeyAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

Broker:
    HTTPBroker | AMQPBroker | MQTTBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('keepalive:' keepalive=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('queue:' queue=STRING)
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Metadata:
    'Metadata' name=ID
    (
        ('version:' version=STRING)?
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[Broker])?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry_count:' retry_count=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' execution_mode=ExecutionMode)?
    )#
    'end'
;