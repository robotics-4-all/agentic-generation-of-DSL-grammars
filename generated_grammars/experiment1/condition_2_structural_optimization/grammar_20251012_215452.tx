SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth=AuthenticationConfig?
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

AuthenticationMechanism:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'BasicAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'CertificateAuth'
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
        ('ca:' ca=STRING)?
    )#
    'end'
;

AuthMethod:
    'basic' | 'token' | 'certificate' | 'oauth' | 'api_key'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=AuthenticationMechanism)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=AuthenticationMechanism)?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=AuthenticationMechanism)?
    )#
    'end'
;

AuthenticationConfig:
    'Authentication'
    (
        ('enabled:' enabled=BOOL)
        ('method:' method=AuthMethod)
        ('config:' config=AuthenticationMechanism)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

DataType:
    'str' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

Behavior:
    name=ID ':' action=[Action] ('when' condition=[Condition])?
;

Entity:
    'Entity' name=ID
    (
        ('type:' type=EntityType)
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
        ('broker:' broker=[BrokerConfig])?
    )#
    'end'
;

RepeatPattern:
    'daily' | 'weekly' | 'monthly' | 'hourly' | 'once'
;

ExecutionMode:
    'immediate' | 'delayed' | 'scheduled' | 'conditional'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('delay:' delay=INT)?
        ('timeout:' timeout=INT)?
        ('retries:' retries=INT)?
    )#
    'end'
;

Trigger:
    EntityTrigger | TimeTrigger | EventTrigger
;

EntityTrigger:
    'entity:' entity=[Entity] 'property:' property=ID 'operator:' operator=ComparisonOperator 'value:' value=PropertyValue
;

TimeTrigger:
    'time:' time=STRING ('repeat:' repeat=RepeatPattern)?
;

EventTrigger:
    'event:' event=STRING ('source:' source=STRING)?
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

ConditionType:
    'simple' | 'complex' | 'temporal' | 'spatial'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

EvaluationMode:
    'continuous' | 'periodic' | 'on_change' | 'manual'
;

ComparisonExpression:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

Condition:
    'Condition' name=ID
    (
        ('type:' type=ConditionType)
        ('expression:' expression=LogicalExpression)
        ('evaluation:' evaluation=EvaluationMode)?
    )#
    'end'
;

EntityOperation:
    'set' | 'get' | 'toggle' | 'increment' | 'decrement' | 'reset'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'mqtt' | 'webhook'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Action:
    EntityAction | NotificationAction | SystemAction
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('target:' target=[Entity])
        ('operation:' operation=EntityOperation)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('confirmation:' confirmation=BOOL)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=NotificationChannel)
        ('recipients:' '-' recipients*=STRING['-'])?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

SystemAction:
    'Action<System>' name=ID
    (
        ('command:' command=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('requireAuth:' requireAuth=BOOL)?
    )#
    'end'
;