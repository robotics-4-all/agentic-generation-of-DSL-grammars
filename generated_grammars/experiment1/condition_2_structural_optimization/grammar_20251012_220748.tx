SmartEnvironmentModel:
    imports_or_references*=ImportOrReferenceStm
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentications*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

ImportOrReferenceStm:
    ImportStm | ReferenceStm
;

ImportStm:
    'import' grammar_to_import=GrammarToImport
;

ReferenceStm:
    'reference' language_name=LanguageName ('as' language_alias=ID)?
;

GrammarToImport:
    /(\w|\.)+/
;

LanguageName:
    /(\w|-)+/
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('base_path:' base_path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
        ('header:' header_name=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=EntityProperty['-'])?
        ('behaviors:' '-' behaviors*=EntityBehavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

EntityProperty:
    name=ID ':' data_type=PropertyDataType ('=' default_value=PropertyValue)?
;

PropertyDataType:
    'str' | 'int' | 'float' | 'bool' | 'json' | 'array'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

EntityBehavior:
    name=ID ':' behavior_type=BehaviorType ('(' parameters=BehaviorParameters ')')?
;

BehaviorType:
    'periodic' | 'event_driven' | 'on_demand' | 'threshold_based'
;

BehaviorParameters:
    params*=BehaviorParam[',']
;

BehaviorParam:
    name=ID '=' value=PropertyValue
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EntityTrigger | EventTrigger
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EntityTrigger:
    'entity' '(' entity=[Entity] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

EventTrigger:
    'event' '(' event_name=STRING ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' value=INT ',' unit=TimeUnit ')'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionTerm:
    '(' expr=ConditionExpression ')' | SimpleCondition
;

SimpleCondition:
    EntityCondition | TimeCondition | ValueCondition
;

EntityCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

ValueCondition:
    left_value=PropertyValue operator=ComparisonOperator right_value=PropertyValue
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=ActionTarget)?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'send_notification' | 'call_service' | 'delay'
;

ActionTarget:
    EntityTarget | ServiceTarget | NotificationTarget
;

EntityTarget:
    'entity' '(' entity=[Entity] (',' property=ID)? ')'
;

ServiceTarget:
    'service' '(' service_name=STRING ')'
;

NotificationTarget:
    'notification' '(' channel=STRING ')'
;

ActionParameter:
    name=ID ':' value=ParameterValue
;

ParameterValue:
    FLOAT | INT | STRING | BOOL | EntityReference
;

EntityReference:
    entity=[Entity] ('.' property=ID)?
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;