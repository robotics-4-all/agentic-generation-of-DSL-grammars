SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth_configs*=AuthConfig
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object'
;

PropertyValue:
    Array | Object | FLOAT | INT | STRING | BOOL
;

Array:
    '[' items*=PropertyValue[','] ']'
;

Object:
    '{' pairs*=ObjectPair[','] '}'
;

ObjectPair:
    key=STRING ':' value=PropertyValue
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

BehaviorType:
    'read' | 'write' | 'notify' | 'execute' | 'schedule'
;

BehaviorParam:
    name=ID '=' value=PropertyValue
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' params*=BehaviorParam[','] ')')?
;

ComparisonOperator:
    '==' | '!=' | '>=' | '<=' | '>' | '<' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ActionType:
    'set_property' | 'call_behavior' | 'send_notification' | 'execute_script' | 'trigger_automation'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Metadata:
    'Metadata' name=ID
    (
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

CoapBroker:
    'Broker<CoAP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | CoapBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

TimeTrigger:
    'time(' schedule=STRING ')'
;

EventTrigger:
    'event(' event_name=STRING ')'
;

PropertyTrigger:
    'property(' entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue ')'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | PropertyTrigger
;

PropertyCondition:
    entity=[Entity] '.' property=ID comparison=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' comparison=ComparisonOperator time_value=STRING
;

StateCondition:
    entity=[Entity] '.' 'status' comparison=ComparisonOperator status=EntityStatus
;

ConditionTerm:
    PropertyCondition | TimeCondition | StateCondition | '(' expression=ConditionExpression ')'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry:' retry=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' condition_refs*=[Condition]['-'])?
        ('actions:' '-' action_refs*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;