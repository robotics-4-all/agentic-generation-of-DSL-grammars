SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentications*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

EntityType:
    'SENSOR' | 'ACTUATOR' | 'DEVICE' | 'CONTROLLER' | 'GATEWAY'
;

EntityStatus:
    'ACTIVE' | 'INACTIVE' | 'MAINTENANCE' | 'ERROR'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

Behavior:
    name=ID ':' description=STRING
;

ExecutionMode:
    'SEQUENTIAL' | 'PARALLEL' | 'CONDITIONAL'
;

PropertyReference:
    entity=[Entity] '.' property=ID
;

Operand:
    PropertyReference | PropertyValue
;

LogicalOperator:
    'AND' | 'OR' | 'NOT'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'CONTAINS' | 'MATCHES'
;

ComparisonExpression:
    left=Operand operator=ComparisonOperator right=Operand
;

LogicalTerm:
    ComparisonExpression | '(' expression=LogicalExpression ')'
;

LogicalExpression:
    terms+=LogicalTerm (operator=LogicalOperator terms+=LogicalTerm)*
;

EventTrigger:
    'Event' '(' entity=[Entity] ',' event=STRING ')'
;

TimeTrigger:
    'Time' '(' schedule=STRING ')'
;

StateTrigger:
    'State' '(' entity=[Entity] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

Trigger:
    EventTrigger | TimeTrigger | StateTrigger
;

ActionType:
    'SET_PROPERTY' | 'SEND_COMMAND' | 'SEND_MESSAGE' | 'CALL_SERVICE' | 'TRIGGER_AUTOMATION'
;

ActionParameter:
    name=ID '=' value=PropertyValue
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('clientId:' clientId=STRING)?
        ('keepAlive:' keepAlive=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('baseUrl:' baseUrl=STRING)
        ('timeout:' timeout=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])?
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Action:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('target:' target=[Entity])
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retries:' retries=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('executionMode:' mode=ExecutionMode)?
    )#
    'end'
;