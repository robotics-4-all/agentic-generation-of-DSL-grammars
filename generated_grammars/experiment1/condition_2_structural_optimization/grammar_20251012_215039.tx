SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=Broker
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('basePath:' basePath=STRING)?
        ('webPath:' webPath=STRING)?
        ('webPort:' webPort=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('topicExchange:' topicExchange=STRING)?
        ('rpcExchange:' rpcExchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

PlainAuth:
    'Auth<Plain>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

ApiKeyAuth:
    'Auth<ApiKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Cert>' name=ID
    (
        ('cert:' cert=STRING)
        ('certPath:' certPath=STRING)?
        ('keyPath:' keyPath=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'hybrid' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

Parameter:
    name=ID ':' value=PropertyValue
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=STRING)
        ('action:' action=STRING)
        ('parameters:' '-' parameters*=Parameter['-'])?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[Broker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not' | 'xor'
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

EntityAction:
    'EntityAction'
    (
        ('target:' target=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' '-' parameters*=Parameter['-'])?
    )#
    'end'
;

SystemAction:
    'SystemAction'
    (
        ('command:' command=STRING)
        ('parameters:' '-' parameters*=Parameter['-'])?
    )#
    'end'
;

NotificationSeverity:
    'info' | 'warning' | 'error' | 'critical'
;

NotificationAction:
    'NotificationAction'
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)
        ('severity:' severity=NotificationSeverity)?
    )#
    'end'
;

WeekDay:
    'monday' | 'tuesday' | 'wednesday' | 'thursday' | 'friday' | 'saturday' | 'sunday'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days' | 'weeks'
;

TimeSchedule:
    'TimeSchedule'
    (
        ('time:' time=STRING)
        ('days:' '-' days*=WeekDay['-'])?
        ('timezone:' timezone=STRING)?
    )#
    'end'
;

IntervalSchedule:
    'IntervalSchedule'
    (
        ('interval:' interval=INT)
        ('unit:' unit=TimeUnit)
        ('startTime:' startTime=STRING)?
        ('endTime:' endTime=STRING)?
    )#
    'end'
;

EventSchedule:
    'EventSchedule'
    (
        ('eventSource:' eventSource=[Entity])
        ('eventType:' eventType=STRING)
        ('eventCondition:' eventCondition=Condition)?
    )#
    'end'
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;

Comment:
    CommentLine | CommentBlock
;

Schedule:
    TimeSchedule | IntervalSchedule | EventSchedule
;

Action:
    EntityAction | SystemAction | NotificationAction
;

Authentication:
    PlainAuth | ApiKeyAuth | CertAuth
;

Broker:
    MQTTBroker | AMQPBroker | RedisBroker
;

Condition:
    left=SimpleCondition (operator=LogicalOperator right=SimpleCondition)*
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)
        ('priority:' priority=INT)?
        ('conditions:' '-' conditions*=Condition['-'])
        ('actions:' '-' actions*=Action['-'])
        ('schedule:' schedule=Schedule)?
        ('executionMode:' executionMode=ExecutionMode)?
    )#
    'end'
;