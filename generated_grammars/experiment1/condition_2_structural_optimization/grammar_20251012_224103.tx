SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[Authentication])?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('basePath:' basePath=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    TokenAuth | BasicAuth | CertificateAuth
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('tokenType:' tokenType=STRING)?
        ('header:' header=STRING)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Entity:
    SensorEntity | ActuatorEntity | DeviceEntity
;

SensorEntity:
    'Entity<Sensor>' name=ID
    (
        ('type:' entityType=STRING)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('sampling:' sampling=INT)?
        ('unit:' unit=STRING)?
    )#
    'end'
;

ActuatorEntity:
    'Entity<Actuator>' name=ID
    (
        ('type:' entityType=STRING)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('commands:' '-' commands*=STRING['-'])?
    )#
    'end'
;

DeviceEntity:
    'Entity<Device>' name=ID
    (
        ('type:' entityType=STRING)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('capabilities:' '-' capabilities*=STRING['-'])?
    )#
    'end'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'float' | 'int' | 'string' | 'bool' | 'array' | 'object'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

Behavior:
    name=ID ':' description=STRING ('trigger:' trigger=STRING)?
;

Automation:
    'Automation' name=ID
    (
        ('description:' description=STRING)?
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'Time' '(' schedule=STRING ')'
;

EventTrigger:
    'Event' '(' entity=[Entity] ',' event=STRING ')'
;

StateTrigger:
    'State' '(' entity=[Entity] '.' property=ID operator=ConditionOperator value=PropertyValue ')'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

Condition:
    'Condition' name=ID
    (
        ('description:' description=STRING)?
        ('expression:' expression=ConditionExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ConditionExpression:
    left=ConditionOperand (operator=ConditionOperator right=ConditionOperand)*
;

ConditionOperand:
    EntityReference | LiteralValue | FunctionCall | '(' ConditionExpression ')'
;

EntityReference:
    entity=[Entity] ('.' property=ID)?
;

LiteralValue:
    FLOAT | INT | STRING | BOOL
;

FunctionCall:
    function=ID '(' parameters*=ConditionOperand[','] ')'
;

ConditionOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'and' | 'or' | 'not'
;

Action:
    SendAction | SetAction | CallAction | DelayAction
;

SendAction:
    'Action<Send>' name=ID
    (
        ('description:' description=STRING)?
        ('target:' target=[Entity])
        ('message:' message=STRING)
        ('payload:' payload=ActionPayload)?
        ('retry:' retry=INT)?
    )#
    'end'
;

SetAction:
    'Action<Set>' name=ID
    (
        ('description:' description=STRING)?
        ('target:' target=[Entity])
        ('property:' property=ID)
        ('value:' value=ActionValue)
    )#
    'end'
;

CallAction:
    'Action<Call>' name=ID
    (
        ('description:' description=STRING)?
        ('service:' service=STRING)
        ('method:' method=STRING)
        ('parameters:' parameters=ActionPayload)?
    )#
    'end'
;

DelayAction:
    'Action<Delay>' name=ID
    (
        ('description:' description=STRING)?
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

ActionPayload:
    '{' items*=PayloadItem[','] '}'
;

PayloadItem:
    key=STRING ':' value=ActionValue
;

ActionValue:
    FLOAT | INT | STRING | BOOL | EntityReference
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;