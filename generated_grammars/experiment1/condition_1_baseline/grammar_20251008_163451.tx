SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=Broker)*
    (entities*=Entity)*
    (automations*=Automation)*
    (conditions*=Condition)*
    (actions*=Action)*
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=Authentication)?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('base_path:' base_path=STRING)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

Authentication:
    UsernamePasswordAuth | APIKeyAuth | CertificateAuth
;

UsernamePasswordAuth:
    'username:' username=STRING 'password:' password=STRING
;

APIKeyAuth:
    'api_key:' api_key=STRING
;

CertificateAuth:
    'certificate:' certificate=STRING
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[Broker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'string' | 'integer' | 'float' | 'boolean' | 'array' | 'object'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

Behavior:
    'behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('action:' action=[Action])
        ('frequency:' frequency=INT)?
    )#
    'end'
;

BehaviorTrigger:
    'periodic' | 'event_driven' | 'condition_based'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event_type=STRING ')'
;

StateTrigger:
    'state' '(' condition=[Condition] ')'
;

TimeSchedule:
    'cron:' cron_expression=STRING | 'interval:' interval=INT
;

ExecutionControl:
    'sequential' | 'parallel' | 'conditional'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ComparisonExpression:
    '(' expression=LogicalExpression ')' |
    left=PropertyReference operator=ComparisonOperator right=ComparisonValue
;

PropertyReference:
    entity=[Entity] '.' property=ID
;

ComparisonValue:
    STRING | INT | FLOAT | BOOL | PropertyReference
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'in'
;

Action:
    EntityAction | NotificationAction | SystemAction
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('target:' target=[Entity])
        ('operation:' operation=EntityOperation)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry:' retry=INT)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=NotificationChannel)
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

SystemAction:
    'Action<System>' name=ID
    (
        ('command:' command=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

EntityOperation:
    'turn_on' | 'turn_off' | 'set_value' | 'get_status' | 'reset'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'webhook'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

ActionParameter:
    name=ID ':' value=ParameterValue
;

ParameterValue:
    STRING | INT | FLOAT | BOOL | PropertyReference
;