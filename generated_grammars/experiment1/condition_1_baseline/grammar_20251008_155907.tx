SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Cert>' name=ID
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)
        ('ca:' ca=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])?
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=TriggerType)
        ('frequency:' frequency=INT)?
        ('payload:' payload=STRING)?
    )#
    'end'
;

TriggerType:
    'periodic' | 'event' | 'change' | 'threshold'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=AutomationTrigger)
        ('condition:' condition=[Condition])?
        ('actions:' '-' actions*=[Action]['-'])
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;

AutomationTrigger:
    EntityTrigger | TimeTrigger | EventTrigger
;

EntityTrigger:
    'EntityTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=STRING)
        ('event:' event=TriggerEvent)
        ('value:' value=PropertyValue)?
    )#
    'end'
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('repeat:' repeat=BOOL)?
    )#
    'end'
;

EventTrigger:
    'EventTrigger'
    (
        ('event:' event=STRING)
        ('source:' source=STRING)?
    )#
    'end'
;

TriggerEvent:
    'changed' | 'equals' | 'greater' | 'less' | 'contains'
;

ExecutionMode:
    'sequential' | 'parallel' | 'immediate' | 'delayed'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
    )#
    'end'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionExpression)?
;

ConditionTerm:
    SimpleCondition | GroupedCondition
;

SimpleCondition:
    entity=[Entity] '.' property=STRING comparison=ComparisonOperator value=PropertyValue
;

GroupedCondition:
    '(' expression=ConditionExpression ')'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

Action:
    EntityAction | NotificationAction | ScriptAction
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('entity:' entity=[Entity])
        ('property:' property=STRING)
        ('value:' value=PropertyValue)
        ('method:' method=ActionMethod)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=NotificationChannel)
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

ScriptAction:
    'Action<Script>' name=ID
    (
        ('script:' script=STRING)
        ('language:' language=ScriptLanguage)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ActionMethod:
    'set' | 'toggle' | 'increment' | 'decrement'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'mqtt' | 'webhook'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

ScriptLanguage:
    'python' | 'javascript' | 'bash' | 'lua'
;