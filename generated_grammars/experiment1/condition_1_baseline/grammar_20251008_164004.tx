SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('system_info:' system_info=SystemInfo)?
    )#
    'end'
;

SystemInfo:
    '{'
    (
        ('platform:' platform=STRING)?
        ('environment:' environment=STRING)?
        ('deployment:' deployment=STRING)?
    )#
    '}'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('base_path:' base_path=STRING)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'BasicAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'CertAuth'
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'service'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'array'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL | JsonObject | JsonArray
;

JsonObject:
    '{' items*=JsonItem[','] '}'
;

JsonArray:
    '[' items*=PropertyValue[','] ']'
;

JsonItem:
    name=STRING ':' value=PropertyValue
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' parameters=BehaviorParams ')')?
;

BehaviorType:
    'periodic' | 'event_driven' | 'reactive' | 'scheduled'
;

BehaviorParams:
    '{' params*=BehaviorParam[','] '}'
;

BehaviorParam:
    name=ID '=' value=PropertyValue
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' execution_mode=ExecutionMode)?
    )#
    'end'
;

AutomationTrigger:
    EventTrigger | TimeTrigger | StateTrigger
;

EventTrigger:
    'EventTrigger'
    (
        ('entity:' entity=[Entity])
        ('event:' event=STRING)
        ('filter:' filter=TriggerFilter)?
    )#
    'end'
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('timezone:' timezone=STRING)?
    )#
    'end'
;

StateTrigger:
    'StateTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=STRING)
        ('condition:' condition=StateCondition)
    )#
    'end'
;

StateCondition:
    operator=ComparisonOperator value=PropertyValue
;

TriggerFilter:
    '{' filters*=FilterCondition[','] '}'
;

FilterCondition:
    property=STRING operator=ComparisonOperator value=PropertyValue
;

ExecutionMode:
    'sequential' | 'parallel' | 'single'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;

LogicalExpression:
    terms+=LogicalTerm (operators+=LogicalOperator terms+=LogicalTerm)*
;

LogicalTerm:
    '(' expression=LogicalExpression ')' | condition=SimpleCondition
;

SimpleCondition:
    EntityCondition | TimeCondition | ValueCondition
;

EntityCondition:
    entity=[Entity] '.' property=STRING operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

ValueCondition:
    left=PropertyValue operator=ComparisonOperator right=PropertyValue
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' parameters=ActionParameters)?
        ('retry_policy:' retry_policy=RetryPolicy)?
        ('description:' description=STRING)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'send_notification' | 'call_service' | 'script'
;

ActionParameters:
    '{' params*=ActionParam[','] '}'
;

ActionParam:
    name=ID '=' value=PropertyValue
;

RetryPolicy:
    'RetryPolicy'
    (
        ('max_attempts:' max_attempts=INT)
        ('delay:' delay=INT)?
        ('backoff:' backoff=STRING)?
    )#
    'end'
;