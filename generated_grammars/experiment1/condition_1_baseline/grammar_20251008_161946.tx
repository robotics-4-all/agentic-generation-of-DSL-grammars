SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=Broker)?
    (auth_mechanisms*=AuthMechanism)?
    (entities*=Entity)?
    (automations*=Automation)?
    (conditions*=Condition)?
    (actions*=Action)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('system_id:' system_id=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic_prefix:' topic_prefix=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
        ('qos:' qos=INT)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('base_url:' base_url=STRING)
        ('port:' port=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

AuthMechanism:
    BasicAuth | TokenAuth | CertificateAuth | APIKeyAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('token_type:' token_type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('api_key:' api_key=STRING)
        ('header_name:' header_name=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[Broker])?
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

Property:
    'Property' name=ID
    (
        ('data_type:' data_type=DataType)
        ('value:' value=PropertyValue)?
        ('unit:' unit=STRING)?
        ('readonly:' readonly=BOOL)?
        ('min_value:' min_value=NUMBER)?
        ('max_value:' max_value=NUMBER)?
    )#
    'end'
;

DataType:
    'boolean' | 'integer' | 'float' | 'string' | 'timestamp' | 'json' | 'binary'
;

PropertyValue:
    NUMBER | STRING | BOOL
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('action:' action=[Action])
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

BehaviorTrigger:
    'on_change' | 'on_threshold' | 'on_schedule' | 'on_event'
;

Automation:
    'Automation' name=ID
    (
        ('triggers:' '-' triggers*=AutomationTrigger['-'])
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('mode:' mode=AutomationMode)?
        ('enabled:' enabled=BOOL)?
        ('description:' description=STRING)?
    )#
    'end'
;

AutomationTrigger:
    PropertyTrigger | TimeTrigger | EventTrigger
;

PropertyTrigger:
    'PropertyTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=STRING)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
    'end'
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('repeat:' repeat=BOOL)?
    )#
    'end'
;

EventTrigger:
    'EventTrigger'
    (
        ('event_type:' event_type=STRING)
        ('source:' source=[Entity])?
    )#
    'end'
;

AutomationMode:
    'single' | 'restart' | 'queued' | 'parallel'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ComparisonExpression:
    left=ConditionOperand operator=ComparisonOperator right=ConditionOperand
    | '(' expression=LogicalExpression ')'
;

ConditionOperand:
    PropertyReference | ConstantValue
;

PropertyReference:
    entity=[Entity] '.' property=STRING
;

ConstantValue:
    NUMBER | STRING | BOOL
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'in' | 'not_in'
;

Action:
    SetPropertyAction | CallServiceAction | NotifyAction | DelayAction
;

SetPropertyAction:
    'Action<SetProperty>' name=ID
    (
        ('entity:' entity=[Entity])
        ('property:' property=STRING)
        ('value:' value=PropertyValue)
    )#
    'end'
;

CallServiceAction:
    'Action<CallService>' name=ID
    (
        ('service_url:' service_url=STRING)
        ('method:' method=HTTPMethod)
        ('payload:' payload=STRING)?
        ('headers:' '-' headers*=Header['-'])?
    )#
    'end'
;

NotifyAction:
    'Action<Notify>' name=ID
    (
        ('message:' message=STRING)
        ('target:' target=STRING)?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

DelayAction:
    'Action<Delay>' name=ID
    (
        ('duration:' duration=NUMBER)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

Header:
    'Header' name=STRING ':' value=STRING
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;