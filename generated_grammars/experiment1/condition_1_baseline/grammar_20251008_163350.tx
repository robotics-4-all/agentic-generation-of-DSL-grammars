SmartEnvironmentModel:
    metadata=Metadata?
    brokers*=Broker
    authentication*=Authentication
    entities*=Entity
    automations*=Automation
    conditions*=Condition
    actions*=Action
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)?
        ('method:' method=HTTPMethod)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth | APIKeyAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('token_type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('api_key:' api_key=STRING)
        ('header_name:' header_name=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[Broker])
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

Property:
    'Property' name=ID
    (
        ('data_type:' data_type=DataType)
        ('value:' value=PropertyValue)?
        ('unit:' unit=STRING)?
        ('range:' range=ValueRange)?
        ('readonly:' readonly=BOOL)?
    )#
    'end'
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    INT | FLOAT | STRING | BOOL
;

ValueRange:
    'Range' '(' min=NUMBER ',' max=NUMBER ')'
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('action:' action=[Action])
        ('parameters:' '-' parameters*=Parameter['-'])?
    )#
    'end'
;

BehaviorTrigger:
    'on_change' | 'on_value' | 'periodic' | 'external'
;

Parameter:
    name=ID ':' value=PropertyValue
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('execution:' execution=ExecutionMode)?
        ('priority:' priority=INT)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | PropertyTrigger
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('repeat:' repeat=BOOL)?
    )#
    'end'
;

EventTrigger:
    'EventTrigger'
    (
        ('event_type:' event_type=STRING)
        ('source:' source=[Entity])?
    )#
    'end'
;

PropertyTrigger:
    'PropertyTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=STRING)
        ('condition:' condition=TriggerCondition)
    )#
    'end'
;

TriggerCondition:
    'equals' | 'greater_than' | 'less_than' | 'changed' | 'contains'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

Condition:
    'Condition' name=ID
    (
        ('type:' condition_type=ConditionType)
        ('entity:' entity=[Entity])?
        ('property:' property=STRING)?
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
        ('logical_op:' logical_op=LogicalOperator)?
        ('next_condition:' next_condition=[Condition])?
    )#
    'end'
;

ConditionType:
    'property_check' | 'time_check' | 'state_check' | 'custom'
;

ComparisonOperator:
    'eq' | 'ne' | 'gt' | 'lt' | 'ge' | 'le' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not' | 'xor'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])?
        ('operation:' operation=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry_count:' retry_count=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ActionType:
    'device_control' | 'notification' | 'data_logging' | 'service_call' | 'custom'
;

ActionParameter:
    'ActionParam' name=ID
    (
        ('value:' value=PropertyValue)
        ('source:' source=ParameterSource)?
    )#
    'end'
;

ParameterSource:
    'static' | 'dynamic' | 'computed' | 'external'
;