SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certFile:' certFile=STRING)
        ('keyFile:' keyFile=STRING)
        ('caFile:' caFile=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])?
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('capabilities:' '-' capabilities*=Capability['-'])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)? ('(' constraints=PropertyConstraints ')')?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'object' | 'array'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

PropertyConstraints:
    min=NUMBER (',' max=NUMBER)? | choices=StringList
;

StringList:
    '[' items*=STRING[','] ']'
;

Behavior:
    name=ID ':' implementation=BehaviorImplementation
;

BehaviorImplementation:
    'script:' script=STRING | 'function:' function=STRING | 'service:' service=STRING
;

Capability:
    name=ID ':' capabilityType=CapabilityType
;

CapabilityType:
    'read' | 'write' | 'execute' | 'notify' | 'subscribe'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

TimeSchedule:
    'cron:' cronExpression=STRING | 'interval:' interval=INT | 'at:' time=STRING
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event=STRING ')'
;

StateTrigger:
    'state' '(' entity=[Entity] ',' property=ID ',' value=PropertyValue ')'
;

ExecutionMode:
    'sequential' | 'parallel' | 'single' | 'queued'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ConditionExpression:
    left=ConditionOperand operator=ComparisonOperator right=ConditionOperand |
    left=ConditionExpression logical=LogicalOperator right=ConditionExpression |
    '(' expression=ConditionExpression ')'
;

ConditionOperand:
    EntityPropertyRef | ConstantValue | FunctionCall
;

EntityPropertyRef:
    entity=[Entity] '.' property=ID
;

ConstantValue:
    STRING | INT | FLOAT | BOOL
;

FunctionCall:
    function=ID '(' parameters*=FunctionParameter[','] ')'
;

FunctionParameter:
    name=ID '=' value=ConditionOperand
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'startsWith' | 'endsWith'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('target:' target=ActionTarget)?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry:' retryPolicy=RetryPolicy)?
    )#
    'end'
;

ActionType:
    'set' | 'call' | 'notify' | 'execute' | 'delay' | 'log'
;

ActionTarget:
    EntityTarget | ServiceTarget | NotificationTarget
;

EntityTarget:
    'entity:' entity=[Entity] ('.' property=ID)?
;

ServiceTarget:
    'service:' service=STRING
;

NotificationTarget:
    'notification:' channel=STRING
;

ActionParameter:
    name=ID ':' value=ActionValue
;

ActionValue:
    STRING | INT | FLOAT | BOOL | EntityPropertyRef | VariableRef
;

VariableRef:
    '$' variable=ID
;

RetryPolicy:
    'attempts:' attempts=INT (',' 'delay:' delay=INT)?
;