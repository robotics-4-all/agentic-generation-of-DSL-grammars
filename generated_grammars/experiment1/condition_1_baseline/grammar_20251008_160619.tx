SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=Broker)*
    (entities*=Entity)*
    (automations*=Automation)*
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=Authentication)?
        ('topics:' '-' topics*=Topic['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('basePath:' basePath=STRING)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

Topic:
    name=STRING ':' qos=INT
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'BasicAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
;

CertAuth:
    'CertAuth'
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)
        ('ca:' ca=STRING)?
    )#
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[Broker])
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

Behavior:
    name=ID ':' action=STRING ('when' condition=Condition)?
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

Trigger:
    EntityTrigger | TimeTrigger | EventTrigger
;

EntityTrigger:
    'EntityTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=STRING)
        ('event:' event=TriggerEvent)
    )#
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('timezone:' timezone=STRING)?
    )#
;

EventTrigger:
    'EventTrigger'
    (
        ('event:' event=STRING)
        ('source:' source=STRING)?
    )#
;

TriggerEvent:
    'changed' | 'equals' | 'above' | 'below' | 'between'
;

Condition:
    SimpleCondition | CompoundCondition
;

SimpleCondition:
    left=ConditionOperand operator=ComparisonOperator right=ConditionOperand
;

CompoundCondition:
    conditions+=Condition logicalOp=LogicalOperator conditions+=Condition
;

ConditionOperand:
    EntityReference | LiteralValue | FunctionCall
;

EntityReference:
    entity=[Entity] '.' property=STRING
;

LiteralValue:
    STRING | INT | FLOAT | BOOL
;

FunctionCall:
    name=ID '(' args*=ConditionOperand[','] ')'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'startswith' | 'endswith'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    EntityAction | NotificationAction | ServiceAction | DelayAction
;

EntityAction:
    'EntityAction'
    (
        ('entity:' entity=[Entity])
        ('command:' command=STRING)
        ('parameters:' '-' parameters*=Parameter['-'])?
    )#
;

NotificationAction:
    'NotificationAction'
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)
        ('level:' level=NotificationLevel)?
    )#
;

ServiceAction:
    'ServiceAction'
    (
        ('service:' service=STRING)
        ('method:' method=STRING)
        ('parameters:' '-' parameters*=Parameter['-'])?
    )#
;

DelayAction:
    'DelayAction'
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
;

Parameter:
    name=ID ':' value=ParameterValue
;

ParameterValue:
    STRING | INT | FLOAT | BOOL | EntityReference
;

NotificationLevel:
    'info' | 'warning' | 'error' | 'critical'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('retries:' retries=INT)?
        ('timeout:' timeout=INT)?
        ('onError:' onError=ErrorHandling)?
    )#
;

ExecutionMode:
    'sequential' | 'parallel' | 'async'
;

ErrorHandling:
    'continue' | 'stop' | 'retry' | 'rollback'
;