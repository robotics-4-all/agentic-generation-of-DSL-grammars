SmartEnvironmentModel:
    metadata=SystemMetadata?
    brokers*=BrokerDefinition
    authentication*=AuthenticationDefinition
    entities*=EntityDefinition
    automations*=AutomationDeclaration
    conditions*=ConditionSpecification
    actions*=ActionDefinition
;

SystemMetadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BrokerDefinition:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[AuthenticationDefinition])?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationDefinition])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('database:' database=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationDefinition])?
    )#
    'end'
;

AuthenticationDefinition:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[BrokerDefinition])
        ('location:' location=STRING)?
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('topic:' topic=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

PropertyDefinition:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)? ('(' unit=STRING ')')?
;

BehaviorDefinition:
    name=ID ':' behavior_type=BehaviorType ('=' config=PropertyValue)?
;

BehaviorType:
    'periodic' | 'event_driven' | 'threshold' | 'manual' | 'scheduled'
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'json' | 'array' | 'object'
;

PropertyValue:
    INT | FLOAT | STRING | BOOL | ArrayValue | ObjectValue
;

ArrayValue:
    '[' items*=PropertyValue[','] ']'
;

ObjectValue:
    '{' pairs*=ObjectPair[','] '}'
;

ObjectPair:
    key=STRING ':' value=PropertyValue
;

AutomationDeclaration:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDefinition)
        ('conditions:' '-' conditions*=[ConditionSpecification]['-'])?
        ('actions:' '-' actions*=[ActionDefinition]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

TriggerDefinition:
    EventTrigger | TimeTrigger | ThresholdTrigger
;

EventTrigger:
    'Event' '(' entity=[EntityDefinition] ',' event_type=STRING ')'
;

TimeTrigger:
    'Time' '(' schedule=STRING ')'
;

ThresholdTrigger:
    'Threshold' '(' entity=[EntityDefinition] ',' property=STRING ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('retry:' retry=INT)?
        ('timeout:' timeout=INT)?
        ('delay:' delay=INT)?
    )#
    'end'
;

ExecutionMode:
    'immediate' | 'queued' | 'scheduled' | 'parallel'
;

ConditionSpecification:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
        ('evaluation:' evaluation=EvaluationMode)?
    )#
    'end'
;

LogicalExpression:
    operand=LogicalOperand (operator=LogicalOperator right=LogicalExpression)?
;

LogicalOperand:
    '(' expression=LogicalExpression ')' | ComparisonExpression
;

ComparisonExpression:
    left=ExpressionOperand operator=ComparisonOperator right=ExpressionOperand
;

ExpressionOperand:
    PropertyReference | PropertyValue
;

PropertyReference:
    entity=[EntityDefinition] '.' property=STRING
;

LogicalOperator:
    'and' | 'or' | 'not' | 'xor'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

EvaluationMode:
    'continuous' | 'on_change' | 'periodic'
;

ActionDefinition:
    SetPropertyAction | SendMessageAction | CallServiceAction | DelayAction
;

SetPropertyAction:
    'Action<SetProperty>' name=ID
    (
        ('entity:' entity=[EntityDefinition])
        ('property:' property=STRING)
        ('value:' value=PropertyValue)
        ('confirmation:' confirmation=BOOL)?
    )#
    'end'
;

SendMessageAction:
    'Action<SendMessage>' name=ID
    (
        ('broker:' broker=[BrokerDefinition])
        ('topic:' topic=STRING)
        ('message:' message=PropertyValue)
        ('qos:' qos=INT)?
        ('retain:' retain=BOOL)?
    )#
    'end'
;

CallServiceAction:
    'Action<CallService>' name=ID
    (
        ('service_url:' service_url=STRING)
        ('method:' method=HTTPMethod)
        ('payload:' payload=PropertyValue)?
        ('headers:' headers=ObjectValue)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

DelayAction:
    'Action<Delay>' name=ID
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;