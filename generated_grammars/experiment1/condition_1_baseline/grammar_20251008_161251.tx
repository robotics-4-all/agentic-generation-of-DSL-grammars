SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentications*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('headers:' '-' headers*=Property['-'])?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
        ('header:' header=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('broker:' broker=[MessageBroker])?
        ('topic:' topic=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'system' | 'virtual'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'array' | 'object'
;

PropertyValue:
    INT | FLOAT | STRING | BOOL
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=TriggerType)
        ('frequency:' frequency=INT)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

TriggerType:
    'periodic' | 'event' | 'change' | 'manual'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('mode:' mode=ExecutionMode)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EntityTrigger | EventTrigger
;

TimeTrigger:
    'time' '(' schedule=STRING ')'
;

EntityTrigger:
    'entity' '(' entity=[Entity] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

EventTrigger:
    'event' '(' eventName=STRING ')'
;

ExecutionMode:
    'sequential' | 'parallel' | 'single'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('timeout:' timeout=INT)?
        ('retries:' retries=INT)?
    )#
    'end'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionExpression)?
;

ConditionTerm:
    SimpleCondition | '(' expression=ConditionExpression ')'
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

Action:
    EntityAction | NotificationAction | ServiceAction
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('entity:' entity=[Entity])
        ('operation:' operation=EntityOperation)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('delay:' delay=INT)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)
        ('priority:' priority=NotificationPriority)?
        ('recipients:' '-' recipients*=STRING['-'])?
    )#
    'end'
;

ServiceAction:
    'Action<Service>' name=ID
    (
        ('service:' service=STRING)
        ('method:' method=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

EntityOperation:
    'set' | 'get' | 'toggle' | 'increment' | 'decrement' | 'reset'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;