SmartEnvironmentModel:
    imports*=ImportStm
    (metadata=Metadata)?
    (brokers*=MessageBroker)?
    (authentication*=Authentication)?
    (entities*=Entity)?
    (automations*=Automation)?
    (conditions*=Condition)?
    (actions*=Action)?
;

ImportStm:
    'import' module=STRING ('as' alias=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('url:' url=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' headers=HeaderList)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

HeaderList:
    '[' headers*=Header[','] ']'
;

Header:
    key=STRING ':' value=STRING
;

Authentication:
    BasicAuth | TokenAuth | APIKeyAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('token_type:' token_type=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
        ('param:' param=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' type=EntityType)
        ('location:' location=STRING)?
        ('properties:' properties=PropertyList)?
        ('behaviors:' behaviors=BehaviorList)?
        ('broker:' broker=[MessageBroker])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'room' | 'zone' | 'system'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

PropertyList:
    '[' properties*=Property[','] ']'
;

Property:
    name=ID ':' type=PropertyType ('=' default=PropertyValue)?
;

PropertyType:
    'string' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL | ArrayValue | ObjectValue
;

ArrayValue:
    '[' values*=PropertyValue[','] ']'
;

ObjectValue:
    '{' pairs*=KeyValuePair[','] '}'
;

KeyValuePair:
    key=STRING ':' value=PropertyValue
;

BehaviorList:
    '[' behaviors*=Behavior[','] ']'
;

Behavior:
    name=ID '(' parameters=ParameterList? ')' '{' implementation=STRING '}'
;

ParameterList:
    parameters*=Parameter[',']
;

Parameter:
    name=ID ':' type=PropertyType
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('conditions:' conditions=ConditionList)?
        ('actions:' actions=ActionList)
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

Trigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'TimeTrigger' '(' schedule=TimeSchedule ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule | OnceSchedule
;

CronSchedule:
    'cron:' expression=STRING
;

IntervalSchedule:
    'interval:' value=INT unit=TimeUnit
;

OnceSchedule:
    'once:' datetime=STRING
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

EventTrigger:
    'EventTrigger' '(' entity=[Entity] ',' event=STRING ')'
;

StateTrigger:
    'StateTrigger' '(' condition=[Condition] ')'
;

ConditionList:
    '[' conditions*=Condition[','] ']'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

LogicalExpression:
    orExpr=AndExpression ('or' orExpr=AndExpression)*
;

AndExpression:
    andExpr=ComparisonExpression ('and' andExpr=ComparisonExpression)*
;

ComparisonExpression:
    NotExpression | SimpleExpression
;

NotExpression:
    'not' expr=SimpleExpression
;

SimpleExpression:
    EntityStateExpression | ValueExpression | GroupedExpression
;

EntityStateExpression:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ValueExpression:
    left=PropertyValue operator=ComparisonOperator right=PropertyValue
;

GroupedExpression:
    '(' expr=LogicalExpression ')'
;

ComparisonOperator:
    '==' | '!=' | '<' | '<=' | '>' | '>=' | 'in' | 'not_in' | 'contains'
;

ActionList:
    '[' actions*=Action[','] ']'
;

Action:
    'Action' name=ID
    (
        ('type:' type=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' parameters=ActionParameterList)?
        ('delay:' delay=INT)?
        ('retry:' retry=RetryConfig)?
    )#
    'end'
;

ActionType:
    'set_state' | 'send_command' | 'notify' | 'call_service' | 'script'
;

ActionParameterList:
    '[' parameters*=ActionParameter[','] ']'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

RetryConfig:
    'RetryConfig' '(' attempts=INT ',' interval=INT ')'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('max_duration:' max_duration=INT)?
        ('parallel:' parallel=BOOL)?
    )#
    'end'
;

ExecutionMode:
    'immediate' | 'queued' | 'scheduled' | 'conditional'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;