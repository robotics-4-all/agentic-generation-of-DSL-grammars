SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=Broker)*
    (entities*=Entity)*
    (automations*=Automation)*
    (conditions*=Condition)*
    (actions*=Action)*
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'BasicAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'CertAuth'
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[Broker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'integer' | 'float' | 'boolean' | 'array' | 'object'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=TriggerEvent)
        ('response:' response=ResponseAction)
    )#
    'end'
;

TriggerEvent:
    'property_change' | 'timer' | 'external_event' | 'threshold_exceeded'
;

ResponseAction:
    'send_message' | 'update_property' | 'execute_command' | 'log_event'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('conditions:' '-' conditions*=[Condition]['-'])
        ('actions:' '-' actions*=[Action]['-'])
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

Condition:
    'Condition' name=ID
    (
        ('type:' conditionType=ConditionType)
        ('entity:' entity=[Entity])?
        ('property:' property=STRING)?
        ('operator:' operator=ComparisonOperator)
        ('value:' value=ConditionValue)
        ('logical:' logical=LogicalOperator)?
    )#
    'end'
;

ConditionType:
    'property_equals' | 'property_greater' | 'property_less' | 'time_based' | 'state_change'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ConditionValue:
    STRING | INT | FLOAT | BOOL
;

Action:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('entity:' entity=[Entity])?
        ('property:' property=STRING)?
        ('value:' value=ActionValue)?
        ('message:' message=STRING)?
        ('command:' command=STRING)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'send_notification' | 'log_message' | 'trigger_automation'
;

ActionValue:
    STRING | INT | FLOAT | BOOL
;