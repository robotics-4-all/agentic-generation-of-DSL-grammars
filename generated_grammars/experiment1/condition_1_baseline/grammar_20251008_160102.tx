SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=Broker)*
    (authentications*=Authentication)*
    (entities*=Entity)*
    (automations*=Automation)*
    (conditions*=Condition)*
    (actions*=Action)*
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('base_path:' base_path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('header_name:' header_name=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_file:' cert_file=STRING)
        ('key_file:' key_file=STRING)
        ('ca_file:' ca_file=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[Broker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=Location)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'system' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'json' | 'array'
;

PropertyValue:
    INT | FLOAT | STRING | BOOL
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' parameters=BehaviorParameters ')')?
;

BehaviorType:
    'periodic' | 'event_driven' | 'on_demand' | 'reactive'
;

BehaviorParameters:
    params*=Parameter[',']
;

Parameter:
    name=ID '=' value=PropertyValue
;

Location:
    'Location' '(' x=FLOAT ',' y=FLOAT (',' z=FLOAT)? ')'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' execution_mode=ExecutionMode)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'Time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'Event' '(' entity=[Entity] ',' event_type=STRING ')'
;

StateTrigger:
    'State' '(' entity=[Entity] ',' property=STRING ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule | FixedTimeSchedule
;

CronSchedule:
    'cron:' expression=STRING
;

IntervalSchedule:
    'interval:' seconds=INT
;

FixedTimeSchedule:
    'at:' time=STRING
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('timeout:' timeout=INT)?
        ('retry_count:' retry_count=INT)?
    )#
    'end'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionTerm:
    SimpleCondition | GroupedCondition
;

SimpleCondition:
    entity=[Entity] '.' property=STRING operator=ComparisonOperator value=PropertyValue
;

GroupedCondition:
    '(' expression=ConditionExpression ')'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'not_contains'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    DeviceAction | SystemAction | NotificationAction
;

DeviceAction:
    'Action<Device>' name=ID
    (
        ('entity:' entity=[Entity])
        ('command:' command=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('timeout:' timeout=INT)?
        ('retry_count:' retry_count=INT)?
    )#
    'end'
;

SystemAction:
    'Action<System>' name=ID
    (
        ('operation:' operation=SystemOperation)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=NotificationChannel)
        ('recipients:' '-' recipients*=STRING['-'])?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

SystemOperation:
    'restart' | 'shutdown' | 'backup' | 'log' | 'script'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'slack' | 'webhook'
;

NotificationPriority:
    'low' | 'medium' | 'high' | 'critical'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;