SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=Broker)*
    (authentications*=Authentication)*
    (entities*=Entity)*
    (automations*=Automation)*
;

Metadata:
    'Metadata' name=ID
    (
        ('version:' version=STRING)?
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('basePath:' basePath=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('basePath:' basePath=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('caCertPath:' caCertPath=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[Broker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=Location)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'service' | 'virtual'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'array'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

Behavior:
    name=ID ':' action=BehaviorAction
;

BehaviorAction:
    'publish' | 'subscribe' | 'request' | 'response' | 'notify'
;

Location:
    'Location' '(' x=FLOAT ',' y=FLOAT (',' z=FLOAT)? ')'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Condition)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;

Condition:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionTerm:
    '(' condition=Condition ')' |
    PrimitiveCondition
;

PrimitiveCondition:
    NumericCondition | StringCondition | BooleanCondition | TimeCondition
;

NumericCondition:
    entity=[Entity] '.' property=ID operator=NumericOperator value=NUMBER
;

StringCondition:
    entity=[Entity] '.' property=ID operator=StringOperator value=STRING
;

BooleanCondition:
    entity=[Entity] '.' property=ID operator=BooleanOperator value=BOOL
;

TimeCondition:
    'time' operator=TimeOperator value=STRING
;

NumericOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

StringOperator:
    '==' | '!=' | 'contains' | 'startsWith' | 'endsWith'
;

BooleanOperator:
    '==' | '!='
;

TimeOperator:
    'before' | 'after' | 'between' | 'at'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    EntityAction | DelayAction | NotificationAction
;

EntityAction:
    'set' entity=[Entity] '.' property=ID 'to' value=ActionValue
;

DelayAction:
    'delay' duration=INT unit=TimeUnit
;

NotificationAction:
    'notify' message=STRING ('via' channel=STRING)?
;

ActionValue:
    STRING | INT | FLOAT | BOOL | entity=[Entity] '.' property=ID
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;