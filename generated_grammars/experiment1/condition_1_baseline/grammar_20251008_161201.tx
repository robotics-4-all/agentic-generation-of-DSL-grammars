SmartEnvironmentModel:
    (
        (metadata=Metadata)?
        (brokers*=Broker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('keepalive:' keepalive=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth | APIKeyAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('token_type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_file:' cert_file=STRING)
        ('key_file:' key_file=STRING)
        ('ca_file:' ca_file=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('api_key:' api_key=STRING)
        ('header_name:' header_name=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('broker:' broker=[Broker])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'hybrid'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

Property:
    'Property' name=ID
    (
        ('data_type:' data_type=DataType)
        ('value:' value=PropertyValue)?
        ('readonly:' readonly=BOOL)?
        ('unit:' unit=STRING)?
        ('min_value:' min_value=NUMBER)?
        ('max_value:' max_value=NUMBER)?
    )#
    'end'
;

DataType:
    'boolean' | 'integer' | 'float' | 'string' | 'array' | 'object'
;

PropertyValue:
    NUMBER | STRING | BOOL | Array | Object
;

Array:
    '[' items*=PropertyValue[','] ']'
;

Object:
    '{' items*=ObjectItem[','] '}'
;

ObjectItem:
    key=STRING ':' value=PropertyValue
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('action:' action=[Action])
        ('conditions:' '-' conditions*=[Condition]['-'])?
    )#
    'end'
;

BehaviorTrigger:
    'on_change' | 'on_threshold' | 'on_schedule' | 'on_event' | 'on_command'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('priority:' priority=INT)?
        ('schedule:' schedule=STRING)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | PropertyTrigger
;

TimeTrigger:
    'Trigger<Time>'
    (
        ('schedule:' schedule=STRING)
        ('timezone:' timezone=STRING)?
    )#
    'end'
;

EventTrigger:
    'Trigger<Event>'
    (
        ('event_type:' event_type=STRING)
        ('source:' source=[Entity])?
    )#
    'end'
;

PropertyTrigger:
    'Trigger<Property>'
    (
        ('entity:' entity=[Entity])
        ('property:' property=STRING)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
    'end'
;

Condition:
    'Condition' name=ID
    (
        ('entity:' entity=[Entity])
        ('property:' property=STRING)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
        ('logical_op:' logical_op=LogicalOperator)?
    )#
    'end'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'in' | 'not_in' | 'contains'
;

LogicalOperator:
    'and' | 'or' | 'not' | 'xor'
;

Action:
    EntityAction | NotificationAction | ScriptAction | DelayAction
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('target:' target=[Entity])
        ('operation:' operation=EntityOperation)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

EntityOperation:
    'set_property' | 'get_property' | 'execute_command' | 'toggle_state'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=NotificationChannel)
        ('recipients:' '-' recipients*=STRING['-'])?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'webhook' | 'mqtt'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

ScriptAction:
    'Action<Script>' name=ID
    (
        ('script_type:' script_type=ScriptType)
        ('content:' content=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

ScriptType:
    'python' | 'javascript' | 'bash' | 'lua'
;

DelayAction:
    'Action<Delay>' name=ID
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ActionParameter:
    'Parameter' name=ID
    (
        ('value:' value=PropertyValue)
        ('type:' param_type=DataType)?
    )#
    'end'
;