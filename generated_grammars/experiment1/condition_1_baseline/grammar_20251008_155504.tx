SmartEnvironmentModel:
    imports*=Import
    metadata=Metadata
    brokers*=BrokerConfig
    authentication*=AuthenticationConfig
    entities*=EntityDefinition
    automations*=AutomationRule
    conditions*=ConditionSpec
    actions*=ActionDefinition
;

Import:
    'import' importURI=STRING ('as' alias=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
        ('realm:' realm=STRING)?
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
        ('header:' header=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

PropertyDefinition:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'string' | 'integer' | 'float' | 'boolean' | 'array' | 'object'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL | ArrayValue | ObjectValue
;

ArrayValue:
    '[' values*=PropertyValue[','] ']'
;

ObjectValue:
    '{' pairs*=ObjectPair[','] '}'
;

ObjectPair:
    key=STRING ':' value=PropertyValue
;

BehaviorDefinition:
    name=ID ':' behavior_type=BehaviorType ('config:' config=ObjectValue)?
;

BehaviorType:
    'periodic' | 'event_driven' | 'threshold' | 'schedule'
;

AutomationRule:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDefinition)
        ('conditions:' '-' conditions*=[ConditionSpec]['-'])?
        ('actions:' '-' actions*=[ActionDefinition]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

TriggerDefinition:
    EventTrigger | TimeTrigger | ThresholdTrigger
;

EventTrigger:
    'Event' '(' entity=[EntityDefinition] ',' event_type=STRING ')'
;

TimeTrigger:
    'Time' '(' schedule=STRING ')'
;

ThresholdTrigger:
    'Threshold' '(' entity=[EntityDefinition] ',' property=STRING ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('retry:' retry=INT)?
        ('timeout:' timeout=INT)?
        ('delay:' delay=INT)?
    )#
    'end'
;

ExecutionMode:
    'sequential' | 'parallel' | 'async'
;

ConditionSpec:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
        ('evaluation:' evaluation=EvaluationMode)?
    )#
    'end'
;

LogicalExpression:
    term=LogicalTerm (operator=LogicalOperator term=LogicalTerm)*
;

LogicalTerm:
    ComparisonExpression | '(' LogicalExpression ')' | NotExpression
;

NotExpression:
    'not' expression=LogicalTerm
;

ComparisonExpression:
    left=ExpressionValue operator=ComparisonOperator right=ExpressionValue
;

ExpressionValue:
    PropertyReference | PropertyValue
;

PropertyReference:
    entity=[EntityDefinition] '.' property=STRING
;

LogicalOperator:
    'and' | 'or' | 'xor'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'matches'
;

EvaluationMode:
    'immediate' | 'deferred' | 'cached'
;

ActionDefinition:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[EntityDefinition])?
        ('parameters:' parameters=ObjectValue)?
        ('confirmation:' confirmation=BOOL)?
        ('rollback:' rollback=STRING)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'notify' | 'log' | 'script' | 'webhook'
;