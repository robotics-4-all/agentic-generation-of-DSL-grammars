SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=BrokerConfig)*
    (auth*=AuthenticationMechanism)*
    (entities*=EntityDefinition)*
    (automations*=AutomationDeclaration)*
    (conditions*=ConditionSpecification)*
    (actions*=ActionDefinition)*
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('keepalive:' keepalive=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationMechanism])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationMechanism])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('url:' url=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' headers=HeaderList)?
        ('timeout:' timeout=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationMechanism])?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

HeaderList:
    '[' headers*=Header[','] ']'
;

Header:
    key=STRING ':' value=STRING
;

AuthenticationMechanism:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('properties:' '-' properties*=EntityProperty['-'])?
        ('behaviors:' '-' behaviors*=EntityBehavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

EntityProperty:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'string' | 'integer' | 'float' | 'boolean' | 'array' | 'object'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL | ArrayValue | ObjectValue
;

ArrayValue:
    '[' values*=PropertyValue[','] ']'
;

ObjectValue:
    '{' pairs*=ObjectPair[','] '}'
;

ObjectPair:
    key=STRING ':' value=PropertyValue
;

EntityBehavior:
    'on' trigger=BehaviorTrigger 'do' action=[ActionDefinition]
;

BehaviorTrigger:
    'change' | 'update' | 'error' | 'startup' | 'shutdown'
;

AutomationDeclaration:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[ConditionSpecification]['-'])?
        ('actions:' '-' actions*=[ActionDefinition]['-'])
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

TimeSchedule:
    CronExpression | IntervalExpression | AbsoluteTime
;

CronExpression:
    'cron' '(' expression=STRING ')'
;

IntervalExpression:
    'interval' '(' value=INT unit=TimeUnit ')'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

AbsoluteTime:
    'at' '(' time=STRING ')'
;

EventTrigger:
    'event' '(' source=[EntityDefinition] event_type=STRING ')'
;

StateTrigger:
    'state' '(' entity=[EntityDefinition] property=ID operator=ComparisonOperator value=PropertyValue ')'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('retry:' retry=INT)?
        ('timeout:' timeout=INT)?
        ('delay:' delay=INT)?
    )#
    'end'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional' | 'immediate'
;

ConditionSpecification:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=LogicalExpression)?
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonExpression:
    left=ValueExpression operator=ComparisonOperator right=ValueExpression
    | '(' expression=LogicalExpression ')'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'matches'
;

ValueExpression:
    PropertyReference | LiteralValue | FunctionCall
;

PropertyReference:
    entity=[EntityDefinition] '.' property=ID
;

LiteralValue:
    STRING | INT | FLOAT | BOOL
;

FunctionCall:
    function_name=ID '(' parameters*=ValueExpression[','] ')'
;

ActionDefinition:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[EntityDefinition])?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry:' retry=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'send_notification' | 'call_service' | 'delay' | 'log'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;