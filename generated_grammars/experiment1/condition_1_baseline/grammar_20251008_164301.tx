SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=Broker)*
    (authentication*=Authentication)*
    (entities*=Entity)*
    (automations*=Automation)*
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('topic:' topic=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    PlainAuth | TokenAuth | CertAuth
;

PlainAuth:
    'Auth<Plain>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[Broker])?
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' parameters=BehaviorParameters ')')?
;

BehaviorType:
    'periodic' | 'event_driven' | 'threshold' | 'pattern' | 'custom'
;

BehaviorParameters:
    params*=BehaviorParam[',']
;

BehaviorParam:
    name=ID '=' value=PropertyValue
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Condition)
        ('actions:' '-' actions*=Action['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('schedule:' schedule=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

Condition:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionTerm:
    '(' condition=Condition ')' | SimpleCondition
;

SimpleCondition:
    PropertyCondition | TimeCondition | StateCondition
;

PropertyCondition:
    entity=[Entity] '.' property=ID comparison=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' comparison=ComparisonOperator time_value=STRING
;

StateCondition:
    entity=[Entity] '.' 'state' comparison=ComparisonOperator state_value=STRING
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

Action:
    SetPropertyAction | SendMessageAction | TriggerEntityAction | DelayAction
;

SetPropertyAction:
    'set' entity=[Entity] '.' property=ID '=' value=PropertyValue
;

SendMessageAction:
    'send' message=STRING 'to' target=ActionTarget
;

TriggerEntityAction:
    'trigger' entity=[Entity] '.' behavior=ID ('(' parameters=BehaviorParameters ')')?
;

DelayAction:
    'delay' duration=INT unit=TimeUnit
;

ActionTarget:
    'broker' broker=[Broker] | 'topic' topic=STRING | 'entity' entity=[Entity]
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;