SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=Broker)?
    (entities*=Entity)?
    (automations*=Automation)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('url:' url=STRING)
        ('timeout:' timeout=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'BasicAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'CertAuth'
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[Broker])
        ('topic:' topic=STRING)?
        ('attributes:' '-' attributes*=Attribute['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

Attribute:
    name=ID ':' data_type=DataType ('=' default_value=AttributeValue)?
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'json' | 'array'
;

AttributeValue:
    INT | FLOAT | STRING | BOOL
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=STRING)
        ('action:' action=STRING)
        ('frequency:' frequency=INT)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)
        ('conditions:' conditions=ConditionGroup)
        ('actions:' '-' actions*=Action['-'])
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;

ExecutionMode:
    'immediate' | 'delayed' | 'scheduled' | 'conditional'
;

ConditionGroup:
    conditions+=Condition (operator=LogicalOperator conditions+=Condition)*
;

Condition:
    '(' condition=ConditionGroup ')' | 
    SimpleCondition
;

SimpleCondition:
    EntityCondition | TimeCondition | ValueCondition
;

EntityCondition:
    entity=[Entity] '.' attribute=ID comparison=ComparisonOperator value=AttributeValue
;

TimeCondition:
    'time' comparison=ComparisonOperator time_value=TimeValue
;

ValueCondition:
    left_operand=Operand comparison=ComparisonOperator right_operand=Operand
;

Operand:
    AttributeValue | EntityReference
;

EntityReference:
    entity=[Entity] '.' attribute=ID
;

TimeValue:
    hour=INT ':' minute=INT (':' second=INT)?
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    EntityAction | NotificationAction | DelayAction | ScriptAction
;

EntityAction:
    'EntityAction'
    (
        ('entity:' entity=[Entity])
        ('attribute:' attribute=ID)
        ('value:' value=AttributeValue)
        ('method:' method=ActionMethod)?
    )#
    'end'
;

ActionMethod:
    'set' | 'toggle' | 'increment' | 'decrement'
;

NotificationAction:
    'NotificationAction'
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

NotificationPriority:
    'low' | 'medium' | 'high' | 'critical'
;

DelayAction:
    'DelayAction'
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ScriptAction:
    'ScriptAction'
    (
        ('script:' script=STRING)
        ('language:' language=ScriptLanguage)?
        ('parameters:' '-' parameters*=Parameter['-'])?
    )#
    'end'
;

ScriptLanguage:
    'python' | 'javascript' | 'bash' | 'lua'
;

Parameter:
    name=ID '=' value=AttributeValue
;

FQN:
    ID ('.' ID)*
;