SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
        ('baseTopic:' baseTopic=STRING)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
        ('exchange:' exchange=STRING)?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'BasicAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'CertAuth'
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)?
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'integer' | 'float' | 'boolean' | 'json' | 'array'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

Behavior:
    name=ID ':' description=STRING
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('mode:' mode=AutomationMode)?
    )#
    'end'
;

AutomationTrigger:
    TimeBasedTrigger | EventBasedTrigger | StateChangeTrigger
;

TimeBasedTrigger:
    'TimeBasedTrigger'
    (
        ('schedule:' schedule=STRING)
        ('interval:' interval=INT)?
        ('unit:' timeUnit=TimeUnit)?
    )#
    'end'
;

EventBasedTrigger:
    'EventBasedTrigger'
    (
        ('entity:' entity=[Entity])
        ('event:' event=STRING)
        ('value:' value=PropertyValue)?
    )#
    'end'
;

StateChangeTrigger:
    'StateChangeTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=STRING)
        ('from:' fromValue=PropertyValue)?
        ('to:' toValue=PropertyValue)
    )#
    'end'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

AutomationMode:
    'single' | 'restart' | 'parallel'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionTerm:
    '(' expression=ConditionExpression ')' | PrimitiveCondition
;

PrimitiveCondition:
    ComparisonCondition | BooleanCondition | ExistenceCondition
;

ComparisonCondition:
    entity=[Entity] '.' property=STRING comparator=ComparisonOperator value=PropertyValue
;

BooleanCondition:
    entity=[Entity] '.' property=STRING
;

ExistenceCondition:
    'exists' '(' entity=[Entity] '.' property=STRING ')'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('description:' description=STRING)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ActionType:
    'setValue' | 'sendCommand' | 'sendNotification' | 'callService' | 'script'
;

ActionParameter:
    name=ID ':' value=ParameterValue
;

ParameterValue:
    STRING | INT | FLOAT | BOOL | EntityReference
;

EntityReference:
    entity=[Entity] ('.' property=STRING)?
;