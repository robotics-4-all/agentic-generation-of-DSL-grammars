SmartEnvironmentModel:
    imports_or_references*=ImportOrReferenceStm
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

ImportOrReferenceStm:
    ImportStm | ReferenceStm
;

ImportStm:
    'import' grammar_to_import=GrammarToImport
;

ReferenceStm:
    'reference' language_name=LanguageName ('as' language_alias=ID)?
;

GrammarToImport:
    /(\w|\.)+/
;

LanguageName:
    /(\w|-)+/
;

Metadata:
    'Metadata'
    (
        ('name:' name=ID)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('system_info:' system_info=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    AuthPlain | AuthApiKey | AuthCert
;

AuthPlain:
    'Auth<Plain>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

AuthApiKey:
    'Auth<ApiKey>' name=ID
    (
        ('key:' key=STRING)
        ('secret:' secret=STRING)?
    )#
    'end'
;

AuthCert:
    'Auth<Cert>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[MessageBroker])?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL | Array | Object
;

Array:
    '[' items*=PropertyValue[','] ']'
;

Object:
    '{' items*=ObjectItem[','] '}'
;

ObjectItem:
    key=STRING ':' value=PropertyValue
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' parameters*=BehaviorParam[','] ')')?
;

BehaviorType:
    'read' | 'write' | 'subscribe' | 'publish' | 'execute' | 'monitor'
;

BehaviorParam:
    name=ID '=' value=PropertyValue
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' execution_mode=ExecutionMode)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'time' '(' schedule=STRING ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event_name=STRING ')'
;

StateTrigger:
    'state' '(' entity=[Entity] ',' property=STRING ',' condition=LogicalCondition ')'
;

ExecutionMode:
    'sequential' | 'parallel' | 'single'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ComparisonExpression:
    left=PropertyReference operator=ComparisonOperator right=ConditionValue
    | '(' expression=LogicalExpression ')'
    | LogicalCondition
;

LogicalCondition:
    entity=[Entity] '.' property=STRING operator=ComparisonOperator value=ConditionValue
;

PropertyReference:
    entity=[Entity] '.' property=STRING
;

ConditionValue:
    STRING | INT | FLOAT | BOOL | PropertyReference
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])
        ('parameters:' '-' parameters*=ActionParam['-'])?
        ('timeout:' timeout=INT)?
        ('retry:' retry=INT)?
    )#
    'end'
;

ActionType:
    'set_property' | 'call_service' | 'send_notification' | 'execute_script' | 'delay'
;

ActionParam:
    name=ID ':' value=PropertyValue
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;