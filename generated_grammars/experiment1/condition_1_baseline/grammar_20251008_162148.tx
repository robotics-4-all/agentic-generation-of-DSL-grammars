SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
    )#
;

Import:
    'import' importURI=STRING ('as' alias=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('keepalive:' keepalive=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('url:' url=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' headers=PropertyList)?
        ('timeout:' timeout=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth | APIKeyAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('token_type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('api_key:' api_key=STRING)
        ('header_name:' header_name=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])
        ('properties:' properties=PropertyList)?
        ('behaviors:' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'camera' | 'display' | 'speaker'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

PropertyList:
    '[' properties*=Property[','] ']'
;

Property:
    name=ID ':' value=PropertyValue
;

PropertyValue:
    STRING | INT | FLOAT | BOOL | PropertyList
;

Behavior:
    name=ID ':' action=BehaviorAction
;

BehaviorAction:
    'send' | 'receive' | 'process' | 'store' | 'forward' | 'alert' | 'monitor'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Condition)
        ('conditions:' conditions*=Condition['-'])?
        ('actions:' actions*=Action['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('delay:' delay=INT)?
        ('retry:' retry=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ExecutionMode:
    'immediate' | 'delayed' | 'scheduled' | 'conditional'
;

Condition:
    ComparisonCondition | LogicalCondition | TimeCondition | StateCondition
;

ComparisonCondition:
    operand1=ConditionOperand operator=ComparisonOperator operand2=ConditionOperand
;

LogicalCondition:
    left=Condition operator=LogicalOperator right=Condition
;

TimeCondition:
    'time' operator=ComparisonOperator time_value=TimeValue
;

StateCondition:
    'state' '(' entity=[Entity] ')' operator=ComparisonOperator state_value=STRING
;

ConditionOperand:
    PropertyReference | ConstantValue
;

PropertyReference:
    entity=[Entity] '.' property=ID
;

ConstantValue:
    STRING | INT | FLOAT | BOOL
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

TimeValue:
    hour=INT ':' minute=INT (':' second=INT)?
;

Action:
    SendAction | SetAction | CallAction | NotifyAction | ControlAction
;

SendAction:
    'send' message=STRING 'to' target=[Entity]
;

SetAction:
    'set' entity=[Entity] '.' property=ID 'to' value=PropertyValue
;

CallAction:
    'call' service=STRING 'with' parameters=PropertyList?
;

NotifyAction:
    'notify' message=STRING ('via' channel=STRING)?
;

ControlAction:
    'control' entity=[Entity] 'action' action_type=ControlActionType
;

ControlActionType:
    'start' | 'stop' | 'pause' | 'resume' | 'reset' | 'configure'
;