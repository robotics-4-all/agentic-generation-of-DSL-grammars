SmartEnvironmentModel:
    imports*=ImportStm
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)?
        (authentication*=Authentication)?
        (entities*=Entity)?
        (automations*=Automation)?
        (conditions*=Condition)?
        (actions*=Action)?
    )#
;

ImportStm:
    'import' grammar_to_import=STRING
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('topic:' topic=STRING)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('username:' username=STRING)?
        ('password:' password=STRING)?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('username:' username=STRING)?
        ('password:' password=STRING)?
    )#
    'end'
;

Authentication:
    AuthPlain | AuthToken | AuthCertificate
;

AuthPlain:
    'Auth<Plain>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

AuthToken:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

AuthCertificate:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'hub'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'list' | 'dict' | 'timestamp'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL | List | Dict
;

List:
    '[' items*=PropertyValue[','] ']'
;

Dict:
    '{' items*=DictItem[','] '}'
;

DictItem:
    key=STRING ':' value=PropertyValue
;

Behavior:
    name=ID ':' description=STRING
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('mode:' mode=ExecutionMode)?
    )#
    'end'
;

Trigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'time' ':' time_spec=TimeSpecification
;

EventTrigger:
    'event' ':' event_name=STRING
;

StateTrigger:
    'state' ':' entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeSpecification:
    CronExpression | TimeInterval | FixedTime
;

CronExpression:
    'cron' '(' expression=STRING ')'
;

TimeInterval:
    'interval' '(' seconds=INT ')'
;

FixedTime:
    'at' '(' time=STRING ')'
;

ExecutionMode:
    'single' | 'parallel' | 'queued' | 'restart'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ComparisonExpression:
    left=ValueExpression operator=ComparisonOperator right=ValueExpression
    | '(' expression=LogicalExpression ')'
;

ValueExpression:
    EntityReference | PropertyValue | FunctionCall
;

EntityReference:
    entity=[Entity] '.' property=ID
;

FunctionCall:
    function_name=ID '(' parameters*=PropertyValue[','] ')'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'in' | 'not_in'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry:' retry=RetryPolicy)?
    )#
    'end'
;

ActionType:
    'set_state' | 'send_command' | 'notify' | 'log' | 'script' | 'webhook'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

RetryPolicy:
    'RetryPolicy'
    (
        ('max_attempts:' max_attempts=INT)
        ('delay:' delay=INT)
        ('backoff:' backoff=BackoffStrategy)?
    )#
    'end'
;

BackoffStrategy:
    'linear' | 'exponential' | 'fixed'
;