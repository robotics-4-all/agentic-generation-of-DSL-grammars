SmartEnvironmentModel:
    metadata=Metadata?
    (
        brokers*=BrokerConfig
        auth*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
        conditions*=ConditionDef
        actions*=ActionDef
    )#
;

Metadata:
    'metadata' name=ID
    (
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'broker' 'mqtt' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'broker' 'amqp' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

HTTPBroker:
    'broker' 'http' name=ID
    (
        ('url:' url=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' headers*=HeaderPair)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

HeaderPair:
    key=STRING ':' value=STRING
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'auth' 'basic' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'auth' 'token' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'auth' 'cert' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

EntityDef:
    'entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('properties:' properties*=PropertyDef)?
        ('behaviors:' behaviors*=BehaviorDef)?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'hybrid' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

PropertyDef:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'array'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL | ArrayValue | JsonValue
;

ArrayValue:
    '[' items*=PropertyValue[','] ']'
;

JsonValue:
    '{' pairs*=JsonPair[','] '}'
;

JsonPair:
    key=STRING ':' value=PropertyValue
;

BehaviorDef:
    name=ID ':' behavior_type=BehaviorType
;

BehaviorType:
    'read_only' | 'write_only' | 'read_write' | 'event_trigger'
;

AutomationDef:
    'automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' conditions*=[ConditionDef])?
        ('actions:' actions*=[ActionDef])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;

TriggerDef:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'time' '(' schedule=STRING ')'
;

EventTrigger:
    'event' '(' entity=[EntityDef] ',' event_type=STRING ')'
;

StateTrigger:
    'state' '(' entity=[EntityDef] ',' property=ID ',' operator=ComparisonOp ',' value=PropertyValue ')'
;

ConditionDef:
    'condition' name=ID
    (
        ('expression:' expression=ConditionExpr)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ConditionExpr:
    SimpleCondition | ComplexCondition
;

SimpleCondition:
    entity=[EntityDef] '.' property=ID operator=ComparisonOp value=PropertyValue
;

ComplexCondition:
    left=ConditionExpr logical_op=LogicalOp right=ConditionExpr
;

ComparisonOp:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOp:
    'and' | 'or' | 'not'
;

ActionDef:
    'action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[EntityDef])
        ('parameters:' parameters*=ActionParam)?
        ('delay:' delay=INT)?
        ('retry:' retry=INT)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'notify' | 'log' | 'script'
;

ActionParam:
    name=ID ':' value=PropertyValue
;