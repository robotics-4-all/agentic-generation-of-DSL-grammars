SmartEnvironmentModel:
    (imports*=Import)?
    (metadata=Metadata)?
    (
        (brokers*=BrokerConfig)
        (auth_mechanisms*=AuthMechanism)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | CoapBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[AuthMechanism])?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

CoapBroker:
    'Broker<CoAP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('secure:' secure=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

AuthMechanism:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_file:' cert_file=STRING)
        ('key_file:' key_file=STRING)
        ('ca_file:' ca_file=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'gateway' | 'device' | 'service'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

Property:
    'Property' name=ID
    (
        ('data_type:' data_type=DataType)
        ('value:' value=PropertyValue)?
        ('readable:' readable=BOOL)?
        ('writable:' writable=BOOL)?
        ('unit:' unit=STRING)?
    )#
    'end'
;

DataType:
    'boolean' | 'integer' | 'float' | 'string' | 'array' | 'object'
;

PropertyValue:
    BOOL | INT | FLOAT | STRING | List | Dict
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('action:' action=[Action])
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

BehaviorTrigger:
    'on_change' | 'on_threshold' | 'on_event' | 'periodic' | 'manual'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('repeat:' repeat=BOOL)?
    )#
    'end'
;

EventTrigger:
    'EventTrigger'
    (
        ('event_type:' event_type=STRING)
        ('source:' source=[Entity])?
    )#
    'end'
;

StateTrigger:
    'StateTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=PropertyRef)
        ('condition:' condition=ComparisonCondition)
    )#
    'end'
;

PropertyRef:
    entity=[Entity] '.' property=ID
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

ConditionExpression:
    LogicalCondition | ComparisonCondition | PropertyCondition
;

LogicalCondition:
    left=ConditionExpression operator=LogicalOperator right=ConditionExpression
;

ComparisonCondition:
    left=ConditionOperand operator=ComparisonOperator right=ConditionOperand
;

PropertyCondition:
    property=PropertyRef operator=PropertyOperator value=PropertyValue
;

ConditionOperand:
    PropertyRef | PropertyValue
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>='
;

PropertyOperator:
    'equals' | 'not_equals' | 'greater_than' | 'less_than' | 'contains' | 'in_range'
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry_count:' retry_count=INT)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'notify' | 'execute_script' | 'call_service'
;

ActionParameter:
    'Parameter' name=ID
    (
        ('value:' value=PropertyValue)
        ('type:' param_type=DataType)?
    )#
    'end'
;

List:
    '[' items*=ListItem[','] ']'
;

ListItem:
    PropertyValue
;

Dict:
    '{' items*=DictItem[','] '}'
;

DictItem:
    key=STRING ':' value=PropertyValue
;