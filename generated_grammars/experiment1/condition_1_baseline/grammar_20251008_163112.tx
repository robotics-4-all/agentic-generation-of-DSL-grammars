SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=Broker)*
    (authentication=Authentication)?
    (entities*=Entity)*
    (automations*=Automation)*
    conditions*=Condition
    actions*=Action
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('topic:' topic=STRING)?
        ('clientId:' clientId=STRING)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('routingKey:' routingKey=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)
        ('ssl:' ssl=BOOL)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Authentication:
    'Authentication'
    (
        ('method:' method=AuthMethod)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('token:' token=STRING)?
        ('certificate:' certificate=STRING)?
        ('key:' key=STRING)?
    )#
    'end'
;

AuthMethod:
    'basic' | 'bearer' | 'oauth' | 'certificate' | 'apikey'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[Broker])
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('capabilities:' '-' capabilities*=STRING['-'])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance' | 'unknown'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'integer' | 'float' | 'boolean' | 'datetime' | 'json' | 'array'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

Behavior:
    name=ID '(' parameters*=Parameter[','] ')' ':' returnType=DataType
;

Parameter:
    name=ID ':' paramType=DataType
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('executionMode:' executionMode=ExecutionMode)?
    )#
    'end'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional' | 'loop'
;

Trigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'TimeTrigger' '(' schedule=STRING ')'
;

EventTrigger:
    'EventTrigger' '(' event=STRING ')'
;

StateTrigger:
    'StateTrigger' '(' entity=[Entity] ',' property=ID ',' value=PropertyValue ')'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('operator:' operator=LogicalOperator)?
        ('operands:' '-' operands*=Operand['-'])?
    )#
    'end'
;

ConditionExpression:
    SimpleCondition | ComplexCondition
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ComplexCondition:
    '(' left=ConditionExpression operator=LogicalOperator right=ConditionExpression ')'
;

LogicalOperator:
    'and' | 'or' | 'not' | 'xor'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

Operand:
    entity=[Entity] '.' property=ID | value=PropertyValue
;

Action:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('target:' target=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('timeout:' timeout=INT)?
        ('retries:' retries=INT)?
    )#
    'end'
;

ActionType:
    'control' | 'notify' | 'log' | 'trigger' | 'schedule' | 'http'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;