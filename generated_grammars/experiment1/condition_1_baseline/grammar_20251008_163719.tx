SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=MessageBroker)*
    (authentications*=Authentication)*
    (entities*=Entity)*
    (automations*=Automation)*
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('source:' source=[MessageBroker])?
        ('topic:' topic=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'system' | 'virtual'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'timestamp' | 'json'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

Behavior:
    name=ID ':' action=BehaviorAction
;

BehaviorAction:
    'notify' | 'log' | 'store' | 'forward' | 'transform'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('conditions:' conditions=ConditionGroup)
        ('actions:' '-' actions*=Action['-'])
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('interval:' interval=INT)?
        ('maxRuns:' maxRuns=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ExecutionMode:
    'immediate' | 'scheduled' | 'periodic' | 'conditional'
;

ConditionGroup:
    conditions*=Condition (operator=LogicalOperator conditions*=Condition)*
;

Condition:
    SimpleCondition | '(' group=ConditionGroup ')'
;

SimpleCondition:
    EntityCondition | TimeCondition | ValueCondition
;

EntityCondition:
    entity=[Entity] '.' property=ID comparison=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' comparison=ComparisonOperator timeValue=TimeValue
;

ValueCondition:
    leftOperand=Operand comparison=ComparisonOperator rightOperand=Operand
;

Operand:
    PropertyValue | EntityReference
;

EntityReference:
    entity=[Entity] '.' property=ID
;

TimeValue:
    hour=INT ':' minute=INT (':' second=INT)?
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    EntityAction | NotificationAction | SystemAction
;

EntityAction:
    'EntityAction'
    (
        ('target:' target=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' parameters=ActionParameters)?
    )#
    'end'
;

NotificationAction:
    'NotificationAction'
    (
        ('message:' message=STRING)
        ('level:' level=NotificationLevel)
        ('recipients:' recipients=STRING)?
    )#
    'end'
;

SystemAction:
    'SystemAction'
    (
        ('command:' command=STRING)
        ('parameters:' parameters=ActionParameters)?
    )#
    'end'
;

NotificationLevel:
    'info' | 'warning' | 'error' | 'critical'
;

ActionParameters:
    '{' items*=ParameterItem[','] '}'
;

ParameterItem:
    name=ID ':' value=PropertyValue
;