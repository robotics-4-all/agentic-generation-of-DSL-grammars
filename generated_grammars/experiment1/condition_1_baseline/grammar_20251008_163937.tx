SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])?
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'array'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL | JsonObject | Array
;

JsonObject:
    '{' pairs*=JsonPair[','] '}'
;

JsonPair:
    key=STRING ':' value=PropertyValue
;

Array:
    '[' items*=PropertyValue[','] ']'
;

Behavior:
    'behavior' name=ID
    (
        ('trigger:' trigger=STRING)
        ('action:' action=STRING)
        ('parameters:' parameters=JsonObject)?
    )#
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateChangeTrigger
;

TimeTrigger:
    'time' '(' schedule=STRING ')'
;

EventTrigger:
    'event' '(' eventName=STRING ')'
;

StateChangeTrigger:
    'state_change' '(' entity=[Entity] ',' property=ID ')'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionTerm:
    '(' expression=ConditionExpression ')' |
    SimpleCondition
;

SimpleCondition:
    EntityPropertyCondition | TimeCondition | ValueCondition
;

EntityPropertyCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

ValueCondition:
    leftValue=PropertyValue operator=ComparisonOperator rightValue=PropertyValue
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

Action:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' parameters=JsonObject)?
        ('description:' description=STRING)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'notify' | 'log' | 'delay' | 'script'
;