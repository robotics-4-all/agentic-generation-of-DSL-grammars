SmartEnvironmentModel:
    imports*=Import
    metadata=Metadata
    brokers*=BrokerConfig
    authentications*=AuthenticationConfig
    entities*=EntityDefinition
    automations*=AutomationDeclaration
    conditions*=ConditionSpecification
    actions*=ActionDefinition
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

AuthenticationConfig:
    UsernamePasswordAuth | TokenAuth | CertificateAuth
;

UsernamePasswordAuth:
    'Auth<UserPass>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

PropertyDefinition:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)? ('(' constraints=PropertyConstraints ')')?
;

DataType:
    'string' | 'integer' | 'float' | 'boolean' | 'timestamp' | 'json' | 'array'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

PropertyConstraints:
    min_value=NUMBER (',' max_value=NUMBER)? (',' unit=STRING)?
;

BehaviorDefinition:
    name=ID ':' behavior_type=BehaviorType ('(' parameters=BehaviorParameters ')')?
;

BehaviorType:
    'periodic' | 'event_driven' | 'threshold' | 'state_change'
;

BehaviorParameters:
    interval=INT | threshold=NUMBER | event=STRING
;

AutomationDeclaration:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDefinition)
        ('conditions:' '-' conditions*=[ConditionSpecification]['-'])?
        ('actions:' '-' actions*=[ActionDefinition]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

TriggerDefinition:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EventTrigger:
    'event' '(' entity=[EntityDefinition] ',' event_type=STRING ')'
;

StateTrigger:
    'state' '(' entity=[EntityDefinition] ',' property=STRING ',' value=PropertyValue ')'
;

TimeSchedule:
    'cron' '(' expression=STRING ')' | 'interval' '(' seconds=INT ')'
;

ExecutionControl:
    'sequential' | 'parallel' | 'conditional' | 'loop'
;

ConditionSpecification:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
        ('retry:' retry=INT)?
    )#
    'end'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ComparisonExpression:
    left=OperandExpression operator=ComparisonOperator right=OperandExpression
    | '(' expression=LogicalExpression ')'
    | operand=OperandExpression
;

OperandExpression:
    PropertyReference | LiteralValue | FunctionCall
;

PropertyReference:
    entity=[EntityDefinition] '.' property=STRING
;

LiteralValue:
    STRING | INT | FLOAT | BOOL
;

FunctionCall:
    function_name=ID '(' arguments*=OperandExpression[','] ')'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

ActionDefinition:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=ActionTarget)
        ('parameters:' parameters=ActionParameters)?
        ('delay:' delay=INT)?
        ('retry:' retry=INT)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'send_notification' | 'call_service' | 'log_event'
;

ActionTarget:
    EntityTarget | ServiceTarget | NotificationTarget
;

EntityTarget:
    'entity' '(' entity=[EntityDefinition] ',' property=STRING ')'
;

ServiceTarget:
    'service' '(' url=STRING ',' method=HTTPMethod ')'
;

NotificationTarget:
    'notification' '(' channel=STRING ',' recipient=STRING ')'
;

ActionParameters:
    '{' parameters*=ParameterDefinition[','] '}'
;

ParameterDefinition:
    name=STRING ':' value=ParameterValue
;

ParameterValue:
    STRING | INT | FLOAT | BOOL | PropertyReference
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;