SmartEnvironmentModel:
    imports*=Import
    metadata=Metadata
    brokers*=BrokerConfig
    auth_mechanisms*=AuthMechanism
    entities*=Entity
    automations*=Automation
;

Import:
    'import' module=STRING
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
        ('topic_prefix:' topic_prefix=STRING)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

AuthMechanism:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=Value)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

Value:
    STRING | INT | FLOAT | BOOL
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' parameters=ParameterList ')')?
;

BehaviorType:
    'read' | 'write' | 'notify' | 'command' | 'schedule'
;

ParameterList:
    parameters*=Parameter[',']
;

Parameter:
    name=ID '=' value=Value
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Condition)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' execution_mode=ExecutionMode)?
        ('description:' description=STRING)?
    )#
    'end'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

Condition:
    SimpleCondition | ComplexCondition
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=Value
;

ComplexCondition:
    left=Condition logical_operator=LogicalOperator right=Condition
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    EntityAction | NotificationAction | DelayAction
;

EntityAction:
    'EntityAction'
    (
        ('target:' target=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' parameters=ParameterList)?
    )#
    'end'
;

NotificationAction:
    'NotificationAction'
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

DelayAction:
    'DelayAction'
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;