SmartEnvironmentModel:
    imports*=ImportStatement
    (metadata=SystemMetadata)?
    (
        (brokers*=MessageBroker)
        (authentications*=Authentication)
        (entities*=EntityDefinition)
        (automations*=AutomationRule)
        (conditions*=ConditionGroup)
        (actions*=ActionDefinition)
    )#
;

ImportStatement:
    'import' path=STRING ('as' alias=ID)?
;

SystemMetadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('basePath:' basePath=STRING)?
        ('webPath:' webPath=STRING)?
        ('webPort:' webPort=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('topicExchange:' topicExchange=STRING)?
        ('rpcExchange:' rpcExchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    PlainAuth | APIKeyAuth | CertAuth
;

PlainAuth:
    'Auth<Plain>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
        ('ca:' ca=STRING)?
    )#
    'end'
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

PropertyDefinition:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'integer' | 'float' | 'boolean' | 'object' | 'array'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

BehaviorDefinition:
    name=ID ':' behavior=BehaviorType
;

BehaviorType:
    'read' | 'write' | 'notify' | 'command'
;

AutomationRule:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerCondition)
        ('conditions:' '-' conditions*=[ConditionGroup]['-'])?
        ('actions:' '-' actions*=[ActionDefinition]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;

TriggerCondition:
    EntityTrigger | TimeTrigger | EventTrigger
;

EntityTrigger:
    'entity:' entity=[EntityDefinition] 'property:' property=ID 'operator:' operator=ComparisonOperator 'value:' value=PropertyValue
;

TimeTrigger:
    'time:' timeExpression=TimeExpression
;

EventTrigger:
    'event:' eventName=STRING
;

TimeExpression:
    CronExpression | IntervalExpression
;

CronExpression:
    'cron:' expression=STRING
;

IntervalExpression:
    'interval:' seconds=INT
;

ConditionGroup:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ComparisonExpression:
    '(' expression=LogicalExpression ')' | SimpleCondition
;

SimpleCondition:
    entity=[EntityDefinition] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

ActionDefinition:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('target:' target=[EntityDefinition])
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

ActionType:
    'set' | 'toggle' | 'send' | 'notify' | 'call'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;