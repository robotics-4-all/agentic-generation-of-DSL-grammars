SmartEnvironmentModel:
    (metadata=Metadata)?
    (brokers*=BrokerConfig)?
    (auth*=AuthenticationConfig)?
    (entities*=EntityDefinition)?
    (automations*=AutomationDeclaration)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)
        ('ca:' ca=STRING)?
    )#
    'end'
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('broker:' broker=[BrokerConfig])?
        ('topic:' topic=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

PropertyDefinition:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

BehaviorDefinition:
    name=ID ':' behaviorType=BehaviorType
;

BehaviorType:
    'periodic' | 'event_driven' | 'manual' | 'conditional'
;

AutomationDeclaration:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=TriggerCondition)
        ('conditions:' conditions=ConditionExpression)?
        ('actions:' '-' actions*=ActionDefinition['-'])
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

TriggerCondition:
    EntityTrigger | TimeTrigger | EventTrigger
;

EntityTrigger:
    'entity:' entity=[EntityDefinition] 'property:' property=ID 'operator:' operator=ComparisonOperator 'value:' value=PropertyValue
;

TimeTrigger:
    'time:' timeValue=TimeValue
;

EventTrigger:
    'event:' eventName=STRING
;

TimeValue:
    CronExpression | TimeInterval
;

CronExpression:
    'cron:' expression=STRING
;

TimeInterval:
    'interval:' seconds=INT
;

ConditionExpression:
    condition=Condition (logicalOp=LogicalOperator nextCondition=ConditionExpression)?
;

Condition:
    EntityCondition | TimeCondition | SystemCondition | '(' condition=ConditionExpression ')'
;

EntityCondition:
    entity=[EntityDefinition] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=TimeValue
;

SystemCondition:
    'system' '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'in' | 'not_in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ActionDefinition:
    EntityAction | NotificationAction | ServiceAction | ScriptAction
;

EntityAction:
    'entity:' entity=[EntityDefinition] 'property:' property=ID 'value:' value=PropertyValue
;

NotificationAction:
    'notify:' message=STRING ('to:' recipient=STRING)?
;

ServiceAction:
    'service:' serviceName=STRING ('params:' params=ServiceParams)?
;

ScriptAction:
    'script:' scriptPath=STRING ('args:' args=ScriptArgs)?
;

ServiceParams:
    '{' params*=ServiceParam[','] '}'
;

ServiceParam:
    name=ID ':' value=PropertyValue
;

ScriptArgs:
    '[' args*=PropertyValue[','] ']'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('retry:' retry=INT)?
        ('timeout:' timeout=INT)?
        ('delay:' delay=INT)?
    )#
    'end'
;

ExecutionMode:
    'immediate' | 'queued' | 'scheduled' | 'parallel'
;