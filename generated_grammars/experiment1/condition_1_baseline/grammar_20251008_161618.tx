SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=BrokerConfig)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=QoSLevel)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('basePath:' basePath=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

QoSLevel:
    '0' | '1' | '2'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=TokenType)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

TokenType:
    'Bearer' | 'ApiKey' | 'JWT'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('capabilities:' '-' capabilities*=Capability['-'])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'integer' | 'float' | 'boolean' | 'json' | 'binary'
;

PropertyValue:
    STRING | INT | FLOAT | BOOL
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('action:' action=[Action])?
        ('condition:' condition=[Condition])?
    )#
    'end'
;

BehaviorTrigger:
    'propertyChange' | 'timeInterval' | 'external' | 'manual'
;

Capability:
    name=ID ':' description=STRING
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('mode:' mode=ExecutionMode)?
        ('priority:' priority=INT)?
    )#
    'end'
;

AutomationTrigger:
    EntityTrigger | TimeTrigger | EventTrigger
;

EntityTrigger:
    'entity' entity=[Entity] 'property' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeTrigger:
    'time' schedule=TimeSchedule
;

EventTrigger:
    'event' eventName=STRING
;

TimeSchedule:
    CronSchedule | IntervalSchedule | OnceSchedule
;

CronSchedule:
    'cron' expression=STRING
;

IntervalSchedule:
    'interval' seconds=INT
;

OnceSchedule:
    'once' datetime=STRING
;

ExecutionMode:
    'sequential' | 'parallel' | 'single'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

LogicalExpression:
    left=LogicalTerm (operator=LogicalOperator right=LogicalTerm)*
;

LogicalTerm:
    ComparisonExpression | '(' expression=LogicalExpression ')' | NotExpression
;

NotExpression:
    'not' expression=LogicalTerm
;

ComparisonExpression:
    EntityPropertyRef operator=ComparisonOperator value=ExpressionValue
;

EntityPropertyRef:
    entity=[Entity] '.' property=ID
;

ExpressionValue:
    PropertyValue | EntityPropertyRef
;

LogicalOperator:
    'and' | 'or'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'startsWith' | 'endsWith'
;

Action:
    EntityAction | NotificationAction | ScriptAction | DelayAction
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('target:' target=[Entity])
        ('operation:' operation=EntityOperation)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=NotificationChannel)
        ('recipients:' '-' recipients*=STRING['-'])?
    )#
    'end'
;

ScriptAction:
    'Action<Script>' name=ID
    (
        ('language:' language=ScriptLanguage)
        ('code:' code=STRING)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

DelayAction:
    'Action<Delay>' name=ID
    (
        ('duration:' duration=INT)
    )#
    'end'
;

EntityOperation:
    'setValue' | 'toggle' | 'enable' | 'disable' | 'reset' | 'calibrate'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'webhook'
;

ScriptLanguage:
    'python' | 'javascript' | 'bash' | 'lua'
;