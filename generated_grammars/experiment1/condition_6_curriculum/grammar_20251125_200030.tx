SmAutoModel:
    (
        metadata=Metadata?
        broker=BrokerConfig?
        authentication=AuthConfig?
        entities*=Entity
        automations*=Automation
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('base_url:' base_url=STRING)
        ('port:' port=INT)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>'
    (
        ('token:' token=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>'
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'hybrid'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'list' | 'dict'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | List | Dict
;

Behavior:
    name=ID ':' action=BehaviorAction
;

BehaviorAction:
    'turn_on' | 'turn_off' | 'set_value' | 'get_value' | 'toggle' | 'custom'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;

Trigger:
    TimeTrigger | StateTrigger | EventTrigger
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=TimeSchedule)
        ('repeat:' repeat=BOOL)?
    )#
;

StateTrigger:
    'StateTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

EventTrigger:
    'EventTrigger'
    (
        ('event_type:' event_type=STRING)
        ('source:' source=STRING)?
    )#
;

TimeSchedule:
    CronSchedule | IntervalSchedule | OnceSchedule
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' seconds=INT ')'
;

OnceSchedule:
    'once' '(' datetime=STRING ')'
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

Condition:
    left=SimpleCondition (logical_op=LogicalOperator right=SimpleCondition)*
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'in' | 'not_in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    EntityAction | NotificationAction | DelayAction | ScriptAction
;

EntityAction:
    'EntityAction'
    (
        ('target:' target=[Entity])
        ('behavior:' behavior=STRING)
        ('parameters:' parameters=Dict)?
    )#
;

NotificationAction:
    'NotificationAction'
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)?
        ('priority:' priority=NotificationPriority)?
    )#
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

DelayAction:
    'DelayAction'
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)?
    )#
;

TimeUnit:
    'seconds' | 'minutes' | 'hours'
;

ScriptAction:
    'ScriptAction'
    (
        ('script:' script=STRING)
        ('language:' language=ScriptLanguage)?
    )#
;

ScriptLanguage:
    'python' | 'javascript' | 'bash'
;

List:
    '[' items*=PropertyValue[','] ']'
;

Dict:
    '{' items*=DictItem[','] '}'
;

DictItem:
    key=STRING ':' value=PropertyValue
;