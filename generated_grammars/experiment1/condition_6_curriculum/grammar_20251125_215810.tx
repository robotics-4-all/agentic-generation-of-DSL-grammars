SmartHomeModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

Metadata:
    'Metadata' name=ID
    (
        ('version:' version=STRING)?
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'switch' | 'light' | 'thermostat' | 'camera' | 'speaker' | 'lock' | 'other'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

AutomationMode:
    'single' | 'restart' | 'queued' | 'parallel'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('timeout:' timeout=INT)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

PropertyDef:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

ActionParam:
    name=ID ':' value=PropertyValue
;

ActionParameters:
    '{' params*=ActionParam[','] '}'
;

EntityAction:
    'SetProperty' '(' entity=[EntityDef] ',' property=ID ',' value=PropertyValue ')'
;

ServiceAction:
    'CallService' '(' service=STRING (',' parameters=ActionParameters)? ')'
;

NotificationAction:
    'Notify' '(' message=STRING (',' target=STRING)? ')'
;

DelayAction:
    'Delay' '(' duration=INT unit=TimeUnit ')'
;

ActionDef:
    EntityAction | ServiceAction | NotificationAction | DelayAction
;

BehaviorDef:
    name=ID ':' action=ActionDef
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('location:' location=STRING)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

CronSchedule:
    'cron:' expression=STRING
;

IntervalSchedule:
    'interval:' duration=INT unit=TimeUnit
;

OnceSchedule:
    'once:' datetime=STRING
;

TimeSchedule:
    CronSchedule | IntervalSchedule | OnceSchedule
;

TimeTrigger:
    'Time' '(' schedule=TimeSchedule ')'
;

StateTrigger:
    'State' '(' entity=[EntityDef] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

EventTrigger:
    'Event' '(' eventType=STRING (',' data=PropertyValue)? ')'
;

TriggerDef:
    TimeTrigger | StateTrigger | EventTrigger
;

SimpleCondition:
    entity=[EntityDef] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ConditionDef:
    left=SimpleCondition (logicalOp=LogicalOperator right=SimpleCondition)*
;

AutomationDef:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' '-' conditions*=ConditionDef['-'])?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('mode:' mode=AutomationMode)?
    )#
    'end'
;