SmAutoModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication=Authentication?
        entities*=Entity
        automations*=Automation
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('system:' system=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

Authentication:
    'Authentication'
    (
        ('method:' method=AuthMethod)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('token:' token=STRING)?
        ('certificate:' certificate=STRING)?
    )#
    'end'
;

AuthMethod:
    'basic' | 'token' | 'certificate' | 'none'
;

Entity:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('address:' address=STRING)
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

Property:
    name=ID ':' datatype=DataType ('=' default=PropertyValue)?
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

Behavior:
    name=ID ':' action=BehaviorAction
;

BehaviorAction:
    'read' | 'write' | 'execute' | 'notify' | 'subscribe'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('conditions:' conditions=Condition)
        ('actions:' '-' actions*=Action['-'])
        ('description:' description=STRING)?
    )#
    'end'
;

Condition:
    left=SimpleCondition (operator=LogicalOperator right=SimpleCondition)*
;

SimpleCondition:
    '(' group=Condition ')' |
    TimeCondition | PropertyCondition | StateCondition
;

TimeCondition:
    'time' operator=ComparisonOperator value=TimeValue
;

PropertyCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

StateCondition:
    entity=[Entity] 'state' operator=ComparisonOperator value=STRING
;

TimeValue:
    time=Time | duration=Duration | schedule=Schedule
;

Time:
    hour=INT ':' minute=INT (':' second=INT)?
;

Duration:
    value=INT unit=TimeUnit
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

Schedule:
    'daily' | 'weekly' | 'monthly' | 'yearly'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    EntityAction | NotificationAction | DelayAction | ScriptAction
;

EntityAction:
    'set' entity=[Entity] '.' property=ID '=' value=PropertyValue
;

NotificationAction:
    'notify' message=STRING ('to' target=STRING)?
;

DelayAction:
    'delay' duration=Duration
;

ScriptAction:
    'script' code=STRING
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;