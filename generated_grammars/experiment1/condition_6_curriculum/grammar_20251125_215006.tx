SmartHomeModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

Metadata:
    'metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'broker' 'mqtt' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'broker' 'amqp' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

HTTPBroker:
    'broker' 'http' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'auth' 'basic' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'auth' 'token' name=ID
    (
        ('token:' token=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

CertAuth:
    'auth' 'cert' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

EntityDef:
    SensorEntity | ActuatorEntity | HybridEntity
;

SensorEntity:
    'entity' 'sensor' name=ID
    (
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

ActuatorEntity:
    'entity' 'actuator' name=ID
    (
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

HybridEntity:
    'entity' 'hybrid' name=ID
    (
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

PropertyDef:
    name=ID ':' type=PropertyType ('=' default=PropertyValue)?
;

PropertyType:
    'str' | 'int' | 'float' | 'bool' | 'list' | 'dict'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | ListValue | DictValue
;

ListValue:
    '[' items*=PropertyValue[','] ']'
;

DictValue:
    '{' items*=DictItem[','] '}'
;

DictItem:
    key=STRING ':' value=PropertyValue
;

BehaviorDef:
    name=ID '(' params*=BehaviorParam[','] ')' ':' implementation=STRING
;

BehaviorParam:
    name=ID ':' type=PropertyType
;

AutomationDef:
    'automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' conditions=ConditionExpr)?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;

TriggerDef:
    EntityTrigger | TimeTrigger | EventTrigger
;

EntityTrigger:
    'entity' entity=[EntityDef] 'property' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeTrigger:
    'time' time_expr=TimeExpression
;

EventTrigger:
    'event' event_type=STRING ('data:' data=DictValue)?
;

TimeExpression:
    CronExpression | IntervalExpression | AtExpression
;

CronExpression:
    'cron' expression=STRING
;

IntervalExpression:
    'every' interval=INT unit=TimeUnit
;

AtExpression:
    'at' time=STRING
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days' | 'weeks'
;

ConditionExpr:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionTerm:
    '(' expr=ConditionExpr ')' | SimpleCondition
;

SimpleCondition:
    EntityCondition | TimeCondition | ValueCondition
;

EntityCondition:
    entity=[EntityDef] 'property' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator time=STRING
;

ValueCondition:
    left=PropertyValue operator=ComparisonOperator right=PropertyValue
;

ComparisonOperator:
    '==' | '!=' | '<' | '<=' | '>' | '>=' | 'in' | 'not_in' | 'contains'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ActionDef:
    EntityAction | NotificationAction | ServiceAction | DelayAction
;

EntityAction:
    'set' entity=[EntityDef] 'property' property=ID 'to' value=PropertyValue
;

NotificationAction:
    'notify' message=STRING ('channel:' channel=STRING)?
;

ServiceAction:
    'call' service=STRING ('params:' params=DictValue)?
;

DelayAction:
    'delay' duration=INT unit=TimeUnit
;

FQN:
    ID ('.' ID)*
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;