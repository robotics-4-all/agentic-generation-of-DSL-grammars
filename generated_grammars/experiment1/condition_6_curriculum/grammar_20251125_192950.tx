SmAutoModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth*=AuthenticationConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

TokenType:
    'Bearer' | 'API' | 'Custom'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'array' | 'object'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

BehaviorType:
    'read' | 'write' | 'notify' | 'command'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=TokenType)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('passphrase:' passphrase=STRING)?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('queue:' queue=STRING)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

PropertyDef:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

BehaviorDef:
    name=ID ':' behaviorType=BehaviorType
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('timezone:' timezone=STRING)?
    )#
;

EventTrigger:
    'EventTrigger'
    (
        ('entity:' entity=[EntityDef])
        ('event:' event=STRING)
        ('value:' value=PropertyValue)?
    )#
;

StateTrigger:
    'StateTrigger'
    (
        ('entity:' entity=[EntityDef])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

TriggerDef:
    TimeTrigger | EventTrigger | StateTrigger
;

SimpleCondition:
    entity=[EntityDef] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

CompoundCondition:
    left=SimpleCondition (logicalOp=LogicalOperator right=SimpleCondition)*
;

ConditionDef:
    CompoundCondition | SimpleCondition
;

EntityAction:
    'EntityAction'
    (
        ('entity:' entity=[EntityDef])
        ('property:' property=ID)
        ('value:' value=PropertyValue)
        ('method:' method=STRING)?
    )#
;

NotificationAction:
    'NotificationAction'
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)?
        ('priority:' priority=NotificationPriority)?
    )#
;

DelayAction:
    'DelayAction'
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
;

ActionDef:
    EntityAction | NotificationAction | DelayAction
;

AutomationDef:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' '-' conditions*=ConditionDef['-'])?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;