SmAutoModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

PropertyType:
    'str' | 'int' | 'float' | 'bool' | 'json'
;

JsonValue:
    '{' items*=JsonItem[','] '}'
;

JsonItem:
    name=STRING ':' value=PropertyValue
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | JsonValue
;

PropertyDef:
    name=ID ':' ptype=PropertyType ('=' default=PropertyValue)?
;

BehaviorDef:
    name=ID ':' action=STRING
;

LogicalOp:
    'and' | 'or' | 'not'
;

ComparisonOp:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

SimpleCondition:
    entity=[EntityDef] '.' property=ID op=ComparisonOp value=PropertyValue
;

ConditionExpr:
    '(' condition=ConditionGroup ')' | SimpleCondition
;

ConditionGroup:
    conditions+=ConditionExpr (operator=LogicalOp conditions+=ConditionExpr)*
;

TimeTrigger:
    'Time' '(' schedule=STRING ')'
;

EventTrigger:
    'Event' '(' entity=[EntityDef] ',' event=STRING ')'
;

StateTrigger:
    'State' '(' entity=[EntityDef] ',' property=ID ',' value=PropertyValue ')'
;

TriggerDef:
    TimeTrigger | EventTrigger | StateTrigger
;

SetAction:
    'Set' '(' entity=[EntityDef] ',' property=ID ',' value=PropertyValue ')'
;

CallAction:
    'Call' '(' entity=[EntityDef] ',' behavior=ID (',' params=PropertyValue)? ')'
;

NotifyAction:
    'Notify' '(' message=STRING (',' recipient=STRING)? ')'
;

ActionDef:
    SetAction | CallAction | NotifyAction
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Cert>' name=ID
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
    )#
    'end'
;

AutomationDef:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' conditions=ConditionGroup)?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;