SmartHomeModel:
    (
        metadata=Metadata?
        brokers*=Broker
        authentication=Authentication?
        entities*=Entity
        automations*=Automation
    )#
;

EntityType:
    'sensor' | 'actuator' | 'switch' | 'light' | 'thermostat' | 'camera' | 'lock' | 'other'
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'json' | 'array'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | JsonObject | JsonArray
;

JsonObject:
    '{' items*=JsonItem[','] '}'
;

JsonItem:
    key=STRING ':' value=PropertyValue
;

JsonArray:
    '[' items*=PropertyValue[','] ']'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

BehaviorType:
    'read' | 'write' | 'toggle' | 'increment' | 'decrement' | 'custom'
;

BehaviorParameter:
    name=ID '=' value=PropertyValue
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' parameters*=BehaviorParameter[','] ')')?
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'not_contains'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ConditionExpression:
    SimpleCondition | '(' left=ConditionExpression logical_operator=LogicalOperator right=ConditionExpression ')'
;

Condition:
    ConditionExpression
;

TriggerMethod:
    'button' | 'voice' | 'app' | 'api' | 'webhook'
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('timezone:' timezone=STRING)?
    )#
;

StateTrigger:
    'StateTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
        ('duration:' duration=INT)?
    )#
;

EventTrigger:
    'EventTrigger'
    (
        ('event:' event=STRING)
        ('source:' source=STRING)?
        ('data:' data=JsonObject)?
    )#
;

ManualTrigger:
    'ManualTrigger'
    (
        ('name:' trigger_name=STRING)
        ('method:' method=TriggerMethod)
    )#
;

Trigger:
    TimeTrigger | StateTrigger | EventTrigger | ManualTrigger
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'slack' | 'discord' | 'webhook'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ScriptLanguage:
    'python' | 'javascript' | 'bash' | 'lua'
;

EntityAction:
    'EntityAction'
    (
        ('entity:' entity=[Entity])
        ('behavior:' behavior=STRING)
        ('parameters:' parameters=JsonObject)?
    )#
;

NotificationAction:
    'NotificationAction'
    (
        ('message:' message=STRING)
        ('channel:' channel=NotificationChannel)
        ('priority:' priority=NotificationPriority)?
    )#
;

DelayAction:
    'DelayAction'
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
;

ScriptAction:
    'ScriptAction'
    (
        ('script:' script=STRING)
        ('language:' language=ScriptLanguage)?
        ('parameters:' parameters=JsonObject)?
    )#
;

Action:
    EntityAction | NotificationAction | DelayAction | ScriptAction
;

BasicAuth:
    'BasicAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'CertAuth'
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[Broker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('enabled:' enabled=BOOL)?
        ('description:' description=STRING)?
    )#
    'end'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;