SmAutoModel:
    (
        imports*=ImportStm
        metadata=Metadata?
        brokers*=BrokerConfig
        auth*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

ImportStm:
    'import' module=STRING
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('topics:' '-' topics*=STRING['-'])?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('channels:' '-' channels*=STRING['-'])?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

EntityDef:
    SensorEntity | ActuatorEntity | HybridEntity
;

SensorEntity:
    'Entity<Sensor>' name=ID
    (
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)
        ('data_type:' data_type=DataType)
        ('unit:' unit=STRING)?
        ('min_value:' min_value=NUMBER)?
        ('max_value:' max_value=NUMBER)?
        ('update_interval:' update_interval=INT)?
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
    )#
    'end'
;

ActuatorEntity:
    'Entity<Actuator>' name=ID
    (
        ('broker:' broker=[BrokerConfig])
        ('command_topic:' command_topic=STRING)
        ('state_topic:' state_topic=STRING)?
        ('data_type:' data_type=DataType)
        ('states:' '-' states*=STRING['-'])?
        ('commands:' '-' commands*=STRING['-'])?
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
    )#
    'end'
;

HybridEntity:
    'Entity<Hybrid>' name=ID
    (
        ('broker:' broker=[BrokerConfig])
        ('sensor_topic:' sensor_topic=STRING)
        ('actuator_topic:' actuator_topic=STRING)
        ('data_type:' data_type=DataType)
        ('unit:' unit=STRING)?
        ('states:' '-' states*=STRING['-'])?
        ('commands:' '-' commands*=STRING['-'])?
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
    )#
    'end'
;

PropertyDef:
    name=ID ':' value=PropertyValue
;

PropertyValue:
    ListValue | DictValue | STRING | NUMBER | BOOL
;

ListValue:
    '[' items*=PropertyValue[','] ']'
;

DictValue:
    '{' items*=DictItem[','] '}'
;

DictItem:
    key=STRING ':' value=PropertyValue
;

BehaviorDef:
    name=ID '(' params*=BehaviorParam[','] ')' '{' actions*=ActionDef '}' 
;

BehaviorParam:
    name=ID ':' type=DataType ('=' default=PropertyValue)?
;

DataType:
    'float' | 'int' | 'string' | 'bool' | 'list' | 'dict' | 'json'
;

AutomationDef:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' '-' conditions*=ConditionDef['-'])?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;

TriggerDef:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'Time' '(' schedule=TimeSchedule ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule | OnceSchedule
;

CronSchedule:
    'cron:' expression=STRING
;

IntervalSchedule:
    'interval:' seconds=INT
;

OnceSchedule:
    'once:' datetime=STRING
;

EventTrigger:
    'Event' '(' entity=[EntityDef] ',' event=STRING ')'
;

StateTrigger:
    'State' '(' entity=[EntityDef] '.' attribute=ID operator=NumericOp value=NUMBER ')'
;

ConditionDef:
    expr=ConditionExpr
;

ConditionExpr:
    left=ConditionTerm (operator=LogicalOp right=ConditionTerm)*
;

ConditionTerm:
    '(' expr=ConditionExpr ')' | SimpleCondition
;

SimpleCondition:
    NumericCondition | StringCondition | BoolCondition | TimeCondition
;

NumericCondition:
    entity=[EntityDef] '.' attribute=ID operator=NumericOp value=NUMBER
;

StringCondition:
    entity=[EntityDef] '.' attribute=ID operator=StringOp value=STRING
;

BoolCondition:
    entity=[EntityDef] '.' attribute=ID operator=BoolOp value=BOOL
;

TimeCondition:
    entity=[EntityDef] '.' attribute=ID operator=TimeOp value=STRING
;

LogicalOp:
    'and' | 'or' | 'not'
;

NumericOp:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

StringOp:
    '==' | '!=' | 'contains' | 'startswith' | 'endswith' | 'matches'
;

BoolOp:
    '==' | '!='
;

TimeOp:
    'before' | 'after' | 'between' | 'at'
;

ExecutionMode:
    'sequential' | 'parallel' | 'async'
;

ActionDef:
    SetAction | SendAction | CallAction | DelayAction | LogAction
;

SetAction:
    'Set' '(' entity=[EntityDef] '.' attribute=ID ',' value=ActionValue ')'
;

SendAction:
    'Send' '(' topic=STRING ',' message=ActionValue ')'
;

CallAction:
    'Call' '(' entity=[EntityDef] '.' method=ID '(' params*=ActionParam[','] ')' ')'
;

DelayAction:
    'Delay' '(' seconds=NUMBER ')'
;

LogAction:
    'Log' '(' level=LogLevel ',' message=STRING ')'
;

LogLevel:
    'debug' | 'info' | 'warning' | 'error'
;

ActionValue:
    ListValue | DictValue | EntityRef | STRING | NUMBER | BOOL
;

EntityRef:
    entity=[EntityDef] '.' attribute=ID
;

ActionParam:
    name=ID ':' value=ActionValue
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;