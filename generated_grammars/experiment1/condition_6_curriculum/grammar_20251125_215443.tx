SmartHomeModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

PropertyType:
    'str' | 'float' | 'int' | 'bool' | 'json'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

PropertyDef:
    name=ID ':' ptype=PropertyType ('=' default=PropertyValue)?
;

BehaviorDef:
    name=ID ':' action=ActionRef
;

ActionRef:
    ref=[ActionDef]
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('location:' location=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' seconds=INT ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule
;

TimeTrigger:
    'Time' '(' schedule=TimeSchedule ')'
;

StateTrigger:
    'State' '(' entity=[EntityDef] ',' property=ID ',' operator=ComparisonOp ',' value=PropertyValue ')'
;

EventTrigger:
    'Event' '(' source=STRING ',' event=STRING ')'
;

TriggerDef:
    TimeTrigger | StateTrigger | EventTrigger
;

SimpleCondition:
    entity=[EntityDef] '.' property=ID operator=ComparisonOp value=PropertyValue
;

ComparisonOp:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

LogicalOp:
    'and' | 'or' | 'not'
;

ConditionGroup:
    conditions+=Condition (operator=LogicalOp conditions+=Condition)*
;

Condition:
    '(' group=ConditionGroup ')' | simple=SimpleCondition
;

ParamDef:
    name=ID ':' value=PropertyValue
;

ActionParams:
    '{' params*=ParamDef[','] '}'
;

SetAction:
    'Set' '(' entity=[EntityDef] ',' property=ID ',' value=PropertyValue ')'
;

CallAction:
    'Call' '(' service=STRING ',' params=ActionParams? ')'
;

NotifyAction:
    'Notify' '(' message=STRING ',' target=STRING? ')'
;

ActionDef:
    SetAction | CallAction | NotifyAction
;

ExecutionMode:
    'sequential' | 'parallel' | 'single'
;

AutomationDef:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' conditions=ConditionGroup)?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('mode:' mode=ExecutionMode)?
    )#
    'end'
;