SmAutoModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth*=AuthConfig
        entities*=Entity
        automations*=Automation
    )#
;

EntityType:
    'sensor' | 'actuator' | 'switch' | 'light' | 'thermostat' | 'camera' | 'speaker' | 'lock' | 'other'
;

PropertyType:
    'str' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

BehaviorAction:
    'publish' | 'subscribe' | 'request' | 'response' | 'notify'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'in' | 'not_in' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ExecutionMode:
    'sequential' | 'parallel' | 'single' | 'queued'
;

Property:
    name=ID ':' ptype=PropertyType ('=' default=PropertyValue)?
;

Behavior:
    name=ID ':' action=BehaviorAction
;

ScriptParam:
    name=ID '=' value=PropertyValue
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' value=INT unit=TimeUnit ')'
;

FixedTimeSchedule:
    'at' '(' time=STRING ')'
;

TimeSchedule:
    CronSchedule | IntervalSchedule | FixedTimeSchedule
;

TimeTrigger:
    'time' '(' schedule=TimeSchedule ')'
;

EntityTrigger:
    'entity' '(' entity=[Entity] ('.' property=ID)? operator=ComparisonOperator value=PropertyValue ')'
;

EventTrigger:
    'event' '(' event_type=STRING ('from' source=STRING)? ')'
;

ManualTrigger:
    'manual'
;

TriggerDef:
    TimeTrigger | EntityTrigger | EventTrigger | ManualTrigger
;

EntityCondition:
    entity=[Entity] ('.' property=ID)? operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

StateCondition:
    'state' '(' entity=[Entity] ')' operator=ComparisonOperator value=STRING
;

GroupCondition:
    '(' condition_group=ConditionGroup ')'
;

Condition:
    EntityCondition | TimeCondition | StateCondition | GroupCondition
;

ConditionGroup:
    conditions+=Condition (logical_op=LogicalOperator conditions+=Condition)*
;

EntityAction:
    'set' entity=[Entity] ('.' property=ID)? 'to' value=PropertyValue
;

NotificationAction:
    'notify' '(' message=STRING (',' channels*=STRING[','])? ')'
;

DelayAction:
    'delay' '(' duration=INT unit=TimeUnit ')'
;

ScriptAction:
    'script' '(' script_path=STRING (',' params*=ScriptParam[','])? ')'
;

Action:
    EntityAction | NotificationAction | DelayAction | ScriptAction
;

ExecutionControl:
    'mode:' mode=ExecutionMode (',' 'max_runs:' max_runs=INT)? (',' 'timeout:' timeout=INT)?
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=TriggerDef)
        ('conditions:' conditions=ConditionGroup)?
        ('actions:' '-' actions*=Action['-'])
        ('execution:' execution=ExecutionControl)?
        ('description:' description=STRING)?
    )#
    'end'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;