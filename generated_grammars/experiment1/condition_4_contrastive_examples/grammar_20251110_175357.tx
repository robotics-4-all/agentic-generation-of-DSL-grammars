SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth*=AuthenticationConfig
        entities*=EntityDefinition
        automations*=AutomationRule
    )#
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'timestamp' | 'json'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

ComparisonOperator:
    '==' | '!=' | '<' | '<=' | '>' | '>=' | 'contains' | 'startsWith' | 'endsWith'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Parameter:
    name=ID '=' value=PropertyValue
;

ParameterList:
    '[' parameters*=Parameter[','] ']'
;

PropertyDef:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

LiteralValue:
    FLOAT | INT | STRING | BOOL
;

PropertyReference:
    entity=[EntityDefinition] '.' property=ID
;

ConditionOperand:
    PropertyReference | LiteralValue
;

ComparisonCondition:
    left=ConditionOperand operator=ComparisonOperator right=ConditionOperand
;

Condition:
    comparison=ComparisonCondition | '(' group=ConditionGroup ')'
;

ConditionGroup:
    conditions+=Condition (operator=LogicalOperator conditions+=Condition)*
;

BehaviorDef:
    name=ID ':' action=ActionDef
;

TimeTrigger:
    'Time' '(' schedule=STRING ')'
;

EventTrigger:
    'Event' '(' entity=[EntityDefinition] ',' event=STRING ')'
;

StateTrigger:
    'State' '(' entity=[EntityDefinition] ',' property=ID ',' condition=ComparisonCondition ')'
;

TriggerCondition:
    TimeTrigger | EventTrigger | StateTrigger
;

SetPropertyAction:
    'SetProperty' '(' entity=[EntityDefinition] ',' property=ID ',' value=PropertyValue ')'
;

SendMessageAction:
    'SendMessage' '(' broker=[BrokerConfig] ',' message=STRING ',' target=STRING? ')'
;

CallServiceAction:
    'CallService' '(' service=STRING ',' parameters=ParameterList? ')'
;

DelayAction:
    'Delay' '(' duration=INT ')'
;

ActionDef:
    SetPropertyAction | SendMessageAction | CallServiceAction | DelayAction
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('caCertPath:' caCertPath=STRING)?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routingKey:' routingKey=STRING)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' type=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('status:' status=EntityStatus)?
        ('location:' location=STRING)?
    )#
    'end'
;

AutomationRule:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerCondition)
        ('conditions:' conditions=ConditionGroup)?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;