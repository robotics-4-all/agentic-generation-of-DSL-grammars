SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=MessageBroker
        authentications*=Authentication
        entities*=Entity
        automations*=Automation
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_file:' cert_file=STRING)
        ('key_file:' key_file=STRING)
        ('ca_file:' ca_file=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('topic_prefix:' topic_prefix=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('database:' database=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'device' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'json' | 'array'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

BehaviorTrigger:
    'on_message' | 'on_timer' | 'on_condition' | 'on_event'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

TimeUnit:
    'seconds' | 'minutes' | 'hours'
;

ComparisonCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

PrimitiveCondition:
    ComparisonCondition | '(' condition=Condition ')'
;

Condition:
    left=PrimitiveCondition (operator=LogicalOperator right=PrimitiveCondition)*
;

ExecutionControl:
    'ExecutionControl'
    (
        ('max_runs:' max_runs=INT)?
        ('timeout:' timeout=INT)?
        ('retry_count:' retry_count=INT)?
        ('parallel:' parallel=BOOL)?
    )#
    'end'
;

PublishAction:
    'PublishAction'
    (
        ('topic:' topic=STRING)
        ('message:' message=STRING)
        ('broker:' broker=[MessageBroker])?
    )#
    'end'
;

SetPropertyAction:
    'SetPropertyAction'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('value:' value=PropertyValue)
    )#
    'end'
;

CallServiceAction:
    'CallServiceAction'
    (
        ('service:' service=STRING)
        ('parameters:' parameters=STRING)?
    )#
    'end'
;

DelayAction:
    'DelayAction'
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

Action:
    PublishAction | SetPropertyAction | CallServiceAction | DelayAction
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('actions:' '-' actions*=Action['-'])
        ('conditions:' conditions=Condition)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])?
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('repeat:' repeat=BOOL)?
    )#
;

EventTrigger:
    'EventTrigger'
    (
        ('event_type:' event_type=STRING)
        ('source:' source=[Entity])?
    )#
;

PropertyTrigger:
    'PropertyTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

AutomationTrigger:
    TimeTrigger | EventTrigger | PropertyTrigger
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' conditions=Condition)?
        ('actions:' '-' actions*=Action['-'])
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;