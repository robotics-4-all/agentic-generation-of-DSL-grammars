ImportOrReferenceStm:
    ImportStm | ReferenceStm
;

ImportStm:
    'import' grammar_to_import=STRING
;

ReferenceStm:
    'reference' language_name=ID ('as' language_alias=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

APIKeyLocation:
    'HEADER' | 'QUERY' | 'BODY'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
        ('location:' location=APIKeyLocation)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth | APIKeyAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('channel:' channel=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('url:' url=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' headers=Dict)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker | HTTPBroker
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'gateway' | 'device' | 'service' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error' | 'unknown'
;

DataType:
    'str' | 'int' | 'float' | 'bool' | 'array' | 'object' | 'datetime'
;

DictItem:
    key=STRING ':' value=Value
;

Dict:
    '{' items*=DictItem[','] '}'
;

Array:
    '[' items*=Value[','] ']'
;

Value:
    STRING | FLOAT | INT | BOOL | Array | Dict
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=Value)?
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=STRING)
        ('action:' action=STRING)
        ('parameters:' parameters=Dict)?
    )#
    'end'
;

Coordinates:
    'Coordinates' '(' x=FLOAT ',' y=FLOAT (',' z=FLOAT)? ')'
;

Location:
    'Location'
    (
        ('room:' room=STRING)?
        ('floor:' floor=STRING)?
        ('building:' building=STRING)?
        ('coordinates:' coordinates=Coordinates)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' type=EntityType)
        ('broker:' broker=[MessageBroker])
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=Location)?
        ('status:' status=EntityStatus)?
        ('description:' description=STRING)?
    )#
    'end'
;

DayOfWeek:
    'monday' | 'tuesday' | 'wednesday' | 'thursday' | 'friday' | 'saturday' | 'sunday'
;

CronExpression:
    'cron' '(' expression=STRING ')'
;

SimpleTime:
    'time' '(' hour=INT ':' minute=INT (',' days*=DayOfWeek[','])? ')'
;

TimeExpression:
    CronExpression | SimpleTime
;

RepeatPattern:
    'once' | 'daily' | 'weekly' | 'monthly' | 'yearly' | 'interval' '(' seconds=INT ')'
;

TimeTrigger:
    'TimeTrigger'
    (
        ('time:' time=TimeExpression)
        ('repeat:' repeat=RepeatPattern)?
    )#
;

EventTrigger:
    'EventTrigger'
    (
        ('entity:' entity=[Entity])
        ('event:' event=STRING)
        ('filter:' filter=STRING)?
    )#
;

StateTrigger:
    'StateTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=Value)
    )#
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional' | 'immediate'
;

BackoffStrategy:
    'linear' | 'exponential' | 'fixed'
;

RetryPolicy:
    'RetryPolicy'
    (
        ('max_attempts:' max_attempts=INT)
        ('delay:' delay=INT)?
        ('backoff:' backoff=BackoffStrategy)?
    )#
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('timeout:' timeout=INT)?
        ('retry:' retry=RetryPolicy)?
        ('parallel:' parallel=BOOL)?
    )#
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'in' | 'not_in' | 'contains' | 'matches'
;

EntityReference:
    entity=[Entity] '.' property=ID
;

ConditionValue:
    Value | EntityReference
;

ComparisonExpression:
    left=EntityReference operator=ComparisonOperator right=ConditionValue
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ConditionExpression:
    LogicalExpression
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('execution:' execution=ExecutionControl)?
        ('priority:' priority=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;

ActionType:
    'set_property' | 'call_service' | 'send_notification' | 'execute_command' | 'trigger_automation' | 'delay'
;

EntityTarget:
    'entity' '(' entity=[Entity] (',' property=ID)? ')'
;

ServiceTarget:
    'service' '(' service=STRING ')'
;

NotificationTarget:
    'notification' '(' channel=STRING ')'
;

ActionTarget:
    EntityTarget | ServiceTarget | NotificationTarget
;

Action:
    'Action' name=ID
    (
        ('type:' type=ActionType)
        ('target:' target=ActionTarget)
        ('parameters:' parameters=Dict)?
        ('timeout:' timeout=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;

SmartEnvironmentModel:
    (
        imports_or_references*=ImportOrReferenceStm
        metadata=Metadata?
        brokers*=MessageBroker
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;