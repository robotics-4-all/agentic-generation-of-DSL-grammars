SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        brokers*=MessageBroker
        authentications*=Authentication
        entities*=Entity
        conditions*=Condition
        actions*=Action
        automations*=Automation
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepAlive:' keepAlive=INT)?
        ('clientId:' clientId=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('tokenType:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)?
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('state:' state=EntityState)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'array'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | JsonObject | JsonArray
;

JsonObject:
    '{' items*=JsonProperty[','] '}'
;

JsonProperty:
    key=STRING ':' value=PropertyValue
;

JsonArray:
    '[' items*=PropertyValue[','] ']'
;

Behavior:
    name=ID ':' action=[Action]
;

EntityState:
    'online' | 'offline' | 'error' | 'idle' | 'active'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('timeout:' timeout=INT)?
    )#
    'end'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionTerm:
    EntityCondition | TimeCondition | ValueCondition | '(' expression=ConditionExpression ')'
;

EntityCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

ValueCondition:
    left=PropertyValue operator=ComparisonOperator right=PropertyValue
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

Action:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('delay:' delay=INT)?
        ('retries:' retries=INT)?
    )#
    'end'
;

ActionType:
    'set_state' | 'send_command' | 'notify' | 'script' | 'service_call'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' conditions*=[Condition][','])?
        ('actions:' actions*=[Action][','])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('mode:' mode=AutomationMode)?
    )#
    'end'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'TimeTrigger' '(' schedule=STRING ')'
;

EventTrigger:
    'EventTrigger' '(' entity=[Entity] ',' event=STRING ')'
;

StateTrigger:
    'StateTrigger' '(' entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue ')'
;

AutomationMode:
    'single' | 'restart' | 'queued' | 'parallel'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;