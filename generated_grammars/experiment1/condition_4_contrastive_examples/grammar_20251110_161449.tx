SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthenticationConfig
        entities*=EntityDefinition
        automations*=AutomationDeclaration
    )#
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'hub'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

DataType:
    'str' | 'int' | 'float' | 'bool' | 'datetime' | 'json' | 'binary'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'startsWith' | 'endsWith'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('keepAlive:' keepAlive=INT)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routingKey:' routingKey=STRING)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('baseUrl:' baseUrl=STRING)
        ('endpoint:' endpoint=STRING)
        ('method:' method=HTTPMethod)
        ('timeout:' timeout=INT)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
        ('realm:' realm=STRING)?
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('tokenType:' tokenType=STRING)?
        ('header:' header=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertificateAuth
;

PropertyDefinition:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

BehaviorParameter:
    name=ID ':' dataType=DataType
;

ActionDefinition:
    EntityAction | NotificationAction | ScriptAction
;

BehaviorDefinition:
    name=ID '(' parameters*=BehaviorParameter[','] ')' ':' action=ActionDefinition
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

TimeTrigger:
    'Timer' '(' schedule=STRING ')'
;

EventTrigger:
    'Event' '(' entity=[EntityDefinition] ',' event=STRING ')'
;

StateTrigger:
    'State' '(' entity=[EntityDefinition] ',' property=ID ',' operator=ComparisonOperator ',' value=PropertyValue ')'
;

TriggerCondition:
    TimeTrigger | EventTrigger | StateTrigger
;

EntityPropertyRef:
    entity=[EntityDefinition] '.' property=ID
;

ConstantValue:
    STRING | FLOAT | INT | BOOL
;

ConditionOperand:
    EntityPropertyRef | ConstantValue
;

ComparisonCondition:
    left=ConditionOperand operator=ComparisonOperator right=ConditionOperand
;

LogicalCondition:
    left=ComparisonCondition (operator=LogicalOperator right=ComparisonCondition)*
;

ConditionSpecification:
    condition=LogicalCondition
;

ParameterDefinition:
    name=ID ':' value=PropertyValue
;

ParameterList:
    '{' parameters*=ParameterDefinition[','] '}'
;

EntityAction:
    'EntityAction' '(' entity=[EntityDefinition] ',' method=ID ',' parameters=ParameterList? ')'
;

NotificationAction:
    'Notification' '(' message=STRING ',' channel=STRING? ')'
;

ScriptAction:
    'Script' '(' scriptPath=STRING ',' parameters=ParameterList? ')'
;

AutomationDeclaration:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerCondition)
        ('conditions:' conditions=ConditionSpecification)?
        ('actions:' '-' actions*=ActionDefinition['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;