SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=Broker
        authentications*=Authentication
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)?
        ('method:' method=HTTPMethod)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('passphrase:' passphrase=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[Broker])
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=TriggerEvent)
        ('response:' response=BehaviorResponse)
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

TriggerEvent:
    'property_change' | 'time_based' | 'external_event' | 'threshold_exceeded'
;

BehaviorResponse:
    'notify' | 'execute_action' | 'update_property' | 'send_command'
;

TimeBasedTrigger:
    'TimeBased' '(' time=TimeExpression ')'
;

EventBasedTrigger:
    'EventBased' '(' event=STRING ')'
;

PropertyChangeTrigger:
    'PropertyChange' '(' entity=[Entity] ',' property=ID ')'
;

TimeExpression:
    CronExpression | IntervalExpression
;

CronExpression:
    'cron' '(' expression=STRING ')'
;

IntervalExpression:
    'interval' '(' seconds=INT ')'
;

ScheduleType:
    'once' | 'recurring' | 'conditional'
;

ComparisonExpression:
    left=Operand operator=ComparisonOperator right=Operand
;

PropertyExpression:
    entity=[Entity] '.' property=ID
;

Operand:
    PropertyExpression | LiteralValue
;

LiteralValue:
    STRING | FLOAT | INT | BOOL
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

DeviceAction:
    'Action<Device>' name=ID
    (
        ('target:' target=[Entity])
        ('command:' command=STRING)
        ('parameters:' parameters=ActionParameters)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('recipients:' recipients=STRING)
        ('priority:' priority=NotificationPriority)?
        ('channel:' channel=NotificationChannel)?
    )#
    'end'
;

PropertyAction:
    'Action<Property>' name=ID
    (
        ('target:' target=[Entity])
        ('property:' property=ID)
        ('value:' value=PropertyValue)
        ('persistent:' persistent=BOOL)?
    )#
    'end'
;

ServiceAction:
    'Action<Service>' name=ID
    (
        ('service:' service=STRING)
        ('method:' method=STRING)
        ('parameters:' parameters=ActionParameters)?
        ('async:' async=BOOL)?
    )#
    'end'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'webhook'
;

ActionParameters:
    '{' items*=ParameterItem[','] '}'
;

ParameterItem:
    name=ID ':' value=PropertyValue
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('priority:' priority=INT)?
        ('schedule:' schedule=ScheduleType)?
    )#
    'end'
;

AutomationTrigger:
    TimeBasedTrigger | EventBasedTrigger | PropertyChangeTrigger
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionalExpression)
        ('operator:' operator=LogicalOperator)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

ConditionalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

Action:
    DeviceAction | NotificationAction | PropertyAction | ServiceAction
;