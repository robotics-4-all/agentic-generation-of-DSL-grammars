SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth*=Authentication
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

Metadata:
    'Metadata' name=ID
    (
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('tokenType:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Cert>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)
        ('routingKey:' routingKey=STRING)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('url:' url=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' headers=Dict)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller'
;

Behavior:
    name=ID ':' action=[Action]
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('properties:' properties=Dict)?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
    )#
    'end'
;

TimeTrigger:
    'Time' '(' schedule=STRING ')'
;

EventTrigger:
    'Event' '(' entity=[Entity] ',' event=STRING ')'
;

StateTrigger:
    'State' '(' entity=[Entity] ',' condition=[Condition] ')'
;

Trigger:
    TimeTrigger | EventTrigger | StateTrigger
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

EntityValue:
    entity=[Entity] '.' property=ID
;

LiteralValue:
    STRING | FLOAT | INT | BOOL
;

FunctionCall:
    name=ID '(' args*=ValueExpression[','] ')'
;

ValueExpression:
    EntityValue | LiteralValue | FunctionCall
;

ComparisonExpression:
    left=ValueExpression operator=ComparisonOperator right=ValueExpression
    | '(' expression=LogicalExpression ')'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;

Action:
    'Action' name=ID
    (
        ('target:' target=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' parameters=Dict)?
        ('description:' description=STRING)?
    )#
    'end'
;

List:
    '[' items*=ListItem[','] ']'
;

ListItem:
    STRING | FLOAT | INT | BOOL | Dict | List
;

Dict:
    '{' items*=DictItem[','] '}'
;

DictItem:
    key=STRING ':' value=DictValue
;

DictValue:
    STRING | FLOAT | INT | BOOL | Dict | List
;