SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=BrokerConfig)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'array' | 'object'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE'
;

AutomationMode:
    'single' | 'restart' | 'queued' | 'parallel'
;

ScheduleType:
    'time' | 'cron' | 'interval'
;

DayOfWeek:
    'monday' | 'tuesday' | 'wednesday' | 'thursday' | 'friday' | 'saturday' | 'sunday'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

EntityOperation:
    'turn_on' | 'turn_off' | 'set_value' | 'toggle' | 'reset'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'slack' | 'webhook'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ScriptLanguage:
    'python' | 'javascript' | 'lua' | 'bash'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)?
        ('method:' method=HTTPMethod)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

CoapBroker:
    'Broker<CoAP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('resource:' resource=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | HTTPBroker | CoapBroker
;

Property:
    'Property' name=ID
    (
        ('dataType:' dataType=DataType)
        ('value:' value=PropertyValue)?
        ('unit:' unit=STRING)?
        ('readable:' readable=BOOL)?
        ('writable:' writable=BOOL)?
    )#
    'end'
;

ActionParameter:
    'Parameter' name=ID
    (
        ('value:' value=PropertyValue)
        ('type:' type=DataType)?
    )#
    'end'
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('entity:' entity=[Entity])
        ('operation:' operation=EntityOperation)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('recipient:' recipient=STRING)?
        ('channel:' channel=NotificationChannel)
    )#
    'end'
;

DelayAction:
    'Action<Delay>' name=ID
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

ScriptAction:
    'Action<Script>' name=ID
    (
        ('language:' language=ScriptLanguage)
        ('code:' code=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

Action:
    EntityAction | NotificationAction | DelayAction | ScriptAction
;

SimpleCondition:
    'Condition<Simple>' name=ID
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
    'end'
;

ComplexCondition:
    'Condition<Complex>' name=ID
    (
        ('operator:' operator=LogicalOperator)
        ('conditions:' '-' conditions*=[Condition]['-'])
    )#
    'end'
;

ScheduleCondition:
    'Condition<Schedule>' name=ID
    (
        ('type:' type=ScheduleType)
        ('value:' value=STRING)
        ('days:' '-' days*=DayOfWeek['-'])?
    )#
    'end'
;

Condition:
    SimpleCondition | ComplexCondition | ScheduleCondition
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=[Condition])
        ('action:' action=[Action])
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' type=EntityType)
        ('location:' location=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('broker:' broker=[BrokerConfig])?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('description:' description=STRING)?
        ('triggers:' '-' triggers*=[Condition]['-'])
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('mode:' mode=AutomationMode)?
    )#
    'end'
;