SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=MessageBroker
        authentication*=Authentication
        entities*=Entity
        conditions*=Condition
        actions*=Action
        automations*=Automation
    )#
;

QoSLevel:
    '0' | '1' | '2'
;

TokenType:
    'Bearer' | 'API_KEY' | 'JWT'
;

EntityType:
    'SENSOR' | 'ACTUATOR' | 'DEVICE' | 'CONTROLLER' | 'GATEWAY' | 'SERVICE'
;

EntityStatus:
    'ACTIVE' | 'INACTIVE' | 'MAINTENANCE' | 'ERROR'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'array' | 'timestamp'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

TriggerType:
    'PERIODIC' | 'EVENT_DRIVEN' | 'ON_DEMAND' | 'CONDITIONAL'
;

ExecutionMode:
    'SEQUENTIAL' | 'PARALLEL' | 'CONDITIONAL' | 'IMMEDIATE'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'AND' | 'OR' | 'NOT'
;

EntityOperation:
    'SET' | 'GET' | 'TOGGLE' | 'RESET' | 'CALIBRATE' | 'UPDATE'
;

NotificationType:
    'EMAIL' | 'SMS' | 'PUSH' | 'WEBHOOK' | 'LOG'
;

NotificationPriority:
    'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

TimeUnit:
    'SECONDS' | 'MINUTES' | 'HOURS' | 'DAYS'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

Behavior:
    'Behavior' name=ID
    (
        ('frequency:' frequency=INT)?
        ('trigger:' trigger=TriggerType)?
        ('payload:' payload=STRING)?
    )#
    'end'
;

TimeTrigger:
    'Trigger<Time>'
    (
        ('schedule:' schedule=STRING)
        ('timezone:' timezone=STRING)?
    )#
;

EntityTrigger:
    'Trigger<Entity>'
    (
        ('entity:' entity=ID)
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

EventTrigger:
    'Trigger<Event>'
    (
        ('event_type:' eventType=STRING)
        ('source:' source=STRING)?
        ('filter:' filter=STRING)?
    )#
;

AutomationTrigger:
    TimeTrigger | EntityTrigger | EventTrigger
;

SimpleCondition:
    entity=ID '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ConditionExpression:
    left=SimpleCondition (logicalOp=LogicalOperator right=ConditionExpression)?
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=TokenType)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' certPath=STRING)
        ('key_path:' keyPath=STRING)?
        ('ca_path:' caPath=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=QoSLevel)?
        ('auth:' auth=ID)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=ID)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=ID)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('target:' target=ID)
        ('operation:' operation=EntityOperation)
        ('parameters:' parameters*=ParameterList)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('type:' notificationType=NotificationType)
        ('recipient:' recipient=STRING)
        ('message:' message=STRING)
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

ServiceAction:
    'Action<Service>' name=ID
    (
        ('service_url:' serviceUrl=STRING)
        ('method:' method=HTTPMethod)
        ('headers:' headers*=ParameterList)?
        ('body:' body=STRING)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

DelayAction:
    'Action<Delay>' name=ID
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

ParameterList:
    '-' parameters*=ActionParameter['-']
;

Action:
    EntityAction | NotificationAction | ServiceAction | DelayAction
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=ID)?
        ('topic:' topic=STRING)?
        ('properties:' properties*=PropertyList)?
        ('behaviors:' behaviors*=BehaviorList)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

PropertyList:
    '-' properties*=Property['-']
;

BehaviorList:
    '-' behaviors*=Behavior['-']
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('timeout:' timeout=INT)?
        ('retry:' retry=INT)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=AutomationTrigger)
        ('condition:' condition=ID)?
        ('actions:' actions*=ActionList)
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;

ActionList:
    '-' actions*=ID['-']
;