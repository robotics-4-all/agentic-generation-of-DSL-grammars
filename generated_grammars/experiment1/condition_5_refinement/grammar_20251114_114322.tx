SmartEnvironmentModel:
    imports_or_references*=ImportOrReferenceStm
    (
        metadata=Metadata?
        brokers*=MessageBroker
        auth_mechanisms*=Authentication
        entities*=Entity
        conditions*=Condition
        actions*=Action
        automations*=Automation
    )*
;

ImportOrReferenceStm:
    ImportStm | ReferenceStm
;

ImportStm:
    'import' grammar_to_import=GrammarToImport
;

ReferenceStm:
    'reference' language_name=LanguageName ('as' language_alias=ID)?
;

GrammarToImport:
    /(\w|\.)+/
;

LanguageName:
    /(\w|-)+/
;

Metadata:
    'Metadata'
    (
        ('name:' name=ID)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('topic_prefix:' topic_prefix=STRING)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('base_path:' base_path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('timeout:' timeout=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth | APIKeyAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('token_type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('api_key:' api_key=STRING)
        ('header_name:' header_name=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[MessageBroker])?
        ('topic:' topic=STRING)?
        ('properties:' properties*=Property['-'])?
        ('behaviors:' behaviors*=Behavior['-'])?
        ('state:' state=EntityState)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

Property:
    '-' name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

DataType:
    'int' | 'float' | 'string' | 'bool' | 'array' | 'object' | 'timestamp'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | ArrayValue | ObjectValue
;

ArrayValue:
    '[' values*=PropertyValue[','] ']'
;

ObjectValue:
    '{' pairs*=ObjectPair[','] '}'
;

ObjectPair:
    key=STRING ':' value=PropertyValue
;

Behavior:
    '-' 'Behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('actions:' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

BehaviorTrigger:
    'on_property_change' | 'on_message' | 'on_schedule' | 'on_condition'
;

EntityState:
    'State'
    (
        ('current:' current=STRING)
        ('possible:' possible_states*=PossibleState)
        ('transitions:' transitions*=StateTransition['-'])?
    )#
    'end'
;

PossibleState:
    '-' state=STRING
;

StateTransition:
    '-' from_state=STRING '->' to_state=STRING ('when' condition=[Condition])?
;

Condition:
    'Condition' name=ID
    (
        ('type:' condition_type=ConditionType)
        ('expression:' expression=LogicalExpression)
        ('entities:' entities*=EntityRef['-'])?
    )#
    'end'
;

EntityRef:
    '-' entity=[Entity]
;

ConditionType:
    'simple' | 'composite' | 'temporal' | 'spatial'
;

LogicalExpression:
    or_expr=OrExpression
;

OrExpression:
    left=AndExpression ('or' right=AndExpression)*
;

AndExpression:
    left=NotExpression ('and' right=NotExpression)*
;

NotExpression:
    ('not')? operand=ComparisonExpression
;

ComparisonExpression:
    left=PropertyReference operator=ComparisonOperator right=ComparisonValue
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

ComparisonValue:
    PropertyValue | PropertyReference
;

PropertyReference:
    entity=[Entity] '.' property=ID
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=[Entity])?
        ('parameters:' parameters*=ActionParameter['-'])?
        ('timeout:' timeout=INT)?
        ('retry:' retry=BOOL)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_message' | 'call_service' | 'trigger_automation' | 'log_event'
;

ActionParameter:
    '-' name=ID ':' value=PropertyValue
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' conditions*=ConditionRef['-'])?
        ('actions:' actions*=ActionRef['-'])
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

ConditionRef:
    '-' condition=[Condition]
;

ActionRef:
    '-' action=[Action]
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('repeat:' repeat=BOOL)?
    )#
;

EventTrigger:
    'EventTrigger'
    (
        ('event_type:' event_type=STRING)
        ('source:' source=[Entity])?
    )#
;

StateTrigger:
    'StateTrigger'
    (
        ('entity:' entity=[Entity])
        ('state_change:' state_change=STRING)
    )#
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('delay:' delay=INT)?
        ('retry_count:' retry_count=INT)?
        ('parallel:' parallel=BOOL)?
    )#
;

ExecutionMode:
    'immediate' | 'delayed' | 'scheduled' | 'conditional'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;