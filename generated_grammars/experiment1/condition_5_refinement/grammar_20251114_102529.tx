SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth_configs*=AuthConfig
        entities*=Entity
        automations*=Automation
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'json' | 'binary'
;

Value:
    STRING | FLOAT | INT | BOOL
;

BehaviorType:
    'periodic' | 'event_driven' | 'on_demand' | 'continuous'
;

BehaviorParam:
    name=ID '=' value=Value
;

BehaviorParams:
    param_items*=BehaviorParam[',']
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional' | 'immediate'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

NotificationPriority:
    'low' | 'medium' | 'high' | 'critical'
;

SystemOperation:
    'log' | 'email' | 'sms' | 'webhook' | 'script' | 'database'
;

ActionParam:
    name=ID '=' value=Value
;

ActionParameters:
    param_list*=ActionParam[',']
;

Attribute:
    name=ID ':' data_type=DataType ('=' default_value=Value)?
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' params=BehaviorParams ')')?
;

TimeExpression:
    'time' '(' time_value=STRING ')'
;

TimeComparison:
    left=TimeExpression operator=ComparisonOperator right=TimeExpression
;

EntityReference:
    entity_name=ID ('.' attribute=ID)?
;

ConditionOperand:
    EntityReference | Value | TimeExpression
;

ComparisonCondition:
    left=ConditionOperand operator=ComparisonOperator right=ConditionOperand
;

EntityCondition:
    entity=ID '.' attribute=ID operator=ComparisonOperator value=Value
;

PrimitiveCondition:
    ComparisonCondition | EntityCondition | TimeComparison
;

Condition:
    left=PrimitiveCondition (operator=LogicalOperator right=PrimitiveCondition)*
;

EntityAction:
    'EntityAction'
    (
        ('target:' target_name=ID)
        ('command:' command=STRING)
        ('parameters:' parameters=ActionParameters)?
    )#
;

NotificationAction:
    'NotificationAction'
    (
        ('channel:' channel=STRING)
        ('message:' message=STRING)
        ('priority:' priority=NotificationPriority)?
    )#
;

SystemAction:
    'SystemAction'
    (
        ('operation:' operation=SystemOperation)
        ('parameters:' parameters=ActionParameters)?
    )#
;

Action:
    EntityAction | NotificationAction | SystemAction
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('delay:' delay=INT)?
        ('timeout:' timeout=INT)?
        ('retry:' retry=INT)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker_name=ID)
        ('topic:' topic=STRING)?
        ('attributes:' '-' attributes*=Attribute['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Condition)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('execution:' execution=ExecutionControl)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;