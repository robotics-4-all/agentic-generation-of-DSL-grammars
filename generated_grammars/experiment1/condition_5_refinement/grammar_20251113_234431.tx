SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=Broker
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
    )#
;

Metadata:
    'Metadata' name=ID
    (
        ('version:' version=STRING)?
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('username:' username=STRING)?
        ('password:' password=STRING)?
        ('ssl:' ssl=BOOL)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=[Broker])?
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'SENSOR' | 'ACTUATOR' | 'DEVICE' | 'CONTROLLER' | 'GATEWAY' | 'VIRTUAL'
;

EntityStatus:
    'ACTIVE' | 'INACTIVE' | 'ERROR' | 'MAINTENANCE'
;

Property:
    'Property' name=ID
    (
        ('datatype:' datatype=DataType)
        ('value:' value=PropertyValue)?
        ('unit:' unit=STRING)?
        ('readonly:' readonly=BOOL)?
        ('range:' range=Range)?
    )#
    'end'
;

DataType:
    'str' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

Range:
    'Range' '(' min=FLOAT ',' max=FLOAT ')'
;

Behavior:
    'Behavior' name=ID
    (
        ('action:' action=STRING)
        ('parameters:' '-' parameters*=Parameter['-'])?
        ('frequency:' frequency=INT)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

Parameter:
    name=ID ':' value=PropertyValue
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)
        ('trigger:' trigger=Trigger)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=Action['-'])
        ('priority:' priority=INT)?
        ('schedule:' schedule=Schedule)?
    )#
    'end'
;

Trigger:
    EventTrigger | TimeTrigger | PropertyTrigger
;

EventTrigger:
    'Trigger<Event>'
    (
        ('event:' event=STRING)
        ('source:' source=[Entity])?
    )#
;

TimeTrigger:
    'Trigger<Time>'
    (
        ('cron:' cron=STRING)
        ('interval:' interval=INT)?
    )#
;

PropertyTrigger:
    'Trigger<Property>'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

PrimitiveCondition:
    PropertyCondition | TimeCondition
;

Condition:
    left=PrimitiveCondition (operator=LogicalOperator right=PrimitiveCondition)*
;

PropertyCondition:
    'Condition<Property>'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
;

TimeCondition:
    'Condition<Time>'
    (
        ('start:' start=TIME)
        ('end:' end=TIME)?
        ('days:' days=DaysList)?
    )#
;

LogicalOperator:
    'AND' | 'OR' | 'NOT'
;

DaysList:
    '[' days*=DAY[','] ']'
;

DAY:
    'MON' | 'TUE' | 'WED' | 'THU' | 'FRI' | 'SAT' | 'SUN'
;

TIME:
    /([0-1]?[0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?/
;

Action:
    PropertyAction | ServiceAction | NotificationAction
;

PropertyAction:
    'Action<Property>'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('value:' value=PropertyValue)
        ('delay:' delay=INT)?
    )#
;

ServiceAction:
    'Action<Service>'
    (
        ('service:' service=STRING)
        ('method:' method=STRING)
        ('parameters:' '-' parameters*=Parameter['-'])?
        ('timeout:' timeout=INT)?
    )#
;

NotificationAction:
    'Action<Notification>'
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)
        ('priority:' priority=NotificationPriority)?
    )#
;

NotificationPriority:
    'LOW' | 'NORMAL' | 'HIGH' | 'CRITICAL'
;

Schedule:
    'Schedule'
    (
        ('start:' start=TIME)?
        ('end:' end=TIME)?
        ('repeat:' repeat=BOOL)?
        ('days:' days=DaysList)?
    )#
;