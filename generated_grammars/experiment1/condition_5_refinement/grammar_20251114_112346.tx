SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentications*=Authentication
        executionControls*=ExecutionControl
        entities*=EntityDefinition
        automations*=AutomationDeclaration
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'controller' | 'gateway' | 'hybrid'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional' | 'immediate'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

TimeValue:
    hour=INT ':' minute=INT (':' second=INT)?
;

PropertyDefinition:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

ActionDefinition:
    EntityAction | NotificationAction | SystemAction
;

EntityAction:
    'set' entity=[EntityDefinition] '.' property=ID 'to' value=PropertyValue
;

NotificationAction:
    'notify' message=STRING ('to' target=STRING)?
;

SystemAction:
    'execute' command=STRING ('with' parameters=STRING)?
;

BehaviorDefinition:
    name=ID ':' action=ActionDefinition
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
        ('ca:' ca=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('location:' location=STRING)?
        ('description:' description=STRING)?
    )#
    'end'
;

EntityCondition:
    entity=[EntityDefinition] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=TimeValue
;

ValueCondition:
    property=ID operator=ComparisonOperator value=PropertyValue
;

SimpleCondition:
    EntityCondition | TimeCondition | ValueCondition
;

ComplexCondition:
    left=SimpleCondition (operator=LogicalOperator right=ConditionSpecification)*
;

ConditionSpecification:
    ComplexCondition | SimpleCondition
;

ExecutionControl:
    'ExecutionControl' name=ID
    (
        ('mode:' mode=ExecutionMode)
        ('retry:' retryCount=INT)?
        ('timeout:' timeout=INT)?
        ('delay:' delay=INT)?
    )#
    'end'
;

AutomationDeclaration:
    'Automation' name=ID
    (
        ('trigger:' trigger=ConditionSpecification)
        ('conditions:' '-' conditions*=ConditionSpecification['-'])?
        ('actions:' '-' actions*=ActionDefinition['-'])
        ('priority:' priority=INT)?
        ('enabled:' enabled=BOOL)?
        ('execution:' executionControl=[ExecutionControl])?
    )#
    'end'
;