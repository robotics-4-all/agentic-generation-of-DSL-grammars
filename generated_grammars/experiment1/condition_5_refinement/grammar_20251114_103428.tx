SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

DataType:
    'int' | 'float' | 'str' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'hybrid'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

ComparisonOperator:
    '==' | '!=' | '>=' | '<=' | '>' | '<' | 'contains' | 'in'
;

LogicalOperator:
    'and' | 'or' | 'not' | 'xor'
;

BehaviorType:
    'publish' | 'subscribe' | 'request' | 'response' | 'periodic' | 'triggered' | 'scheduled'
;

ExecutionMode:
    'immediate' | 'delayed' | 'scheduled' | 'conditional'
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | CoapBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('qos:' qos=INT)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=ID)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=ID)?
    )#
    'end'
;

CoapBroker:
    'Broker<CoAP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('security:' security=BOOL)?
        ('auth:' auth=ID)?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

PropertyDef:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)? ('unit:' unit=STRING)?
;

BehaviorDef:
    name=ID ':' behavior_type=BehaviorType ('config:' config=STRING)?
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=ID)
        ('topic:' topic=STRING)?
        ('location:' location=STRING)?
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)
        ('delay:' delay=INT)?
        ('timeout:' timeout=INT)?
        ('retry:' retry=INT)?
    )#
    'end'
;

SimpleCondition:
    entity_ref=ID '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ConditionGroup:
    left=Condition (logical_op=LogicalOperator right=Condition)*
;

Condition:
    SimpleCondition | '(' ConditionGroup ')'
;

ActionData:
    PropertyValue | JsonData
;

JsonValue:
    PropertyValue | JsonData | ArrayData
;

JsonItem:
    key=STRING ':' value=JsonValue
;

JsonData:
    '{' items*=JsonItem[','] '}'
;

ArrayData:
    '[' items*=JsonValue[','] ']'
;

ActionDef:
    SetAction | PublishAction | CallAction | DelayAction
;

SetAction:
    'Set' entity_ref=ID '.' property=ID '=' value=PropertyValue
;

PublishAction:
    'Publish' topic=STRING 'data:' data=ActionData
;

CallAction:
    'Call' service=STRING ('params:' params=ActionData)?
;

DelayAction:
    'Delay' duration=INT
;

AutomationDef:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('conditions:' conditions=ConditionGroup)
        ('actions:' '-' actions*=ActionDef['-'])
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;