SmartEnvironmentModel:
    (
        metadata=Metadata
        brokers*=MessageBroker
        authentications*=Authentication
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

ExecutionMode:
    'immediate' | 'scheduled' | 'delayed' | 'periodic'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'startsWith' | 'endsWith'
;

ActionMethod:
    'set' | 'increment' | 'decrement' | 'toggle'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

Behavior:
    name=ID ':' action=[Action]
;

HeaderParam:
    name=ID ':' value=STRING
;

PropertyReference:
    entity=[Entity] '.' property=ID
;

ComparisonValue:
    FLOAT | INT | STRING | BOOL | PropertyReference
;

ComparisonExpression:
    left=PropertyReference operator=ComparisonOperator right=ComparisonValue
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

Metadata:
    'Metadata' name=ID
    (
        ('version:' version=STRING)?
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
        ('ca:' ca=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('location:' location=STRING)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
        ('description:' description=STRING)?
    )#
    'end'
;

PropertyAction:
    'Action<Property>' name=ID
    (
        ('target:' target=PropertyReference)
        ('value:' value=PropertyValue)
        ('method:' method=ActionMethod)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('recipients:' '-' recipients*=STRING['-'])?
        ('channel:' channel=STRING)?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

ServiceAction:
    'Action<Service>' name=ID
    (
        ('url:' url=STRING)
        ('method:' httpMethod=HTTPMethod)
        ('headers:' '-' headers*=HeaderParam['-'])?
        ('body:' body=STRING)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

DelayAction:
    'Action<Delay>' name=ID
    (
        ('duration:' duration=INT)
        ('unit:' timeUnit=TimeUnit)
    )#
    'end'
;

Action:
    PropertyAction | NotificationAction | ServiceAction | DelayAction
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('condition:' condition=[Condition])
        ('actions:' '-' actions*=[Action]['-'])
        ('mode:' mode=ExecutionMode)?
        ('schedule:' schedule=STRING)?
    )#
    'end'
;