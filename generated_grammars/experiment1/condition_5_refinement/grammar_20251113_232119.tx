SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=Broker
        auth_mechanisms*=AuthMechanism
        entities*=Entity
        conditions*=Condition
        actions*=Action
        automations*=Automation
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'system' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

BehaviorType:
    'read_only' | 'write_only' | 'read_write' | 'event_driven' | 'periodic'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'not_contains'
;

LogicalOperator:
    'AND' | 'OR' | 'NOT' | 'XOR'
;

EvaluationType:
    'immediate' | 'delayed' | 'periodic'
;

EntityOperation:
    'read' | 'write' | 'toggle' | 'reset' | 'configure'
;

NotificationChannel:
    'email' | 'sms' | 'push' | 'mqtt' | 'webhook'
;

NotificationPriority:
    'low' | 'medium' | 'high' | 'critical'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

Behavior:
    name=ID ':' behavior_type=BehaviorType
;

EntityPropertyRef:
    'entity_property' '.' entity=ID '.' property=ID
;

ConditionValue:
    STRING | FLOAT | INT | BOOL | entity_property=EntityPropertyRef
;

ParameterValue:
    STRING | FLOAT | INT | BOOL | entity_ref=EntityPropertyRef
;

ActionParameter:
    name=ID ':' value=ParameterValue
;

ConditionRef:
    condition=ID
;

ActionRef:
    action=ID
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)?
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)?
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

AuthMechanism:
    BasicAuth | TokenAuth | CertificateAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthMechanism])?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('broker:' broker=[Broker])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

SimpleCondition:
    'Condition' name=ID
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=ConditionValue)
        ('evaluation_type:' eval_type=EvaluationType)?
    )#
    'end'
;

CompoundCondition:
    'CompoundCondition' name=ID
    (
        ('conditions:' '-' sub_conditions*=ConditionRef['-'])
        ('logical_operator:' logical_op=LogicalOperator)
        ('evaluation_type:' eval_type=EvaluationType)?
    )#
    'end'
;

Condition:
    SimpleCondition | CompoundCondition
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('entity:' entity=[Entity])
        ('operation:' operation=EntityOperation)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('recipients:' '-' recipients*=STRING['-'])
        ('channel:' channel=NotificationChannel)
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

ScriptAction:
    'Action<Script>' name=ID
    (
        ('script_path:' script_path=STRING)
        ('interpreter:' interpreter=STRING)?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

Action:
    EntityAction | NotificationAction | ScriptAction
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=[Condition])
        ('actions:' '-' action_list*=ActionRef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution_mode:' exec_mode=ExecutionMode)?
    )#
    'end'
;