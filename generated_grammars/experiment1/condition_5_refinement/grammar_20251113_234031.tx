SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        brokers*=MessageBroker
        auth*=Authentication
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

Import:
    'import' uri=STRING ('as' alias=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'room' | 'zone' | 'system'
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'array'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

BehaviorType:
    'periodic' | 'event_driven' | 'state_change' | 'threshold' | 'custom'
;

BehaviorParam:
    key=ID '=' value=PropertyValue
;

BehaviorParams:
    params*=BehaviorParam[',']
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' params=BehaviorParams ')')?
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Cert>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=STRING)?
        ('location:' location=STRING)?
    )#
    'end'
;

CronExpression:
    'cron' '(' expression=STRING ')'
;

TimeInterval:
    'interval' '(' seconds=INT ')'
;

TimeSpec:
    CronExpression | TimeInterval
;

TimeTrigger:
    'time' '(' time_spec=TimeSpec ')'
;

EventTrigger:
    'event' '(' entity=[Entity] ',' event_type=STRING ')'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'in' | 'contains'
;

StateTrigger:
    'state' '(' entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue ')'
;

AutomationTrigger:
    TimeTrigger | EventTrigger | StateTrigger
;

ExecutionMode:
    'sequential' | 'parallel' | 'single'
;

EntityPropertyRef:
    entity=[Entity] '.' property=ID
;

FunctionCall:
    function_name=ID '(' args*=PropertyValue[','] ')'
;

ValueExpression:
    EntityPropertyRef | PropertyValue | FunctionCall
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonExpression:
    left=ValueExpression operator=ComparisonOperator right=ValueExpression
    | '(' expression=LogicalExpression ')'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=LogicalExpression)
        ('timeout:' timeout=INT)?
        ('retry:' retry=INT)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;

ActionType:
    'set_state' | 'send_message' | 'call_service' | 'notify' | 'delay' | 'script'
;

EntityTarget:
    entity=[Entity] ('.' property=ID)?
;

ServiceTarget:
    service=STRING
;

NotificationTarget:
    channel=STRING
;

ActionTarget:
    EntityTarget | ServiceTarget | NotificationTarget
;

TemplateString:
    'template' '(' content=STRING ')'
;

ParameterValue:
    PropertyValue | EntityPropertyRef | TemplateString
;

ActionParameter:
    key=ID ':' value=ParameterValue
;

Action:
    'Action' name=ID
    (
        ('type:' action_type=ActionType)
        ('target:' target=ActionTarget)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('retry:' retry=INT)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;

Comment:
    CommentLine | CommentBlock
;