SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=Broker
        entities*=Entity
        actions*=Action
        conditions*=Condition
        automations*=Automation
        auth_definitions*=Authentication
        behaviors*=Behavior
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=ID)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

Authentication:
    PlainAuth | TokenAuth | CertAuth
;

PlainAuth:
    'PlainAuth'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'TokenAuth'
    (
        ('token:' token=STRING)
    )#
    'end'
;

CertAuth:
    'CertAuth'
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=Authentication)?
        ('endpoints:' '-' endpoints*=STRING['-'])?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

DataType:
    'float' | 'int' | 'string' | 'bool' | 'array' | 'object'
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | ID
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=STRING)
        ('response:' response=STRING)
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=ID)
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=ID['-'])?
        ('location:' location=STRING)?
    )#
    'end'
;

TimeTrigger:
    'TimeTrigger'
    (
        ('schedule:' schedule=STRING)
        ('repeat:' repeat=BOOL)?
    )#
    'end'
;

EventTrigger:
    'EventTrigger'
    (
        ('event:' event=STRING)
        ('source:' source=ID)?
    )#
    'end'
;

StateTrigger:
    'StateTrigger'
    (
        ('entity:' entity=ID)
        ('property:' property=ID)
        ('operator:' operator=ComparisonOperator)
        ('value:' value=PropertyValue)
    )#
    'end'
;

TriggerDef:
    TimeTrigger | EventTrigger | StateTrigger
;

ComparisonOperator:
    '==' | '!=' | '>=' | '<=' | '>' | '<'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

SimpleCondition:
    entity=ID '.' property=ID operator=ComparisonOperator value=PropertyValue
;

ConditionTerm:
    SimpleCondition | '(' expression=ConditionExpression ')'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

ActionType:
    'set_property' | 'send_command' | 'notify' | 'log' | 'delay'
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

Action:
    'Action' name=ID
    (
        ('type:' actionType=ActionType)
        ('target:' target=ID)?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
        ('description:' description=STRING)?
    )#
    'end'
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('trigger:' trigger=TriggerDef)
        ('conditions:' '-' conditions*=ID['-'])?
        ('actions:' '-' actions*=ID['-'])
        ('priority:' priority=INT)?
    )#
    'end'
;

Comment: CommentLine | CommentBlock;
CommentLine: /\/\/.*?$/;
CommentBlock: /\/\*(.|\n)*?\*\//;