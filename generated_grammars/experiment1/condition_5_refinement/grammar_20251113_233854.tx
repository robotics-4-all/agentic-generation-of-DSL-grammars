SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'error' | 'maintenance'
;

DataType:
    'int' | 'float' | 'bool' | 'string' | 'json' | 'binary'
;

PropertyValue:
    FLOAT | INT | BOOL | STRING
;

TriggerType:
    'periodic' | 'onchange' | 'oncommand' | 'onevent'
;

LogicalOp:
    'and' | 'or' | 'not'
;

CompareOp:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'startswith' | 'endswith'
;

TimeValue:
    hour=INT ':' minute=INT (':' second=INT)?
;

PropertyDef:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

PlainAuth:
    'Auth<Plain>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Cert>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

AuthConfig:
    PlainAuth | TokenAuth | CertAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

BehaviorDef:
    'behavior' name=ID
    (
        ('trigger:' trigger=TriggerType)
        ('action:' action=STRING)
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('location:' location=STRING)?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityCondition:
    entity=[EntityDef] '.' property=ID compareOp=CompareOp value=PropertyValue
;

TimeCondition:
    'time' compareOp=CompareOp timeValue=TimeValue
;

ValueCondition:
    value1=PropertyValue compareOp=CompareOp value2=PropertyValue
;

SimpleCondition:
    EntityCondition | TimeCondition | ValueCondition
;

ConditionTerm:
    '(' condition=ConditionSpec ')' | SimpleCondition
;

ConditionSpec:
    left=ConditionTerm (operator=LogicalOp right=ConditionTerm)*
;

EntityAction:
    'entity' entity=[EntityDef] '.' property=ID '=' value=PropertyValue
;

NotificationAction:
    'notify' message=STRING ('via' broker=[BrokerConfig] 'topic' topic=STRING)?
;

ScriptAction:
    'script' scriptPath=STRING ('args' args*=STRING[','])?
;

ActionSpec:
    EntityAction | NotificationAction | ScriptAction
;

ScheduleSpec:
    'cron' cronExpr=STRING | 'interval' intervalSec=INT | 'daily' time=TimeValue
;

AutomationDef:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('conditions:' condition=ConditionSpec)
        ('actions:' '-' actions*=ActionSpec['-'])
        ('priority:' priority=INT)?
        ('schedule:' schedule=ScheduleSpec)?
    )#
    'end'
;