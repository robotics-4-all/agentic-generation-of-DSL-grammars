SmartEnvironmentModel:
    (
        imports*=ImportStm
        metadata=MetadataDeclaration?
        brokers*=BrokerDeclaration
        entities*=EntityDeclaration
        automations*=AutomationDeclaration
    )#
;

ImportStm:
    'import' module=STRING
;

MetadataDeclaration:
    'Metadata' name=ID
    (
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BrokerDeclaration:
    MQTTBrokerDeclaration | AMQPBrokerDeclaration
;

MQTTBrokerDeclaration:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=AuthenticationMechanism)?
    )#
    'end'
;

AMQPBrokerDeclaration:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=AuthenticationMechanism)?
    )#
    'end'
;

AuthenticationMechanism:
    UsernamePasswordAuth | TokenAuth | CertificateAuth
;

UsernamePasswordAuth:
    'UsernamePassword'
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
;

TokenAuth:
    'Token'
    (
        ('token:' token=STRING)
    )#
;

CertificateAuth:
    'Certificate'
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
    )#
;

EntityDeclaration:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)?
        ('broker:' broker=[BrokerDeclaration])?
        ('topic:' topic=STRING)?
        (properties*=PropertyDeclaration)?
        (behaviors*=BehaviorDeclaration)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller'
;

PropertyDeclaration:
    'properties:' name=ID ':' ptype=PropertyType ('=' default=PropertyValue)?
;

PropertyType:
    'string' | 'int' | 'float' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

BehaviorDeclaration:
    'behaviors:' name=ID ':' behavior=BehaviorType
;

BehaviorType:
    'periodic' | 'event_driven' | 'on_demand'
;

AutomationDeclaration:
    'Automation' name=ID
    (
        ('trigger:' trigger=ConditionSpecification)
        ('actions:' actions*=ActionDefinition)
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;

ComparisonCondition:
    entity=[EntityDeclaration] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' operator=ComparisonOperator value=STRING
;

ConditionSpecification:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionTerm:
    '(' condition=ConditionSpecification ')' | ComparisonCondition | TimeCondition
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

ActionDefinition:
    EntityAction | NotificationAction | DelayAction
;

EntityAction:
    'actions:' 'set' entity=[EntityDeclaration] '.' property=ID '=' value=PropertyValue
;

NotificationAction:
    'actions:' 'notify' message=STRING ('to' target=STRING)?
;

DelayAction:
    'actions:' 'delay' duration=INT
;