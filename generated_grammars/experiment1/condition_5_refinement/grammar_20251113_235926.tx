SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentication*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('author:' author=STRING)?
        ('description:' description=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=ID)?
        ('baseTopic:' baseTopic=STRING)?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=ID)?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('database:' database=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=ID)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('tokenType:' tokenType=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('certificatePath:' certificatePath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('passphrase:' passphrase=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('broker:' broker=ID)?
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'virtual'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

Behavior:
    'Behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('actions:' '-' actions*=Action['-'])
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

BehaviorTrigger:
    'onUpdate' | 'onCommand' | 'onTimer' | 'onThreshold' | 'onEvent'
;

Automation:
    'Automation' name=ID
    (
        ('description:' description=STRING)?
        ('enabled:' enabled=BOOL)?
        ('conditions:' conditions=ConditionGroup)
        ('actions:' '-' actions*=Action['-'])
        ('schedule:' schedule=Schedule)?
        ('priority:' priority=INT)?
    )#
    'end'
;

PrimitiveCondition:
    EntityCondition | SystemCondition | GroupCondition
;

ConditionGroup:
    conditions+=PrimitiveCondition (operator=LogicalOperator conditions+=PrimitiveCondition)*
;

GroupCondition:
    '(' group=ConditionGroup ')'
;

EntityCondition:
    entity=ID '.' property=ID operator=ComparisonOperator value=PropertyValue
;

SystemCondition:
    'system' '.' property=SystemProperty operator=ComparisonOperator value=PropertyValue
;

SystemProperty:
    'hour' | 'minute' | 'dayOfWeek' | 'temperature' | 'humidity' | 'brightness'
;

TimeValue:
    time=TIME | timeRange=TimeRange
;

TimeRange:
    start=TIME '-' end=TIME
;

TIME:
    /([01]?[0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?/
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'in' | 'not' 'in'
;

Action:
    EntityAction | NotificationAction | DelayAction | ScriptAction
;

EntityAction:
    'EntityAction'
    (
        ('target:' target=ID)
        ('command:' command=STRING)
        ('parameters:' parameters=ActionParameters)?
    )#
    'end'
;

NotificationAction:
    'NotificationAction'
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

DelayAction:
    'DelayAction'
    (
        ('duration:' duration=INT)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

ScriptAction:
    'ScriptAction'
    (
        ('script:' script=STRING)
        ('language:' language=ScriptLanguage)?
        ('parameters:' parameters=ActionParameters)?
    )#
    'end'
;

ActionParameters:
    '{' params*=ActionParameter[','] '}'
;

ActionParameter:
    key=ID ':' value=PropertyValue
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

ScriptLanguage:
    'python' | 'javascript' | 'bash' | 'lua'
;

Schedule:
    CronSchedule | IntervalSchedule | TimeSchedule
;

CronSchedule:
    'cron' '(' expression=STRING ')'
;

IntervalSchedule:
    'interval' '(' value=INT unit=TimeUnit ')'
;

TimeSchedule:
    'at' '(' time=TIME ('on' days*=DayOfWeek[','])? ')'
;

DayOfWeek:
    'monday' | 'tuesday' | 'wednesday' | 'thursday' | 'friday' | 'saturday' | 'sunday'
;

FQN:
    ID ('.' ID)*
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;