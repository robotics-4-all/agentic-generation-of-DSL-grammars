SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=MessageBroker
        authentication*=Authentication
        entities*=Entity
        automations*=Automation
        conditions*=Condition
        actions*=Action
    )#
;

Metadata:
    'Metadata' name=ID
    (
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('created:' created=STRING)?
    )#
    'end'
;

MessageBroker:
    HTTPBroker | AMQPBroker | MQTTBroker
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=QoSLevel)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    CertAuth | TokenAuth | BasicAuth
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_file:' cert_file=STRING)
        ('key_file:' key_file=STRING)
        ('ca_file:' ca_file=STRING)?
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' type=EntityType)
        ('location:' location=STRING)?
        ('description:' description=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('broker:' broker=[MessageBroker])?
        ('topic:' topic=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'system' | 'virtual'
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

PropertyValue:
    FLOAT | INT | STRING | BOOL
;

DataType:
    'string' | 'int' | 'float' | 'bool' | 'json' | 'binary'
;

Behavior:
    name=ID '(' parameters*=Parameter[',']? ')'
;

Parameter:
    name=ID ':' data_type=DataType
;

Automation:
    'Automation' name=ID
    (
        ('enabled:' enabled=BOOL)?
        ('description:' description=STRING)?
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('execution:' execution=ExecutionControl)?
    )#
    'end'
;

AutomationTrigger:
    StateTrigger | EventTrigger | TimeTrigger
;

StateTrigger:
    'State' '(' entity=[Entity] ',' property=ID ',' value=PropertyValue ')'
;

EventTrigger:
    'Event' '(' entity=[Entity] ',' event=STRING ')'
;

TimeTrigger:
    'Timer' '(' schedule=STRING ')'
;

ExecutionControl:
    'ExecutionControl'
    (
        ('mode:' mode=ExecutionMode)?
        ('retry_count:' retry_count=INT)?
        ('timeout:' timeout=INT)?
        ('priority:' priority=PriorityLevel)?
    )#
    'end'
;

ExecutionMode:
    'sequential' | 'parallel' | 'conditional'
;

PriorityLevel:
    'low' | 'medium' | 'high' | 'critical'
;

Condition:
    'Condition' name=ID
    (
        ('description:' description=STRING)?
        ('expression:' expression=LogicalExpression)
    )#
    'end'
;

LogicalExpression:
    left=ComparisonExpression (operator=LogicalOperator right=ComparisonExpression)*
;

ComparisonExpression:
    '(' expression=LogicalExpression ')' |
    PropertyComparison
;

PropertyComparison:
    entity=[Entity] '.' property=ID comparator=ComparisonOperator value=PropertyValue
;

LogicalOperator:
    '&&' | '||' | '!'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'in'
;

Action:
    'Action' name=ID
    (
        ('description:' description=STRING)?
        ('type:' type=ActionType)
        ('target:' target=[Entity])
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

ActionType:
    'command' | 'notification' | 'data_write' | 'service_call'
;

ActionParameter:
    name=ID '=' value=PropertyValue
;

QoSLevel:
    '0' | '1' | '2'
;