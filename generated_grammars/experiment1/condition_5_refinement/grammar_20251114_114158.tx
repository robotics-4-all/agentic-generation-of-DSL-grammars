SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthenticationConfig
        entities*=EntityDefinition
        automations*=AutomationRule
    )#
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'array' | 'object'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL
;

ExecutionMode:
    'immediate' | 'scheduled' | 'delayed'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<='
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('clientId:' clientId=STRING)?
        ('keepAlive:' keepAlive=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('database:' database=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertificateAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' tokenType=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('certPath:' certPath=STRING)
        ('keyPath:' keyPath=STRING)?
        ('caPath:' caPath=STRING)?
    )#
    'end'
;

EntityDefinition:
    'Entity' name=ID
    (
        ('type:' entityType=EntityType)
        ('location:' location=STRING)?
        ('properties:' '-' properties*=PropertyDefinition['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDefinition['-'])?
        ('broker:' broker=[BrokerConfig])?
        ('topic:' topic=STRING)?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

PropertyDefinition:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

BehaviorDefinition:
    name=ID '(' parameters*=BehaviorParameter[',']? ')' ':' description=STRING
;

BehaviorParameter:
    name=ID ':' paramType=DataType
;

AutomationRule:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerCondition)
        ('conditions:' conditions=ConditionExpression)?
        ('actions:' '-' actions*=ActionDefinition['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('executionMode:' executionMode=ExecutionMode)?
    )#
    'end'
;

TriggerCondition:
    EntityTrigger | TimeTrigger | EventTrigger
;

EntityTrigger:
    'EntityChange' '(' entity=[EntityDefinition] (',' property=ID)? ')'
;

TimeTrigger:
    'TimeSchedule' '(' schedule=TimeExpression ')'
;

EventTrigger:
    'Event' '(' eventType=STRING ')'
;

TimeExpression:
    CronExpression | IntervalExpression
;

CronExpression:
    'cron' '(' pattern=STRING ')'
;

IntervalExpression:
    'interval' '(' value=INT ',' unit=TimeUnit ')'
;

ConditionExpression:
    left=ConditionTerm (operator=LogicalOperator right=ConditionTerm)*
;

ConditionTerm:
    '(' expr=ConditionExpression ')' | SimpleCondition
;

SimpleCondition:
    EntityCondition | TimeCondition | ValueCondition
;

EntityCondition:
    entity=[EntityDefinition] '.' property=ID comparator=ComparisonOperator value=PropertyValue
;

TimeCondition:
    'time' comparator=ComparisonOperator timeValue=STRING
;

ValueCondition:
    leftValue=PropertyValue comparator=ComparisonOperator rightValue=PropertyValue
;

ActionDefinition:
    EntityAction | NotificationAction | SystemAction
;

EntityAction:
    'SetEntity' '(' entity=[EntityDefinition] ',' property=ID ',' value=PropertyValue ')'
;

NotificationAction:
    'Notify' '(' message=STRING (',' channel=STRING)? ')'
;

SystemAction:
    'Execute' '(' command=STRING (',' parameters=STRING)? ')'
;