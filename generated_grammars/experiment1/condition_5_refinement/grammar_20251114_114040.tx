SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        auth_configs*=AuthConfig
        entities*=EntityDef
        automations*=AutomationDef
    )#
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'controller' | 'gateway' | 'service'
;

EntityStatus:
    'active' | 'inactive' | 'maintenance' | 'error'
;

DataType:
    'str' | 'float' | 'int' | 'bool' | 'json' | 'array' | 'timestamp'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | JsonValue
;

JsonValue:
    '{' pairs*=JsonPair[','] '}'
;

JsonPair:
    key=STRING ':' value=PropertyValue
;

PropertyDef:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

BehaviorType:
    'periodic' | 'triggered' | 'continuous' | 'on_demand'
;

BehaviorDef:
    name=ID ':' behavior_type=BehaviorType
;

HTTPMethod:
    'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
;

HTTPEndpoint:
    'endpoint' path=STRING method=HTTPMethod
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Cert>' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

ApiKeyAuth:
    'Auth<ApiKey>' name=ID
    (
        ('key:' key=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

AuthConfig:
    BasicAuth | TokenAuth | CertAuth | ApiKeyAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
        ('topics:' '-' topics*=STRING['-'])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

RedisBroker:
    'Broker<Redis>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('db:' db=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthConfig])?
        ('endpoints:' '-' endpoints*=HTTPEndpoint['-'])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | RedisBroker | HTTPBroker
;

EntityDef:
    'Entity' name=ID
    (
        ('type:' entity_type=EntityType)
        ('broker:' broker=[BrokerConfig])
        ('location:' location=STRING)?
        ('properties:' '-' properties*=PropertyDef['-'])?
        ('behaviors:' '-' behaviors*=BehaviorDef['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

CronSchedule:
    'cron' expression=STRING
;

IntervalSchedule:
    'interval' value=INT unit=TimeUnit
;

FixedTimeSchedule:
    'at' time=STRING
;

TimeSchedule:
    CronSchedule | IntervalSchedule | FixedTimeSchedule
;

EntityTrigger:
    'entity' entity=[EntityDef] 'property' property=ID operator=ComparisonOperator value=PropertyValue
;

TimeTrigger:
    'time' schedule=TimeSchedule
;

EventTrigger:
    'event' event_name=STRING
;

TriggerDef:
    EntityTrigger | TimeTrigger | EventTrigger
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'in' | 'not_in' | 'contains'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

SimpleCondition:
    entity=[EntityDef] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

GroupedCondition:
    '(' condition=ConditionGroup ')'
;

ConditionExpr:
    SimpleCondition | GroupedCondition
;

ConditionGroup:
    left=ConditionExpr (logical_op=LogicalOperator right=ConditionExpr)*
;

EntityAction:
    'set' entity=[EntityDef] '.' property=ID 'to' value=PropertyValue
;

NotificationAction:
    'notify' message=STRING ('via' channel=STRING)?
;

ServiceAction:
    'call' service=STRING ('with' params=JsonValue)?
;

DelayAction:
    'delay' duration=INT unit=TimeUnit
;

ActionDef:
    EntityAction | NotificationAction | ServiceAction | DelayAction
;

ExecutionMode:
    'sequential' | 'parallel' | 'async'
;

AutomationDef:
    'Automation' name=ID
    (
        ('trigger:' trigger=TriggerDef)
        ('conditions:' conditions=ConditionGroup)?
        ('actions:' '-' actions*=ActionDef['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('execution:' execution=ExecutionMode)?
    )#
    'end'
;