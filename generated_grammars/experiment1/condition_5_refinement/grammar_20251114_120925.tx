SmartEnvironmentModel:
    imports*=Import
    (metadata=Metadata)?
    (
        (brokers*=MessageBroker)
        (authentications*=Authentication)
        (entities*=Entity)
        (automations*=Automation)
        (conditions*=Condition)
        (actions*=Action)
    )#
;

Import:
    'import' importURI=STRING ('as' name=ID)?
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

MessageBroker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('keepalive:' keepalive=INT)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertAuth
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert:' cert=STRING)
        ('key:' key=STRING)?
        ('ca:' ca=STRING)?
    )#
    'end'
;

Entity:
    'Entity' name=ID
    (
        ('type:' etype=EntityType)
        ('broker:' broker=[MessageBroker])
        ('topic:' topic=STRING)?
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
        ('location:' location=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'system' | 'virtual'
;

EntityStatus:
    'online' | 'offline' | 'error' | 'maintenance'
;

Property:
    name=ID ':' dataType=DataType ('=' defaultValue=PropertyValue)?
;

DataType:
    'string' | 'number' | 'boolean' | 'object' | 'array'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | ObjectValue | ArrayValue
;

ObjectValue:
    '{' pairs*=ObjectPair[','] '}'
;

ObjectPair:
    key=STRING ':' value=PropertyValue
;

ArrayValue:
    '[' items*=PropertyValue[','] ']'
;

Behavior:
    name=ID ':' implementation=STRING
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=AutomationTrigger)
        ('conditions:' '-' conditions*=[Condition]['-'])?
        ('actions:' '-' actions*=[Action]['-'])
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
        ('mode:' mode=AutomationMode)?
    )#
    'end'
;

AutomationTrigger:
    TimeBasedTrigger | EventBasedTrigger | StateChangeTrigger
;

TimeBasedTrigger:
    'TimeBasedTrigger'
    (
        ('schedule:' schedule=STRING)
        ('repeat:' repeat=BOOL)?
    )#
;

EventBasedTrigger:
    'EventBasedTrigger'
    (
        ('entity:' entity=[Entity])
        ('event:' event=STRING)
    )#
;

StateChangeTrigger:
    'StateChangeTrigger'
    (
        ('entity:' entity=[Entity])
        ('property:' property=ID)
        ('from:' fromValue=PropertyValue)?
        ('to:' toValue=PropertyValue)
    )#
;

AutomationMode:
    'single' | 'parallel' | 'queued'
;

Condition:
    'Condition' name=ID
    (
        ('expression:' expression=ConditionExpression)
        ('description:' description=STRING)?
    )#
    'end'
;

ConditionExpression:
    left=ConditionOperand operator=ComparisonOperator right=ConditionOperand (logicalOp=LogicalOperator next=ConditionOperand)*
;

ConditionOperand:
    EntityPropertyRef | LiteralValue | FunctionCall
;

EntityPropertyRef:
    entity=[Entity] '.' property=ID
;

LiteralValue:
    STRING | FLOAT | INT | BOOL
;

FunctionCall:
    function=ID '(' args*=ConditionOperand[','] ')'
;

ComparisonOperator:
    '==' | '!=' | '<' | '>' | '<=' | '>=' | 'contains' | 'startsWith' | 'endsWith'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

Action:
    EntityAction | NotificationAction | SystemAction
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('entity:' entity=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' parameters=ObjectValue)?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

NotificationPriority:
    'low' | 'normal' | 'high' | 'critical'
;

SystemAction:
    'Action<System>' name=ID
    (
        ('command:' command=STRING)
        ('parameters:' parameters=ObjectValue)?
        ('timeout:' timeout=INT)?
    )#
    'end'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;