SmartEnvironmentModel:
    (
        metadata=Metadata?
        brokers*=BrokerConfig
        authentication*=AuthenticationConfig
        entities*=Entity
        automations*=Automation
    )#
;

Metadata:
    'metadata'
    (
        ('name:' name=STRING)?
        ('version:' version=STRING)?
        ('description:' description=STRING)?
        ('author:' author=STRING)?
    )#
    'end'
;

EntityType:
    'sensor' | 'actuator' | 'device' | 'system'
;

PropertyType:
    'float' | 'int' | 'str' | 'bool' | 'array' | 'object'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours'
;

ArrayValue:
    '[' values*=PropertyValue[','] ']'
;

ObjectValue:
    '{' pairs*=PropertyPair[','] '}'
;

PropertyPair:
    key=STRING ':' value=PropertyValue
;

PropertyValue:
    FLOAT | INT | STRING | BOOL | ArrayValue | ObjectValue
;

Property:
    name=ID ':' type=PropertyType ('=' default_value=PropertyValue)?
;

BehaviorTrigger:
    'on_change' | 'on_value' | 'periodic' | 'manual'
;

Behavior:
    'behavior' name=ID
    (
        ('trigger:' trigger=BehaviorTrigger)
        ('actions:' actions*=Action)
    )#
    'end'
;

BasicAuth:
    'auth' 'basic' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'auth' 'token' name=ID
    (
        ('token:' token=STRING)
        ('type:' type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'auth' 'certificate' name=ID
    (
        ('cert_path:' cert_path=STRING)
        ('key_path:' key_path=STRING)
        ('ca_path:' ca_path=STRING)?
    )#
    'end'
;

AuthenticationConfig:
    BasicAuth | TokenAuth | CertificateAuth
;

MQTTBroker:
    'broker' 'mqtt' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('keepalive:' keepalive=INT)?
        ('qos:' qos=INT)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

AMQPBroker:
    'broker' 'amqp' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('vhost:' vhost=STRING)?
        ('exchange:' exchange=STRING)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

HTTPBroker:
    'broker' 'http' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('path:' path=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[AuthenticationConfig])?
    )#
    'end'
;

BrokerConfig:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Entity:
    'entity' name=ID
    (
        ('type:' type=EntityType)?
        ('location:' location=STRING)?
        ('broker:' broker=[BrokerConfig])?
        ('topic:' topic=STRING)?
        ('properties:' properties*=Property)?
        ('behaviors:' behaviors*=Behavior)?
    )#
    'end'
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or'
;

SimpleCondition:
    entity=[Entity] '.' property=ID operator=ComparisonOperator value=PropertyValue
;

Condition:
    left=SimpleCondition (operator=LogicalOperator right=SimpleCondition)*
;

ActionParameter:
    name=ID '=' value=PropertyValue
;

SetPropertyAction:
    'set' entity=[Entity] '.' property=ID '=' value=PropertyValue
;

SendMessageAction:
    'send'
    (
        ('broker:' broker=[BrokerConfig])
        ('topic:' topic=STRING)
        ('message:' message=PropertyValue)
    )#
;

CallServiceAction:
    'call' service=STRING
    (
        ('parameters:' parameters*=ActionParameter)?
    )#
;

DelayAction:
    'delay' duration=INT unit=TimeUnit
;

Action:
    SetPropertyAction | SendMessageAction | CallServiceAction | DelayAction
;

Automation:
    'automation' name=ID
    (
        ('conditions:' conditions*=Condition)
        ('actions:' actions*=Action)
        ('enabled:' enabled=BOOL)?
        ('priority:' priority=INT)?
    )#
    'end'
;