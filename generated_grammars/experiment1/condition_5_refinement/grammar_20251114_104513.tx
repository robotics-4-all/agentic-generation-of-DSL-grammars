SmartEnvironmentModel:
    (
        imports*=Import
        metadata=Metadata?
        authentication*=Authentication  
        brokers*=Broker
        entities*=Entity
        actions*=Action
        execution_controls*=ExecutionControl
        automations*=Automation
        conditions*=Condition
    )#
;

Import:
    'import' module=STRING
;

Metadata:
    'Metadata'
    (
        ('name:' name=STRING)
        ('version:' version=STRING)
        ('description:' description=STRING)?
        ('author:' author=STRING)?
        ('timestamp:' timestamp=STRING)?
    )#
    'end'
;

BasicAuth:
    'Auth<Basic>' name=ID
    (
        ('username:' username=STRING)
        ('password:' password=STRING)
    )#
    'end'
;

TokenAuth:
    'Auth<Token>' name=ID
    (
        ('token:' token=STRING)
        ('type:' token_type=STRING)?
    )#
    'end'
;

CertificateAuth:
    'Auth<Certificate>' name=ID
    (
        ('cert_file:' cert_file=STRING)
        ('key_file:' key_file=STRING)?
        ('ca_file:' ca_file=STRING)?
    )#
    'end'
;

APIKeyAuth:
    'Auth<APIKey>' name=ID
    (
        ('key:' api_key=STRING)
        ('header:' header=STRING)?
    )#
    'end'
;

Authentication:
    BasicAuth | TokenAuth | CertificateAuth | APIKeyAuth
;

MQTTBroker:
    'Broker<MQTT>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('topic:' topic=STRING)?
        ('qos:' qos=INT)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

AMQPBroker:
    'Broker<AMQP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('exchange:' exchange=STRING)?
        ('queue:' queue=STRING)?
        ('routing_key:' routing_key=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

HTTPBroker:
    'Broker<HTTP>' name=ID
    (
        ('host:' host=STRING)
        ('port:' port=INT)
        ('endpoint:' endpoint=STRING)?
        ('ssl:' ssl=BOOL)?
        ('auth:' auth=[Authentication])?
    )#
    'end'
;

Broker:
    MQTTBroker | AMQPBroker | HTTPBroker
;

Property:
    name=ID ':' data_type=DataType ('=' default_value=PropertyValue)?
;

Behavior:
    name=ID ':' behavior_type=BehaviorType ('(' parameters*=Parameter[','] ')')?
;

Parameter:
    name=ID ':' value=PropertyValue
;

ListValue:
    '[' items*=PropertyValue[','] ']'
;

DictItem:
    key=STRING ':' value=PropertyValue
;

DictValue:
    '{' items*=DictItem[','] '}'
;

PropertyValue:
    STRING | FLOAT | INT | BOOL | ListValue | DictValue
;

DataType:
    'str' | 'int' | 'float' | 'bool' | 'list' | 'dict' | 'object'
;

BehaviorType:
    'read' | 'write' | 'execute' | 'notify' | 'stream'
;

EntityStatus:
    'online' | 'offline' | 'error' | 'maintenance'
;

SensorEntity:
    'Entity<Sensor>' name=ID
    (
        ('type:' entity_type=STRING)
        ('location:' location=STRING)?
        ('broker:' broker=[Broker])
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

ActuatorEntity:
    'Entity<Actuator>' name=ID
    (
        ('type:' entity_type=STRING)
        ('location:' location=STRING)?
        ('broker:' broker=[Broker])
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

DeviceEntity:
    'Entity<Device>' name=ID
    (
        ('type:' entity_type=STRING)
        ('location:' location=STRING)?
        ('broker:' broker=[Broker])
        ('properties:' '-' properties*=Property['-'])?
        ('behaviors:' '-' behaviors*=Behavior['-'])?
        ('status:' status=EntityStatus)?
    )#
    'end'
;

Entity:
    SensorEntity | ActuatorEntity | DeviceEntity
;

ExecutionMode:
    'immediate' | 'delayed' | 'scheduled' | 'conditional'
;

ExecutionControl:
    'ExecutionControl' name=ID
    (
        ('mode:' mode=ExecutionMode)
        ('delay:' delay=FLOAT)?
        ('retries:' retries=INT)?
        ('timeout:' timeout=FLOAT)?
    )#
    'end'
;

EntityPropertyRef:
    entity=[Entity] '.' property=ID
;

LiteralValue:
    STRING | FLOAT | INT | BOOL
;

FunctionCall:
    function_name=ID '(' arguments*=ConditionOperand[','] ')'
;

ConditionOperand:
    EntityPropertyRef | LiteralValue | FunctionCall
;

ComparisonOperator:
    '==' | '!=' | '>' | '<' | '>=' | '<=' | 'contains' | 'matches'
;

LogicalOperator:
    'and' | 'or' | 'not'
;

SimpleCondition:
    operand1=ConditionOperand operator=ComparisonOperator operand2=ConditionOperand
;

Condition:
    left=SimpleCondition (logical_operator=LogicalOperator right=SimpleCondition)*
;

ActionParameter:
    name=ID ':' value=PropertyValue
;

NotificationPriority:
    'low' | 'medium' | 'high' | 'critical'
;

TimeUnit:
    'seconds' | 'minutes' | 'hours' | 'days'
;

EntityAction:
    'Action<Entity>' name=ID
    (
        ('target:' target=[Entity])
        ('operation:' operation=STRING)
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

NotificationAction:
    'Action<Notification>' name=ID
    (
        ('message:' message=STRING)
        ('channel:' channel=STRING)?
        ('priority:' priority=NotificationPriority)?
    )#
    'end'
;

DelayAction:
    'Action<Delay>' name=ID
    (
        ('duration:' duration=FLOAT)
        ('unit:' unit=TimeUnit)
    )#
    'end'
;

ScriptAction:
    'Action<Script>' name=ID
    (
        ('script:' script=STRING)
        ('language:' language=STRING)?
        ('parameters:' '-' parameters*=ActionParameter['-'])?
    )#
    'end'
;

Action:
    EntityAction | NotificationAction | DelayAction | ScriptAction
;

ActionReference:
    action=[Action]
;

Automation:
    'Automation' name=ID
    (
        ('trigger:' trigger=Condition)
        ('conditions:' '-' conditions*=Condition['-'])?
        ('actions:' '-' actions*=ActionReference['-'])
        ('execution:' execution=[ExecutionControl])?
        ('enabled:' enabled=BOOL)?
    )#
    'end'
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;

Comment:
    CommentLine | CommentBlock
;