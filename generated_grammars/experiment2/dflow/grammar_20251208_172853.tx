dFlowModel:
    (
        (entities_section=EntitiesSection)?
        (synonyms_section=SynonymsSection)?
        (gslots_section=GSlotsSection)?
        (triggers_section=TriggersSection)?
        (dialogues_section=DialoguesSection)?
        (eservices_section=EServicesSection)?
        (connectors_section=ConnectorsSection)?
        (access_controls_section=AccessControlsSection)?
    )#
;

EntitiesSection:
    'entities'
        entities*=TrainableEntity
    'end'
;

SynonymsSection:
    'synonyms'
        synonyms*=Synonym
    'end'
;

GSlotsSection:
    'gslots'
        gslots*=GlobalSlot[',']
    'end'
;

TriggersSection:
    'triggers'
        triggers*=Trigger
    'end'
;

DialoguesSection:
    'dialogues'
        dialogues*=Dialogue
    'end'
;

EServicesSection:
    'eservices'
        eservices*=EServiceDef
    'end'
;

ConnectorsSection:
    'connectors'
        connectors*=Connector
    'end'
;

AccessControlsSection:
    'access_controls'
        access_control=AccessControlDef
    'end'
;

TrainableEntity:
    'Entity' name=ID
        words+=STRING[',']
    'end'
;

PretrainedEntity:
    'PERSON' | 'NORP' | 'FAC' | 'ORG' | 'GPE' | 'LOC' | 'PRODUCT' | 'EVENT' | 'WORK_OF_ART' | 'LAW' | 'LANGUAGE' | 'DATE' | 'TIME' | 'PERCENT' | 'MONEY' | 'QUANTITY' | 'ORDINAL' | 'CARDINAL'
;

Synonym:
    'Synonym' name=ID
        words+=STRING[',']
    'end'
;

EServiceDef:
    EServiceHTTP
;

EServiceHTTP:
    'EServiceHTTP' name=ID
        (
            ('verb:' verb=HTTPVerb)
            ('host:' host=STRING)
            ('port:' port=INT)?
            ('path:' path=STRING)?
        )#
    'end'
;

HTTPVerb:
    'GET' | 'POST' | 'PUT'
;

GlobalSlot:
    name=ID ':' type=SlotType ('=' default=ParameterValue)?
;

SlotType:
    'int' | 'float' | 'str' | 'bool' | 'list' | 'dict'
;

Trigger:
    Intent | Event
;

Intent:
    'Intent' name=ID
        phrases+=IntentPhrase[',']
    'end'
;

Event:
    'Event' name=ID
        uri=STRING
    'end'
;

IntentPhrase:
    elements+=IntentPhraseElement
;

IntentPhraseElement:
    STRING | TrainableEntityRef | PretrainedEntityRef | SynonymRef
;

TrainableEntityRef:
    'TE:' entity=ID
;

PretrainedEntityRef:
    'PE:' entity=PretrainedEntity ('[' examples+=STRING[','] ']')?
;

SynonymRef:
    'S:' synonym=ID
;

Dialogue:
    'Dialogue' name=ID
        'on:' triggers+=ID[',']
        'responses:' responses+=ResponseRef[',']
    'end'
;

ResponseRef:
    response=ID
;

Response:
    ActionGroup | Form
;

ActionGroup:
    'ActionGroup' name=ID
        actions*=Action
    'end'
;

Form:
    'Form' name=ID
        params*=FormParam
    'end'
;

FormParam:
    name=ID ':' type=SlotType '=' source=FormParamSource
;

FormParamSource:
    HRIParamSource | EServiceParamSource
;

HRIParamSource:
    'HRI' '(' text=TextValue (',' '[' extractions+=ExtractionSource[','] ']')? ')'
;

ExtractionSource:
    TrainableEntityRef | PretrainedEntityRef | IntentExtraction
;

IntentExtraction:
    intent=[Intent] ':' value=ParameterValue
;

EServiceParamSource:
    EServiceCall
;

EServiceCall:
    service=[EServiceHTTP] '('
        (
            ('query=' '[' query_params*=EServiceParam[','] ']')?
            ('header=' '[' header_params*=EServiceParam[','] ']')?
            ('path=' '[' path_params*=EServiceParam[','] ']')?
            ('body=' '[' body_params*=EServiceParam[','] ']')?
        )#
    ')' ('[' filter=ResponseFilter ']')? ('[' 'roles=' roles+=RoleName[','] ']')?
;

EServiceParam:
    name=ID '=' value=ParameterValue
;

ResponseFilter:
    elements+=FilterElement['.']
;

FilterElement:
    ID | INT
;

Action:
    SpeakAction | FireEventAction | RESTCallAction | SetFSlotAction | SetGSlotAction
;

SpeakAction:
    'Speak' '(' text=TextValue ')' ('[' 'roles=' roles+=RoleName[','] ']')?
;

FireEventAction:
    'FireEvent' '(' uri=TextValue ',' message=ParameterValue ')' ('[' 'roles=' roles+=RoleName[','] ']')?
;

RESTCallAction:
    EServiceCall
;

SetFSlotAction:
    'SetFSlot' '(' slot=FormParamRef ',' value=ParameterValue ')' ('[' 'roles=' roles+=RoleName[','] ']')?
;

SetGSlotAction:
    'SetGSlot' '(' slot=GlobalSlotRef ',' value=ParameterValue ')' ('[' 'roles=' roles+=RoleName[','] ']')?
;

ParameterValue:
    ListValue | DictValue | FLOAT | INT | STRING | BOOL | EnvProperty | FormParamRef | GlobalSlotRef | TextValue
;

ListValue:
    '[' items*=ParameterValue[','] ']'
;

DictValue:
    '{' items*=DictItem[','] '}'
;

DictItem:
    key=STRING ':' value=ParameterValue
;

FormParamRef:
    param=[FormParam] ('[' index=IndexValue ']')?
;

GlobalSlotRef:
    slot=[GlobalSlot] ('[' index=IndexValue ']')?
;

IndexValue:
    INT | STRING | FormParamRef | GlobalSlotRef
;

EnvProperty:
    UserProperty | SystemProperty
;

UserProperty:
    'USER:' property=UserPropertyType
;

SystemProperty:
    'SYSTEM:' property=SystemPropertyType
;

UserPropertyType:
    'NAME' | 'SURNAME' | 'AGE' | 'EMAIL' | 'PHONE' | 'CITY' | 'ADDRESS'
;

SystemPropertyType:
    'TIME' | 'LOCATION' | 'RANDOM_INT' | 'RANDOM_FLOAT'
;

TextValue:
    STRING | EnvProperty | FormParamRef | GlobalSlotRef
;

Connector:
    SlackConnector | TelegramConnector
;

SlackConnector:
    'Connector' name='slack'
        (
            ('token:' token=STRING)
            ('channel:' channel=STRING)
            ('signing_secret:' signing_secret=STRING)
        )#
    'end'
;

TelegramConnector:
    'Connector' name='telegram'
        (
            ('token:' token=STRING)
            ('verify:' verify=STRING)
            ('webhook_url:' webhook_url=STRING)
        )#
    'end'
;

AccessControlDef:
    (
        roles=RolesDef
        policies*=PolicyDef
        (path=PathDef)?
        (users=UsersDef)?
        authentication=AuthenticationDef
    )#
;

RolesDef:
    'Roles'
        roles+=RoleName[',']
        'default:' default=RoleName
    'end'
;

PolicyDef:
    'Policy' name=ID
        'on:' actions+=ActionName[',']
        'roles:' roles+=RoleName[',']
    'end'
;

PathDef:
    'Path'
        path=STRING
    'end'
;

UsersDef:
    'Users'
        assignments*=UserRoleAssignment
    'end'
;

UserRoleAssignment:
    role=RoleName ':' users+=UserID[',']
;

AuthenticationDef:
    'Authentication'
        'method:' method=AuthMethod
        ('slot_name:' slot_name=STRING)?
    'end'
;

AuthMethod:
    'slot' | 'user_id' | 'slack' | 'telegram'
;

RoleName:
    ID
;

ActionName:
    ID
;

UserID:
    STRING
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;