dFlowModel:
    (
        (entities_section=EntitiesSection)?
        (synonyms_section=SynonymsSection)?
        (gslots_section=GSlotsSection)?
        (triggers_section=TriggersSection)?
        (dialogues_section=DialoguesSection)?
        (eservices_section=EServicesSection)?
        (connectors_section=ConnectorsSection)?
        (access_controls_section=AccessControlsSection)?
    )#
;

EntitiesSection:
    'entities'
        entities*=TrainableEntity
    'end'
;

SynonymsSection:
    'synonyms'
        synonyms*=Synonym
    'end'
;

GSlotsSection:
    'gslots'
        gslots*=GlobalSlot[',']
    'end'
;

TriggersSection:
    'triggers'
        triggers*=Trigger
    'end'
;

DialoguesSection:
    'dialogues'
        dialogues*=Dialogue
    'end'
;

EServicesSection:
    'eservices'
        eservices*=EServiceDef
    'end'
;

ConnectorsSection:
    'connectors'
        connectors*=Connector
    'end'
;

AccessControlsSection:
    'access_controls'
        access_control=AccessControlDef
    'end'
;

TrainableEntity:
    'Entity' name=ID
        words+=STRING[',']
    'end'
;

PretrainedEntity:
    'PERSON' | 'NORP' | 'FAC' | 'ORG' | 'GPE' | 'LOC' | 'PRODUCT' | 'EVENT' | 
    'WORK_OF_ART' | 'LAW' | 'LANGUAGE' | 'DATE' | 'TIME' | 'PERCENT' | 'MONEY' | 
    'QUANTITY' | 'ORDINAL' | 'CARDINAL'
;

Synonym:
    'Synonym' name=ID
        words+=STRING[',']
    'end'
;

GlobalSlot:
    name=ID ':' type=ParameterType ('=' default=ParameterValue)?
;

Trigger:
    Intent | Event
;

Intent:
    'Intent' name=ID
        phrases+=IntentPhrase[',']
    'end'
;

Event:
    'Event' name=ID
        uri=STRING
    'end'
;

IntentPhrase:
    elements+=IntentPhraseElement
;

IntentPhraseElement:
    STRING | TrainableEntityRef | PretrainedEntityRef | SynonymRef
;

TrainableEntityRef:
    'TE:' entity=[TrainableEntity]
;

PretrainedEntityRef:
    'PE:' entity=PretrainedEntity ('[' examples+=STRING[','] ']')?
;

SynonymRef:
    'S:' synonym=[Synonym]
;

Dialogue:
    'Dialogue' name=ID
        'on:' triggers+=[Trigger][',']
        'responses:' responses+=Response[',']
    'end'
;

Response:
    ActionGroup | Form | ID
;

ActionGroup:
    'ActionGroup' name=ID
        actions*=Action
    'end'
;

Form:
    'Form' name=ID
        params*=FormParam
    'end'
;

FormParam:
    name=ID ':' type=ParameterType '=' source=FormParamSource
;

FormParamSource:
    HRIParamSource | EServiceParamSource
;

HRIParamSource:
    'HRI' '(' text=Text (',' '[' extractions+=ExtractionSource[','] ']')? ')'
;

ExtractionSource:
    TrainableEntityRef | PretrainedEntityRef | IntentExtraction
;

IntentExtraction:
    intent=[Intent] ':' value=ParameterValue
;

EServiceParamSource:
    EServiceCall
;

Action:
    SpeakAction | FireEventAction | RESTCallAction | SetFSlotAction | SetGSlotAction
;

SpeakAction:
    'Speak' '(' text=Text ')' ('[' 'roles' '=' roles+=Word[','] ']')?
;

FireEventAction:
    'FireEvent' '(' uri=Text ',' message=ParameterValue ')' ('[' 'roles' '=' roles+=Word[','] ']')?
;

RESTCallAction:
    EServiceCall
;

SetFSlotAction:
    'SetFSlot' '(' slot=[FormParam] ',' value=ParameterValue ')' ('[' 'roles' '=' roles+=Word[','] ']')?
;

SetGSlotAction:
    'SetGSlot' '(' slot=[GlobalSlot] ',' value=ParameterValue ')' ('[' 'roles' '=' roles+=Word[','] ']')?
;

EServiceDef:
    EServiceHTTP
;

EServiceHTTP:
    'EServiceHTTP' name=ID
    (
        ('verb:' verb=HTTPVerb)
        ('host:' host=STRING)
        ('port:' port=INT)?
        ('path:' path=STRING)?
    )#
    'end'
;

EServiceCall:
    service=[EServiceHTTP] '('
    (
        ('query=' '[' query_params*=EServiceParam[','] ']')?
        ('header=' '[' header_params*=EServiceParam[','] ']')?
        ('path=' '[' path_params*=EServiceParam[','] ']')?
        ('body=' '[' body_params*=EServiceParam[','] ']')?
    )#
    ')' ('[' filter=ResponseFilter ']')? ('[' 'roles' '=' roles+=Word[','] ']')?
;

EServiceParam:
    name=ID '=' value=ParameterValue
;

ResponseFilter:
    elements+=ResponseElement['.']
;

ResponseElement:
    ID | INT
;

HTTPVerb:
    'GET' | 'POST' | 'PUT'
;

Connector:
    SlackConnector | TelegramConnector
;

SlackConnector:
    'Connector' name='slack'
    (
        ('token:' token=STRING)
        ('channel:' channel=STRING)
        ('signing_secret:' signing_secret=STRING)
    )#
    'end'
;

TelegramConnector:
    'Connector' name='telegram'
    (
        ('token:' token=STRING)
        ('verify:' verify=STRING)
        ('webhook_url:' webhook_url=STRING)
    )#
    'end'
;

AccessControlDef:
    (
        (roles=RolesDef)?
        (policies*=PolicyDef)?
        (path=PathDef)?
        (users=UsersDef)?
        (authentication=AuthenticationDef)?
    )#
;

RolesDef:
    'Roles'
        roles+=Word[',']
        'default:' default=Word
    'end'
;

PolicyDef:
    'Policy' name=ID
        'on:' actions+=Word[',']
        'roles:' roles+=Word[',']
    'end'
;

PathDef:
    'Path'
        path=STRING
    'end'
;

UsersDef:
    'Users'
        assignments*=UserRoleAssignment
    'end'
;

UserRoleAssignment:
    role=Word ':' users+=Word[',']
;

AuthenticationDef:
    'Authentication'
        'method:' method=AuthMethod
        ('slot_name:' slot_name=Word)?
    'end'
;

AuthMethod:
    'slot' | 'user_id' | 'slack' | 'telegram'
;

ParameterType:
    'int' | 'float' | 'str' | 'bool' | 'list' | 'dict'
;

FormParamRef:
    param=[FormParam] ('[' index=IndexValue ']')?
;

GlobalSlotRef:
    slot=[GlobalSlot] ('[' index=IndexValue ']')?
;

IndexValue:
    ID | INT | STRING
;

UserProperty:
    'USER:' property=UserPropertyType
;

SystemProperty:
    'SYSTEM:' property=SystemPropertyType
;

UserPropertyType:
    'NAME' | 'SURNAME' | 'AGE' | 'EMAIL' | 'PHONE' | 'CITY' | 'ADDRESS'
;

SystemPropertyType:
    'TIME' | 'LOCATION' | 'RANDOM_INT' | 'RANDOM_FLOAT'
;

EnvProperty:
    UserProperty | SystemProperty
;

Text:
    STRING | FormParamRef | GlobalSlotRef | EnvProperty | ID
;

ListValue:
    '[' items*=ParameterValue[','] ']'
;

DictValue:
    '{' items*=DictItem[','] '}'
;

DictItem:
    key=STRING ':' value=ParameterValue
;

Word:
    /[-\w ]+/
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;

ParameterValue:
    FLOAT | INT | STRING | BOOL | ListValue | DictValue | 
    FormParamRef | GlobalSlotRef | EnvProperty | Text
;