dFlowModel:
    (
        ('entities'
            entities*=TrainableEntity
        'end')?
        
        ('synonyms'
            synonyms*=Synonym
        'end')?
        
        ('gslots'
            gslots*=GlobalSlot[',']
        'end')?
        
        ('triggers'
            triggers*=Trigger
        'end')?
        
        ('dialogues'
            dialogues*=Dialogue
        'end')?
        
        ('eservices'
            eservices*=EServiceDef
        'end')?
        
        ('connectors'
            connectors*=Connector
        'end')?
        
        ('access_controls'
            access_control=AccessControlDef
        'end')?
    )#
;

TrainableEntity:
    'Entity' name=ID
        words+=STRING[',']
    'end'
;

PretrainedEntity:
    'PERSON' | 'NORP' | 'FAC' | 'ORG' | 'GPE' | 'LOC' | 'PRODUCT' | 'EVENT' | 
    'WORK_OF_ART' | 'LAW' | 'LANGUAGE' | 'DATE' | 'TIME' | 'PERCENT' | 'MONEY' | 
    'QUANTITY' | 'ORDINAL' | 'CARDINAL'
;

Synonym:
    'Synonym' name=ID
        words+=STRING[',']
    'end'
;

EServiceDef:
    EServiceHTTP
;

EServiceHTTP:
    'EServiceHTTP' name=ID
        (
            ('verb:' verb=HTTPVerb)
            ('host:' host=STRING)
            ('port:' port=INT)?
            ('path:' path=STRING)?
        )#
    'end'
;

HTTPVerb:
    'GET' | 'POST' | 'PUT'
;

GlobalSlot:
    name=ID ':' type=SlotType ('=' default=ParameterValue)?
;

SlotType:
    'int' | 'float' | 'str' | 'bool' | 'list' | 'dict'
;

Trigger:
    Intent | Event
;

Intent:
    'Intent' name=ID
        phrases+=IntentPhrase[',']
    'end'
;

Event:
    'Event' name=ID
        uri=STRING
    'end'
;

IntentPhrase:
    elements+=IntentPhraseElement
;

IntentPhraseElement:
    STRING | TrainableEntityRef | PretrainedEntityRef | SynonymRef
;

TrainableEntityRef:
    'TE:' entity=[TrainableEntity]
;

PretrainedEntityRef:
    'PE:' entity=PretrainedEntity ('[' examples+=STRING[','] ']')?
;

SynonymRef:
    'S:' synonym=[Synonym]
;

Dialogue:
    'Dialogue' name=ID
        'on:' triggers+=[Trigger][',']
        'responses:' responses+=Response[',']
    'end'
;

Response:
    ActionGroup | Form | ResponseRef
;

ResponseRef:
    name=ID
;

ActionGroup:
    'ActionGroup' name=ID
        actions+=Action
    'end'
;

Form:
    'Form' name=ID
        params+=FormParam
    'end'
;

FormParam:
    name=ID ':' type=SlotType '=' source=FormParamSource
;

FormParamSource:
    HRISource | EServiceSource
;

HRISource:
    'HRI' '(' text=TextComposition (',' '[' extractions+=ExtractionSource[','] ']')? ')'
;

EServiceSource:
    EServiceCall
;

ExtractionSource:
    EntityExtraction | IntentExtraction
;

EntityExtraction:
    TrainableEntityRef | PretrainedEntityRef
;

IntentExtraction:
    intent=[Intent] ':' value=ParameterValue
;

Action:
    SpeakAction | FireEventAction | RESTCallAction | SetFSlotAction | SetGSlotAction
;

SpeakAction:
    'Speak' '(' text=TextComposition ')' ('[' 'roles' '=' roles+=ID[','] ']')?
;

FireEventAction:
    'FireEvent' '(' uri=TextComposition ',' message=ParameterValue ')' ('[' 'roles' '=' roles+=ID[','] ']')?
;

RESTCallAction:
    EServiceCall
;

SetFSlotAction:
    'SetFSlot' '(' slot=[FormParam] ',' value=ParameterValue ')' ('[' 'roles' '=' roles+=ID[','] ']')?
;

SetGSlotAction:
    'SetGSlot' '(' slot=[GlobalSlot] ',' value=ParameterValue ')' ('[' 'roles' '=' roles+=ID[','] ']')?
;

EServiceCall:
    service=[EServiceHTTP] '('
        (
            ('query=' '[' query_params*=ServiceParam[','] ']')?
            ('header=' '[' header_params*=ServiceParam[','] ']')?
            ('path=' '[' path_params*=ServiceParam[','] ']')?
            ('body=' '[' body_params*=ServiceParam[','] ']')?
        )#
    ')' ('[' filter=ResponseFilter ']')? ('[' 'roles' '=' roles+=ID[','] ']')?
;

ServiceParam:
    name=ID '=' value=ParameterValue
;

ResponseFilter:
    elements+=FilterElement['.']
;

FilterElement:
    ID | INT
;

ParameterValue:
    FLOAT | INT | STRING | BOOL | ListValue | DictValue | 
    FormParamRef | GlobalSlotRef | EnvProperty | TextComposition
;

ListValue:
    '[' items*=ParameterValue[','] ']'
;

DictValue:
    '{' items*=DictItem[','] '}'
;

DictItem:
    key=ID ':' value=ParameterValue
;

FormParamRef:
    param=[FormParam] ('[' index=IndexAccess ']')?
;

GlobalSlotRef:
    slot=[GlobalSlot] ('[' index=IndexAccess ']')?
;

IndexAccess:
    parts+=ID['.']
;

EnvProperty:
    UserProperty | SystemProperty
;

UserProperty:
    'USER:' property=UserPropertyType
;

SystemProperty:
    'SYSTEM:' property=SystemPropertyType
;

UserPropertyType:
    'NAME' | 'SURNAME' | 'AGE' | 'EMAIL' | 'PHONE' | 'CITY' | 'ADDRESS'
;

SystemPropertyType:
    'TIME' | 'LOCATION' | 'RANDOM_INT' | 'RANDOM_FLOAT'
;

TextComposition:
    elements+=TextElement
;

TextElement:
    STRING | FormParamRef | GlobalSlotRef | EnvProperty
;

Connector:
    SlackConnector | TelegramConnector
;

SlackConnector:
    'Connector' 'slack'
        (
            ('token:' token=STRING)
            ('channel:' channel=STRING)
            ('signing_secret:' signing_secret=STRING)
        )#
    'end'
;

TelegramConnector:
    'Connector' 'telegram'
        (
            ('token:' token=STRING)
            ('verify:' verify=STRING)
            ('webhook_url:' webhook_url=STRING)
        )#
    'end'
;

AccessControlDef:
    (
        roles=RolesDef
        users=UsersDef?
        policies*=PolicyDef
        path=PathDef?
        authentication=AuthenticationDef
    )#
;

RolesDef:
    'Roles'
        roles+=ID[',']
        'default:' default_role=ID
    'end'
;

UsersDef:
    'Users'
        assignments*=UserRoleAssignment
    'end'
;

UserRoleAssignment:
    role=ID ':' users+=STRING[',']
;

PolicyDef:
    'Policy' name=ID
        'on:' actions+=ID[',']
        'roles:' roles+=ID[',']
    'end'
;

PathDef:
    'Path'
        path=STRING
    'end'
;

AuthenticationDef:
    'Authentication'
        'method:' method=AuthMethod
        ('slot_name:' slot_name=ID)?
    'end'
;

AuthMethod:
    'slot' | 'user_id' | 'slack' | 'telegram'
;

Comment:
    CommentLine | CommentBlock
;

CommentLine:
    /\/\/.*?$/
;

CommentBlock:
    /\/\*(.|\n)*?\*\//
;