dFlow:
(
   (entities_section=EntitiesSection)?
   (synonyms_section=SynonymsSection)?
   (gslots_section=GSlotsSection)?
   (triggers_section=TriggersSection)?
   (dialogues_section=DialoguesSection)?
   (eservices_section=EServicesSection)?
   (connectors_section=ConnectorsSection)?
   (access_controls_section=AccessControlsSection)?
)#
;

TrainableEntity:
   'Entity' name=ID
       words+=STRING[',']
   'end'
;

PretrainedEntity:
   'PERSON'        |
   'NORP'          |
   'FAC'           |
   'ORG'           |
   'GPE'           |
   'LOC'           |
   'PRODUCT'       |
   'EVENT'         |
   'WORK_OF_ART'   |
   'LAW'           |
   'LANGUAGE'      |
   'DATE'          |
   'TIME'          |
   'PERCENT'       |
   'MONEY'         |
   'QUANTITY'      |
   'ORDINAL'       |
   'CARDINAL'
;

Synonym:
   'Synonym' name=ID
       words+=STRING[',']
   'end'
;

GlobalSlot:
   name=ID ':' type=ParameterType ('=' default=ParameterValue)?
;

Intent:
   'Intent' name=ID
       phrases+=IntentPhrase[',']
   'end'
;

Event:
   'Event' name=ID
       uri=STRING
   'end'
;

Trigger: Intent | Event;

IntentPhrase:
   STRING |
   TrainableEntityRef |
   PretrainedEntityRef |
   SynonymRef
;

TrainableEntityRef:
   'TE:' entity=[TrainableEntity]
;

PretrainedEntityRef:
   'PE:' entity=PretrainedEntity ('[' examples+=STRING[','] ']')?
;

SynonymRef:
   'S:' synonym=[Synonym]
;

ActionGroup:
   'ActionGroup' name=ID
       actions*=Action
   'end'
;

FormParam:
   name=ID ':' type=ParameterType '=' source=FormParamSource
;

Form:
   'Form' name=ID
       params*=FormParam
   'end'
;

Response: ActionGroup | Form | ResponseRef;

ResponseRef:
   response=[ResponseDef]
;

ResponseDef:
   ActionGroup | Form
;

FormParamSource: HRIParamSource | EServiceParamSource;

HRIParamSource:
   'HRI' '(' text=Text (',' '[' extracts+=ExtractionSource[','] ']')? ')'
;

ExtractionSource: EntityExtract | IntentExtract;

EntityExtract:
   TrainableEntityRef | PretrainedEntityRef
;

IntentExtract:
   intent=[Intent] ':' value=ParameterValue
;

EServiceParamSource:
   EServiceCallHTTP
;

SpeakAction:
   'Speak' '(' text=Text ')' ('[' 'roles' '=' roles+=Word[','] ']')?
;

FireEventAction:
   'FireEvent' '(' uri=Text ',' message=ParameterValue ')' ('[' 'roles' '=' roles+=Word[','] ']')?
;

RESTCallAction:
   EServiceCallHTTP
;

SetFormSlotAction:
   'SetFSlot' '(' slot=[FormParam] ',' value=ParameterValue ')' ('[' 'roles' '=' roles+=Word[','] ']')?
;

SetGlobalSlotAction:
   'SetGSlot' '(' slot=[GlobalSlot] ',' value=ParameterValue ')' ('[' 'roles' '=' roles+=Word[','] ']')?
;

Action:
   SpeakAction |
   FireEventAction |
   RESTCallAction |
   SetFormSlotAction |
   SetGlobalSlotAction
;

EServiceHTTP:
   'EServiceHTTP' name=ID
   (
       ('verb:' verb=HTTPVerb)
       ('host:' host=STRING)
       ('port:' port=INT)?
       ('path:' path=STRING)?
   )#
   'end'
;

EServiceDef:
   EServiceHTTP
;

EServiceCallHTTP:
   service=[EServiceHTTP] '('
   (
       ('query=' '[' query_params*=ServiceParam[','] ']')?
       ('header=' '[' header_params*=ServiceParam[','] ']')?
       ('path=' '[' path_params*=ServiceParam[','] ']')?
       ('body=' '[' body_params*=ServiceParam[','] ']')?
   )#
   ')' ('[' filter=ResponseFilter ']')? ('[' 'roles' '=' roles+=Word[','] ']')?
;

ServiceParam:
   name=ID '=' value=ParameterValue
;

ResponseFilter:
   elements+=ResponseElement['.']
;

ResponseElement:
   ID | INT
;

HTTPVerb:
   'GET' | 'POST' | 'PUT'
;

SlackConnector:
   'Connector' 'slack'
   (
       ('token:' token=STRING)
       ('channel:' channel=STRING)
       ('signing_secret:' signing_secret=STRING)
   )#
   'end'
;

TelegramConnector:
   'Connector' 'telegram'
   (
       ('token:' token=STRING)
       ('verify:' verify=STRING)
       ('webhook_url:' webhook_url=STRING)
   )#
   'end'
;

Connector: SlackConnector | TelegramConnector;

RolesDef:
   'Roles'
       roles+=Word[',']
       'default:' default_role=Word
   'end'
;

UserRole:
   role=Word ':' users+=Word[',']
;

UsersDef:
   'Users'
       user_roles*=UserRole
   'end'
;

PolicyDef:
   'Policy' name=ID
       'on:' actions+=Word[',']
       'roles:' roles+=Word[',']
   'end'
;

PathDef:
   'Path'
       path=STRING
   'end'
;

AuthMethod:
   'slot' | 'user_id' | 'slack' | 'telegram'
;

AuthenticationDef:
   'Authentication'
       'method:' method=AuthMethod
       ('slot_name:' slot_name=Word)?
   'end'
;

AccessControlDef:
   (
       roles=RolesDef
       users=UsersDef?
       policies*=PolicyDef
       path=PathDef?
       authentication=AuthenticationDef
   )#
;

ParameterType:
   'int' | 'float' | 'str' | 'bool' | 'list' | 'dict'
;

DictItem:
   key=STRING ':' value=ParameterValue
;

ListValue:
   '[' items*=ParameterValue[','] ']'
;

DictValue:
   '{' items*=DictItem[','] '}'
;

IndexValue:
   ID | INT
;

FormParamRef:
   param=[FormParam] ('[' index=IndexValue ']')?
;

GlobalSlotRef:
   slot=[GlobalSlot] ('[' index=IndexValue ']')?
;

UserPropertyType:
   'NAME' | 'SURNAME' | 'AGE' | 'EMAIL' | 'PHONE' | 'CITY' | 'ADDRESS'
;

SystemPropertyType:
   'TIME' | 'LOCATION' | 'RANDOM_INT' | 'RANDOM_FLOAT'
;

UserProperty:
   'USER:' property=UserPropertyType
;

SystemProperty:
   'SYSTEM:' property=SystemPropertyType
;

Text:
   STRING |
   FormParamRef |
   GlobalSlotRef |
   UserProperty |
   SystemProperty
;

ParameterValue:
   FLOAT |
   INT |
   STRING |
   BOOL |
   ListValue |
   DictValue |
   FormParamRef |
   GlobalSlotRef |
   UserProperty |
   SystemProperty |
   Text
;

Dialogue:
   'Dialogue' name=ID
       'on:' triggers+=[Trigger][',']
       'responses:' responses+=ID[',']
   'end'
;

Word:
   /[-\w ]+/
;

Comment:
   CommentLine | CommentBlock
;

CommentLine:
   /\/\/.*?$/
;

CommentBlock:
   /\/\*(.|\n)*?\*\//
;

EntitiesSection:
   'entities'
       entities*=TrainableEntity
   'end'
;

SynonymsSection:
   'synonyms'
       synonyms*=Synonym
   'end'
;

GSlotsSection:
   'gslots'
       gslots*=GlobalSlot[',']
   'end'
;

TriggersSection:
   'triggers'
       triggers*=Trigger
   'end'
;

DialoguesSection:
   'dialogues'
       dialogues*=Dialogue
   'end'
;

EServicesSection:
   'eservices'
       eservices*=EServiceDef
   'end'
;

ConnectorsSection:
   'connectors'
       connectors*=Connector
   'end'
;

AccessControlsSection:
   'access_controls'
       access_control=AccessControlDef
   'end'
;